function renderXpdSection(mods, product, bw, freq, xpicOn){
  const sec=document.getElementById('xpdSection');
  const thead=document.getElementById('xpdThead');
  const tbody=document.getElementById('xpdTbody');
  const sub=document.getElementById('xpdSectionSub');
  if(!sec||!thead||!tbody) return;

  if(!state.xpdEnabled||!state.isMW){sec.style.display='none';return;}

  const hasXpic=xpicOn;
  const xpdg=state.antennaXpd||30;
  if(sub)sub.textContent=`XPDg=${xpdg} dB · ${freq} GHz · K_XP=0.7 · Smooth surface · ${hasXpic?'XPIC ON':'No XPIC'}`;

  function ciCell(ci){
    if(ci==null||!isFinite(ci)) return '<td style="text-align:center;color:var(--text3)">—</td>';
    const bg=ci>=20?'#d1fae5':ci>=10?'#fef3c7':'#fee2e2';
    const col=ci>=20?'#065f46':ci>=10?'#92400e':'#991b1b';
    return `<td style="padding:3px 8px;text-align:center;font-family:'JetBrains Mono',monospace;font-weight:700;background:${bg};color:${col}">${ci.toFixed(1)}</td>`;
  }

  let hdr=`<tr style="background:var(--navy);color:#e2efff">
    <th style="padding:5px 8px;text-align:left">Modulation</th>
    <th style="padding:5px 8px;text-align:center" title="XPIF from Ceragon product table">XPIF (dB)</th>
    <th style="padding:5px 8px;text-align:center" title="XPD₀ adjusted antenna XPD">XPD₀ (dB)</th>
    <th style="padding:5px 8px;text-align:center" title="Multipath activity factor">η</th>
    <th style="padding:5px 8px;text-align:center" title="XPD multipath protection factor Q">Q (dB)</th>
    <th style="padding:5px 8px;text-align:center" title="Combined XPD protection C = XPD₀+Q">C (dB)</th>
    <th style="padding:5px 8px;text-align:center" title="XPD_RAIN: rain-induced XPD reduction">XPD Rain (dB)</th>
    <th style="padding:5px 8px;text-align:center" title="C/I carrier-to-interference ratio under multipath — without XPIC (Eq.39)">C/I mph<br>no XPIC</th>`;
  if(hasXpic) hdr+=`<th style="padding:5px 8px;text-align:center;background:#064e3b;color:#6ee7b7" title="C/I with XPIC (Eq.40)">C/I mph<br>+XPIC</th>`;
  hdr+=`<th style="padding:5px 8px;text-align:center" title="C/I carrier-to-interference under rain (Eq.42)">C/I rain<br>no XPIC</th>`;
  if(hasXpic) hdr+=`<th style="padding:5px 8px;text-align:center;background:#064e3b;color:#6ee7b7" title="C/I rain with XPIC (Eq.42)">C/I rain<br>+XPIC</th>`;
  hdr+=`</tr>`;
  thead.innerHTML=hdr;

  tbody.innerHTML='';
  mods.forEach((r,i)=>{
    if(!r||!r.xpd) return;
    const x=r.xpd;
    const bg=i%2===0?'background:var(--card-bg)':'background:var(--sl)';
    let row=`<tr style="${bg}">
      <td style="padding:3px 8px;font-weight:600;white-space:nowrap">${r.mod}</td>
      <td style="padding:3px 8px;text-align:center;font-family:'JetBrains Mono',monospace">${x.xpif!=null?x.xpif.toFixed(1):'—'}</td>
      <td style="padding:3px 8px;text-align:center;font-family:'JetBrains Mono',monospace">${x.xpd0.toFixed(1)}</td>
      <td style="padding:3px 8px;text-align:center;font-family:'JetBrains Mono',monospace">${x.eta.toFixed(3)}</td>
      <td style="padding:3px 8px;text-align:center;font-family:'JetBrains Mono',monospace">${x.Q.toFixed(1)}</td>
      <td style="padding:3px 8px;text-align:center;font-family:'JetBrains Mono',monospace;font-weight:700">${x.C.toFixed(1)}</td>
      <td style="padding:3px 8px;text-align:center;font-family:'JetBrains Mono',monospace">${x.xpdRain.toFixed(1)}</td>
      ${ciCell(x.ci_mph)}`;
    if(hasXpic) row+=ciCell(x.ci_mph_xpic);
    row+=ciCell(x.ci_rain);
    if(hasXpic) row+=ciCell(x.ci_rain_xpic);
    row+=`</tr>`;
    tbody.innerHTML+=row;
  });

  sec.style.display='';
}
