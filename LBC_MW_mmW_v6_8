function scaledAtmos(freq,T_C,P_hPa,rho){
  // Use actual WVD directly in the P.676-12 formula for gW
  // Scale gO by pressure and temperature ratio per P.676-12
  const tK_act=T_C+273.15;
  const tK_std=288.15;
  const pScale=(P_hPa/1013.25)*Math.sqrt(tK_std/tK_act);
  const gW=calcGammaW(freq, rho);          // direct calculation with actual rho
  const gO_std=calcGammaO(freq)*pScale;    // scale O2 by pressure & temperature
  return{gW, gO:gO_std};
}
function getAtmos(f){
  if(state&&state.useClimate&&state.climate)
    return scaledAtmos(f,state.climate.T,state.climate.P,state.climate.WVD);
  return aLerp(f);
}

