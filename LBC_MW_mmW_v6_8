  // Reference vertical line datasets at k=1.0 and k=1.33
  const refLines=[
    {k:1.0, label:'k=1.0', color:'rgba(255,255,255,.3)'},
    {k:1.33,label:'k=4/3',color:'rgba(255,165,0,.4)'},
  ].map(r=>({
    label:r.label,
    data:kPoints.map(k=>Math.abs(k-r.k)<0.026?6:null), // just a vertical tick at +6
    borderColor:r.color, backgroundColor:'transparent',
    borderWidth:1, borderDash:[3,3], pointRadius:0, fill:false, tension:0, spanGaps:false,
    yAxisID:'y',
  }));

  html += `
  <div style="margin-top:14px">
    <div style="font-size:11px;font-weight:700;color:var(--navy2);margin-bottom:4px;display:flex;align-items:center;gap:8px">
      &#128200; Received Signal vs Earth Radius Factor (k)
      <span style="font-weight:400;font-size:9.5px;color:var(--text3)">Smooth-earth two-ray model · |Γ|=1 · ${totalKm.toFixed(2)} km · ${freq_ghz} GHz</span>
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:6px">
      ${kCurves.map(c=>`<span style="font-size:9.5px;display:flex;align-items:center;gap:4px">
        <span style="width:16px;height:2px;background:${c.color};display:inline-block;border-radius:1px"></span>${c.label}</span>`).join('')}
      <span style="font-size:9.5px;color:var(--text3);margin-left:auto">k=1.33 (4/3) = dashed orange · k=1.0 = dashed white</span>
    </div>
    <div style="background:#0f172a;border-radius:8px;padding:4px;border:1px solid #334155">
      <canvas id="kFactorChart" style="width:100%;height:260px;display:block"></canvas>
    </div>
    <div style="font-size:9.5px;color:var(--text3);margin-top:4px;text-align:center">
      Best SD: nulls of Main A→Main B fall on peaks of Main A→Div B and Div A→Main B
    </div>
  </div>`;
  // ─────────────────────────────────────────────────────────────────────────────

  panel.innerHTML=html;
  panel.style.display='';

  // Render k-factor chart after DOM update
  requestAnimationFrame(()=>{
    const kCanvas=document.getElementById('kFactorChart');
    if(!kCanvas||typeof Chart==='undefined') return;
    // Destroy previous instance if any
    const prev=Chart.getChart(kCanvas); if(prev) prev.destroy();
    const dark=document.documentElement.getAttribute('data-theme')==='dark';
    new Chart(kCanvas.getContext('2d'),{
      type:'line',
      data:{labels:kPoints, datasets:[...kDatasets,...refLines]},
      options:{
        responsive:false, maintainAspectRatio:false, animation:{duration:0},
        interaction:{mode:'index',intersect:false},
        plugins:{
          legend:{display:false},
          tooltip:{
            backgroundColor:'rgba(15,23,42,.95)',titleColor:'#bae6fd',bodyColor:'#e2e8f0',padding:8,
            callbacks:{
              title:items=>'k = '+items[0].label,
              label:item=>item.raw!=null?item.dataset.label+': '+item.raw.toFixed(1)+' dB':null,
              filter:item=>item.raw!=null&&!item.dataset.label.startsWith('k=')
            }
          }
        },
        scales:{
          x:{
            title:{display:true,text:'Earth Radius Factor (k)',font:{size:9},color:'#94a3b8'},
            grid:{color:'rgba(255,255,255,.08)'},
            ticks:{color:'#94a3b8',font:{size:8},maxTicksLimit:16,
              callback:v=>kPoints[v]%1===0||[0.5,1.33,1.5,2,3,4,5,7,10,15].includes(kPoints[v])?kPoints[v]:''},
          },
          y:{
            title:{display:true,text:'Relative Receive Signal (dB)',font:{size:9},color:'#94a3b8'},
            min:-30, max:6,
            grid:{color:'rgba(255,255,255,.08)'},
            ticks:{color:'#94a3b8',font:{size:8},stepSize:3},
          }
        },
        layout:{padding:{top:6,right:8,bottom:2,left:0}}
      }
    });
  });
}
