      return [...new Set(Array.from({length:n},(_,i)=>all[Math.round(i*step)]))];
    }
    if(mode&&mode.startsWith('mod:')){const p=mode.slice(4);return all.includes(p)?[p]:all;}
    return all;
  }
  const vMods=validMods(state.bw);
  const sel=document.getElementById('chartMods');if(!sel)return vMods;
  const mode=sel.value;
  if(mode==='all')return vMods;
