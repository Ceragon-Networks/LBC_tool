// ===== DMS COORDINATE FORMAT =====
const _dmsMode = {A: false, B: false};

function decToDms(dd){
  const sign = dd < 0 ? -1 : 1;
  dd = Math.abs(dd);
  const d = Math.floor(dd);
  const m = Math.floor((dd - d) * 60);
  const s = parseFloat(((dd - d - m/60) * 3600).toFixed(3));
  return {d: d*sign, m, s};
}

function dmsToDecVal(d, m, s, hemi){
  const sign = (hemi==='S'||hemi==='W') ? -1 : 1;
  return sign * (Math.abs(+d) + (+m)/60 + (+s)/3600);
}

function toggleCoordFmt(site){
  _dmsMode[site] = !_dmsMode[site];
  const dmsRow = document.getElementById('dmsRow'+site);
  const latEl  = document.getElementById('siteLat'+site);
  const lonEl  = document.getElementById('siteLon'+site);
  const btn    = document.getElementById('coordFmtBtn'+site);

  if(_dmsMode[site]){
    // Switch to DMS: populate DMS fields from current DD values
    const lat = parseFloat(latEl.value);
    const lon = parseFloat(lonEl.value);
    if(!isNaN(lat)){
      const dl = decToDms(lat);
      document.getElementById('dmsLatD'+site).value = Math.abs(dl.d);
      document.getElementById('dmsLatM'+site).value = dl.m;
      document.getElementById('dmsLatS'+site).value = dl.s;
      document.getElementById('dmsLatN'+site).value = lat < 0 ? 'S' : 'N';
    }
    if(!isNaN(lon)){
      const dl = decToDms(lon);
      document.getElementById('dmsLonD'+site).value = Math.abs(dl.d);
      document.getElementById('dmsLonM'+site).value = dl.m;
      document.getElementById('dmsLonS'+site).value = dl.s;
      document.getElementById('dmsLonE'+site).value = lon < 0 ? 'W' : 'E';
    }
    dmsRow.style.display = 'flex';
    latEl.style.opacity = '0.4'; latEl.readOnly = true;
    lonEl.style.opacity = '0.4'; lonEl.readOnly = true;
    if(btn){btn.style.background='var(--blue-l)';btn.style.color='var(--blue)';btn.style.borderColor='var(--blue-m)';}
  } else {
    // Switch back to DD
    dmsRow.style.display = 'none';
    latEl.style.opacity = '1'; latEl.readOnly = false;
    lonEl.style.opacity = '1'; lonEl.readOnly = false;
    if(btn){btn.style.background='var(--sl)';btn.style.color='var(--text2)';btn.style.borderColor='var(--border)';}
  }
}

function _applyDms(site){
  const d = +document.getElementById('dmsLatD'+site).value||0;
  const m = +document.getElementById('dmsLatM'+site).value||0;
  const s = +document.getElementById('dmsLatS'+site).value||0;
  const hn= document.getElementById('dmsLatN'+site).value;
  const dL= +document.getElementById('dmsLonD'+site).value||0;
  const mL= +document.getElementById('dmsLonM'+site).value||0;
  const sL= +document.getElementById('dmsLonS'+site).value||0;
  const he= document.getElementById('dmsLonE'+site).value;
  const lat = dmsToDecVal(d, m, s, hn);
  const lon = dmsToDecVal(dL, mL, sL, he);
  if(!isNaN(lat)&&Math.abs(lat)<=90){
    document.getElementById('siteLat'+site).value = lat.toFixed(6);
  }
  if(!isNaN(lon)&&Math.abs(lon)<=180){
    document.getElementById('siteLon'+site).value = lon.toFixed(6);
  }
  // Trigger pin update
  const latV = parseFloat(document.getElementById('siteLat'+site).value);
  const lonV = parseFloat(document.getElementById('siteLon'+site).value);
  if(!isNaN(latV)&&!isNaN(lonV)){
    if(!siteMap)initSiteMap();
    const label = latV.toFixed(4)+'°'+hn+', '+lonV.toFixed(4)+'°'+he;
    if(site==='A') pinSiteA(latV, lonV, label);
    else           pinSiteB(latV, lonV, label);
  }
}

