// ===== MOVE SITE B TO DISTANCE =====

// Compute bearing from A to B in degrees (0=N, 90=E)
function bearingAtoB(latA,lonA,latB,lonB){
  const toR=d=>d*Math.PI/180;
  const dLon=toR(lonB-lonA);
  const y=Math.sin(dLon)*Math.cos(toR(latB));
  const x=Math.cos(toR(latA))*Math.sin(toR(latB))-Math.sin(toR(latA))*Math.cos(toR(latB))*Math.cos(dLon);
  return (Math.atan2(y,x)*180/Math.PI+360)%360;
}

// Destination point given start, bearing (deg) and distance (km) - Vincenty formula
function destPoint(lat,lon,bearing,distKm){
  const R=6371;
  const toR=d=>d*Math.PI/180, toD=r=>r*180/Math.PI;
  const brg=toR(bearing);
  const lat1=toR(lat), lon1=toR(lon);
  const d=distKm/R;
  const lat2=Math.asin(Math.sin(lat1)*Math.cos(d)+Math.cos(lat1)*Math.sin(d)*Math.cos(brg));
  const lon2=lon1+Math.atan2(Math.sin(brg)*Math.sin(d)*Math.cos(lat1),Math.cos(d)-Math.sin(lat1)*Math.sin(lat2));
  return{lat:toD(lat2),lon:toD(lon2)};
}

function moveSiteBToDistance(){
  const latA=parseFloat(document.getElementById('siteLatA')?.value);
  const lonA=parseFloat(document.getElementById('siteLonA')?.value);
  if(isNaN(latA)||isNaN(lonA)){
    alert('Please set Site A location first.');return;
  }
  const rawDist=parseFloat(document.getElementById('setDistInput').value);
  if(isNaN(rawDist)||rawDist<=0){
    alert('Please enter a valid distance.');return;
  }
  // Convert to km if FCC (miles)
  const distKm=state.std==='FCC'?rawDist*1.60934:rawDist;

  // Get bearing: use current A→B bearing if B exists, else 90° (East) as default
  let bearing=parseFloat(document.getElementById('setDistBearing').value);
  if(isNaN(bearing)){
    const latB=parseFloat(document.getElementById('siteLatB')?.value);
    const lonB=parseFloat(document.getElementById('siteLonB')?.value);
    if(!isNaN(latB)&&!isNaN(lonB)){
      bearing=bearingAtoB(latA,lonA,latB,lonB);
    } else {
      bearing=90; // default East
    }
  }

  // Compute new Site B position
  const dest=destPoint(latA,lonA,bearing,distKm);
  const label=dest.lat.toFixed(4)+'°, '+dest.lon.toFixed(4)+'°';

  // Update Site B
  document.getElementById('siteLatB').value=dest.lat.toFixed(6);
  document.getElementById('siteLonB').value=dest.lon.toFixed(6);
  if(!siteMap)initSiteMap();
  pinSiteB(dest.lat,dest.lon,label);
  reverseGeocodeSite(dest.lat,dest.lon,'B');
  updateDmsFromDd('B');
}

