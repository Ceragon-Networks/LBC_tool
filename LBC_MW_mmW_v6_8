// Step TX frequency through band presets (dir: +1 or -1)
function stepMwFreq(dir){
  const band=state.mwBand;
  const r=MW_BAND_RANGES[band]; if(!r||!r.presets||!r.presets.length)return;
  const presets=r.presets; // in MHz
  const curMHz=state.freqMHz||Math.round((r.low+r.high)/2);
  // Find closest preset index
  let idx=0,minD=Infinity;
  presets.forEach((p,i)=>{const d=Math.abs(p-curMHz);if(d<minD){minD=d;idx=i;}});
  const newIdx=Math.max(0,Math.min(presets.length-1,idx+dir));
  const newMHz=presets[newIdx];
  const newGHz=parseFloat((newMHz/1000).toFixed(3));
  const inp=document.getElementById('mwFreq'); if(!inp)return;
  inp.value=newGHz;
  state.freqMHz=newMHz;
  state.freq=band;
  updateMwFreqPresetHint(band,newIdx);
  updateMwStepButtons(band,newIdx);
  populateMwAntennas();
  updateBlHint();
  update(true);
}
// Show preset position hint  e.g. "Step 3 / 9 — Center"
function updateMwFreqPresetHint(band,idx){
  const r=MW_BAND_RANGES[band]; if(!r||!r.presets)return;
  const n=r.presets.length;
  const el=document.getElementById('mwFreqPresetHint'); if(!el)return;
  const labels={0:'Start','-1':'Stop'};
  const pos=idx===0?'Start':idx===n-1?'Stop':idx===Math.floor((n-1)/2)?'Center':'Step '+(idx+1);
  el.textContent='Preset '+(idx+1)+' / '+n+' — '+pos;
}
// Disable ◀/▶ at band edges
function updateMwStepButtons(band,idx){
  const r=MW_BAND_RANGES[band]; if(!r||!r.presets)return;
  const n=r.presets.length;
  const dn=document.getElementById('mwFreqDown');
  const up=document.getElementById('mwFreqUp');
  if(dn)dn.disabled=(idx<=0);
  if(up)up.disabled=(idx>=n-1);
  if(dn)dn.style.opacity=(idx<=0)?'0.35':'1';
  if(up)up.style.opacity=(idx>=n-1)?'0.35':'1';
}
function onMwFreqInput(){
  const inp=document.getElementById('mwFreq'); if(!inp)return;
  const GHz=parseFloat(inp.value);
  if(!isFinite(GHz))return;
  const MHz=Math.round(GHz*1000);
  // Auto-detect band from MHz value
  const detected=detectMwBand(MHz);
  if(detected){
    const sel=document.getElementById('mwBandSel');
    if(sel&&+sel.value!==detected){
      const product=state.mwProduct||'IP-20C';
      const supported=MW_PRODUCT_BANDS[product]||[];
      if(supported.includes(detected)){
        sel.value=detected;
        const r=MW_BAND_RANGES[detected];
        const lG=(r.low/1000).toFixed(2).replace(/\.?0+$/,'');
        const hG=(r.high/1000).toFixed(2).replace(/\.?0+$/,'');
        inp.min=(r.low/1000).toFixed(3); inp.max=(r.high/1000).toFixed(3);
        inp.placeholder=lG+' – '+hG+' GHz';
        const hint=document.getElementById('mwFreqHint');
        if(hint)hint.textContent='Range: '+lG+' – '+hG+' GHz';
      }
    }
    state.mwBand=detected;
    state.freq=detected;
    // Update preset hint & buttons based on nearest preset
    const r=MW_BAND_RANGES[detected];
    if(r&&r.presets){
      let minD=Infinity,nearIdx=0;
      r.presets.forEach((p,i)=>{const d=Math.abs(p-MHz);if(d<minD){minD=d;nearIdx=i;}});
      updateMwFreqPresetHint(detected,nearIdx);
      updateMwStepButtons(detected,nearIdx);
    }
  }
  state.freqMHz=MHz;
  populateMwAntennas();
  updateBlHint();
  update();
}
