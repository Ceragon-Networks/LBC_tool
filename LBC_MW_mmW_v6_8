// ===== FORMATTERS =====
function fmtSec(s){
  if(s<=0)return '0 s';
  if(s<1)return s.toFixed(2)+' s';if(s<120)return s.toFixed(1)+' s';
  const h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sc=Math.round(s%60);
  return h>0?h+'h '+m+'m':m+'m '+sc+'s';
}
// Format seconds as d:hh:mm:ss — used for "Time in Modulation" column
function fmtDHMS(s){
  if(s<=0)return '0d 00:00:00';
  const t=Math.round(Math.max(s,0));
  const dd=Math.floor(t/86400);
  const hh=Math.floor((t%86400)/3600);
  const mm=Math.floor((t%3600)/60);
  const ss=t%60;
  return dd+'d '+String(hh).padStart(2,'0')+':'+String(mm).padStart(2,'0')+':'+String(ss).padStart(2,'0');
}
function fmtA(v){
  if(v>=100)return '100.000000';
  if(v>=99.9999)return v.toFixed(6);if(v>=99.999)return v.toFixed(5);
  if(v>=99.99)return v.toFixed(4);return v.toFixed(3);
}
function n(v,dp=2){return(isNaN(v)||v===undefined)?'—':v.toFixed(dp);}
function setEl(id,txt,cls){const e=document.getElementById(id);if(!e)return;e.textContent=txt;if(cls!==undefined)e.className='brow-v '+(cls||'');}

