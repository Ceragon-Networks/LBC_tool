    }

    // Show suggestion on map and in panel
    showPeakSuggestion(best.lat, best.lon, maxElev, gainM, site);

    // Show inline suggestion panel
    let panel = document.getElementById('peakSuggestion');
    if(!panel){
      panel = document.createElement('div');
      panel.id = 'peakSuggestion';
      panel.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);z-index:9999;'+
        'background:#ecfdf5;border:2px solid #10b981;border-radius:10px;padding:12px 18px;'+
        'font-size:12px;box-shadow:0 4px 20px rgba(0,0,0,.25);text-align:center;min-width:320px;';
      document.body.appendChild(panel);
    }
    const dispDist = radius+' '+lenUnitLbl();
    panel.innerHTML =
      '<div style="font-weight:700;color:#065f46;font-size:13px;margin-bottom:6px">'+
        '⬆ Higher Ground Found — Site '+site+'</div>'+
      '<div style="color:#047857;margin-bottom:8px">'+
        'Peak elevation: <strong>'+fmtLen(maxElev)+' ASL</strong> '+
        '(+<strong>'+fmtLen(gainM)+'</strong> above current pin)<br>'+
        'Distance from pin: ~'+dispDist+' &nbsp;&middot;&nbsp; Bearing: ~'+best.angle+'°'+
      '</div>'+
      '<div style="display:flex;gap:8px;justify-content:center">'+
        '<button onclick="acceptPeakSuggestion('+best.lat+','+best.lon+',\''+site+'\')" '+
          'style="padding:6px 18px;background:#059669;color:#fff;border:none;border-radius:6px;cursor:pointer;font-weight:600">'+
          '✓ Accept — Move Site '+site+'</button>'+
        '<button onclick="dismissPeakSuggestion()" '+
          'style="padding:6px 14px;background:#f3f4f6;color:#374151;border:1px solid #d1d5db;border-radius:6px;cursor:pointer">'+
          '✗ Dismiss</button>'+
      '</div>';
    panel.style.display = 'block';

  }catch(e){
    alert('Peak search failed: '+e.message);
  }
  clearInterval(_scanTimer);
  if(btn){btn.textContent='⬆ Peak';btn.disabled=false;}
}

