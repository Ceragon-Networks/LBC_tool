// ===== TERRAIN PROFILE & LOS =====
// ══ Reflection Analysis for Space Diversity Planning (ITU-R P.530) ══════════

// ── Smooth-earth two-ray model: received signal (dB) vs k-factor ─────────────
// h1_asl / h2_asl: antenna heights ASL (m); d_km: path length (km); k: earth radius factor
function smoothEarthSignal(h1_asl, h2_asl, d_km, freq_ghz, k){
  const Re_km = 6371;
  const lambda = 300 / (freq_ghz * 1000); // wavelength (m)
  const d_m = d_km * 1000;

  // Earth surface at x km from A: chord (flat interpolation, elev treated as 0) + bulge
  // Bulge B(x) = x*(d-x)*1000 / (2*k*Re_km) [metres, x and d in km]
  function earthZ(x_km){ return x_km*(d_km-x_km)*1000/(2*k*Re_km); }

  // Reflection condition: (h1_asl - z(x)) * (d-x) = (h2_asl - z(x)) * x
  function cond(x){ const z=earthZ(x); return (h1_asl-z)*(d_km-x)-(h2_asl-z)*x; }

  // Bisection — find specular reflection point x_r (km)
  let lo=0.001*d_km, hi=0.999*d_km;
  if(cond(lo)*cond(hi)>0) return null; // no valid reflection (geometry blocked)
  let xr=(lo+hi)/2;
  for(let i=0;i<60;i++){
    xr=(lo+hi)/2;
    const c=cond(xr); if(Math.abs(c)<1e-5) break;
    cond(lo)*c>0?lo=xr:hi=xr;
  }

  const zr=earthZ(xr);
  if(zr>=h1_asl||zr>=h2_asl) return null; // earth blocks path

  const d1_m=xr*1000, d2_m=(d_km-xr)*1000;
  const d_inc=Math.sqrt(d1_m**2+(h1_asl-zr)**2);
  const d_rfr=Math.sqrt(d2_m**2+(h2_asl-zr)**2);
  const d_dir=Math.sqrt(d_m**2+(h2_asl-h1_asl)**2);
  const delta=d_inc+d_rfr-d_dir; // path difference (m)

  // Reflected signal: |1 + Γ·e^jφ| with Γ=-1 (smooth surface phase reversal)
  // = 2|sin(π·Δ/λ)|
  const phi=Math.PI*delta/lambda;
  const sig=2*Math.abs(Math.sin(phi));
  return 20*Math.log10(Math.max(sig,1e-10));
}
// ─────────────────────────────────────────────────────────────────────────────

// Compute specular reflection point + path difference for one antenna pair
// hTx_agl/hRx_agl: heights AGL (m), elevations from Tx end (index 0=Tx site)
function calcReflPath(hTx_agl, hRx_agl, elevations, distances, totalKm, freq_ghz){
  const n   = elevations.length - 1;
  const eA  = elevations[0], eB = elevations[n];
  const hTx = eA + hTx_agl;  // Tx antenna ASL
  const hRx = eB + hRx_agl;  // Rx antenna ASL

  // Specular reflection point: minimise |sinθ_i - sinθ_r| on actual terrain
  // Condition: (hTx-elev[i])/dist[i] = (hRx-elev[i])/(total-dist[i])
  let bestI=Math.round(n/2), bestErr=Infinity;
  for(let i=1;i<n;i++){
    const e=elevations[i], d1=distances[i], d2=totalKm-d1;
    if(d1<0.001||d2<0.001) continue;
    if(hTx<=e||hRx<=e) continue;  // antenna below terrain at reflection point
    const err=Math.abs((hTx-e)*d2-(hRx-e)*d1);
    if(err<bestErr){bestErr=err;bestI=i;}
  }

  const rDist=distances[bestI];       // km from Tx site
  const rElev=elevations[bestI];      // m ASL
  const d1_m=rDist*1000, d2_m=(totalKm-rDist)*1000, dT_m=totalKm*1000;

  // Path lengths
  const d_inc = Math.sqrt(d1_m**2+(hTx-rElev)**2);  // Tx → reflection point
  const d_rfr = Math.sqrt(d2_m**2+(hRx-rElev)**2);  // reflection point → Rx
  const d_dir = Math.sqrt(dT_m**2+(hRx-hTx)**2);    // direct path

  const delta = d_inc + d_rfr - d_dir;               // path difference (m)
  const lambda = 300/(freq_ghz*1000);                 // wavelength (m)

  // Phase: 2π×Δ/λ + π (π = phase reversal for smooth surface)
  const ph_rad = 2*Math.PI*delta/lambda + Math.PI;
  const ph_deg = ((ph_rad*180/Math.PI)%360+360)%360;

  // Grazing angle (deg)
  const graz = Math.atan2(hTx-rElev, d1_m)*180/Math.PI;

  return {rDist, rElev, rI:bestI, delta, lambda, ph_deg, graz, hTx, hRx, hTx_agl, hRx_agl};
}

// Build all 4 reflection paths for current antenna config
function buildReflPaths(elevations, distances, totalKm, hA_agl, hB_agl, sdSep, freq_ghz){
  // Forward paths (A→B), index 0 = Site A
  const p1 = calcReflPath(hA_agl,        hB_agl,        elevations, distances, totalKm, freq_ghz);
  const p2 = calcReflPath(hA_agl,        hB_agl-sdSep,  elevations, distances, totalKm, freq_ghz);
  // Reverse paths (B→A): flip arrays so index 0 = Site B
  const elevR=[...elevations].reverse();
  const distR=distances.map(d=>parseFloat((totalKm-d).toFixed(4))).reverse();
  const p3r = calcReflPath(hB_agl,       hA_agl,        elevR, distR, totalKm, freq_ghz);
  const p4r = calcReflPath(hB_agl,       hA_agl-sdSep,  elevR, distR, totalKm, freq_ghz);
  // Convert reflection distances back to "from A" reference
  const p3={...p3r, rDist:totalKm-p3r.rDist, rI:n-p3r.rI};
  const p4={...p4r, rDist:totalKm-p4r.rDist, rI:n-p4r.rI};
  function n_(){return elevations.length-1;}
  p3.rI=Math.max(0,Math.min(elevations.length-1, elevations.length-1-p3r.rI));
  p4.rI=Math.max(0,Math.min(elevations.length-1, elevations.length-1-p4r.rI));
  return [
    {name:'Main A → Main B',  short:'M-A→M-B', color:'#2563eb', dash:[6,3], ...p1},
    {name:'Main A → Div B',   short:'M-A→D-B', color:'#0891b2', dash:[4,3], ...p2},
    {name:'Main B → Main A',  short:'M-B→M-A', color:'#d97706', dash:[6,3], ...p3},
    {name:'Main B → Div A',   short:'M-B→D-A', color:'#059669', dash:[4,3], ...p4},
  ];
}

// Optimal SD separation (flat earth, symmetric formula)
function optSdSep(hA_agl, hB_agl, totalKm, freq_ghz){
  const lambda=300/(freq_ghz*1000);
  const d_m=totalKm*1000;
  // Phase diff between Main-B and Div-B at receive: ΔΦ=4π·hA·S/(λ·d)=π → S=λd/(4hA)
  const sAB = lambda*d_m/(4*Math.max(hA_agl,0.1));
  const sBA = lambda*d_m/(4*Math.max(hB_agl,0.1));
  const sGeo= lambda*d_m/(4*Math.sqrt(Math.max(hA_agl,0.1)*Math.max(hB_agl,0.1)));
  return {sAB, sBA, sGeo, lambda, d_m,
    multiples: [1,2,3,4].map(k=>({k, s:k*sGeo}))};
}

// Render reflection analysis table below terrain chart
function renderReflectionPanel(paths, hA_agl, hB_agl, sdSep, totalKm, freq_ghz, elevations, distances){
  const panel=document.getElementById('reflectionPanel'); if(!panel)return;
  const curSep=sdSep;
  const f=v=>isFinite(v)?v.toFixed(1):'—';
  const fm=v=>isFinite(v)?(v*1000).toFixed(1):'—';

  // Normalise phase difference to 0–180°
  const normPd=pd=>{const r=((pd%360)+360)%360; return r>180?360-r:r;};

  // Phase diffs at current separation
  const pd_AB=normPd(paths[1].ph_deg-paths[0].ph_deg);
  const pd_BA=normPd(paths[3].ph_deg-paths[2].ph_deg);

  function phaseBadge(pd){
    if(pd>150)return`<span style="background:#d1fae5;color:#065f46;padding:1px 7px;border-radius:4px;font-weight:700;font-size:10px">✓ GOOD (${f(pd)}°)</span>`;
    if(pd>90) return`<span style="background:#fef3c7;color:#92400e;padding:1px 7px;border-radius:4px;font-weight:700;font-size:10px">~ FAIR (${f(pd)}°)</span>`;
    return        `<span style="background:#fee2e2;color:#991b1b;padding:1px 7px;border-radius:4px;font-weight:700;font-size:10px">✗ POOR (${f(pd)}°)</span>`;
  }

  // ── Separation sweep 8–20 m in 0.5 m steps ──────────────────────────────
  const elevR=[...elevations].reverse();
  const distR=distances.map(d=>parseFloat((totalKm-d).toFixed(4))).reverse();
  const ph1=paths[0].ph_deg; // Main A→Main B — constant
  const ph3=paths[2].ph_deg; // Main B→Main A — constant

  const sweepRows=[];
  for(let s=8.0;s<=20.01;s+=0.5){
    const sv=parseFloat(s.toFixed(1));
    // Only recompute the diversity paths (p2 and p4) — p1/p3 are separation-independent
    const p2=calcReflPath(hA_agl, hB_agl-sv, elevations, distances, totalKm, freq_ghz);
    const p4r=calcReflPath(hB_agl, hA_agl-sv, elevR, distR, totalKm, freq_ghz);
    const pd2=normPd(p2.ph_deg-ph1);
    const pd4=normPd(p4r.ph_deg-ph3);
    // Vigants I_SD at reference fade margin A=30dB for comparison across separations
    // (actual I_SD is mod-dependent; this gives the separation sensitivity trend)
    const refA=30;
    const isd=Math.max(1, 1.2e-3*(freq_ghz/totalKm)*sv*sv*Math.pow(10,refA/10));
    const isd_db=10*Math.log10(isd);
    const worst=Math.min(pd2,pd4);
    sweepRows.push({s:sv, pd_AB:pd2, pd_BA:pd4, worst, isd_db});
  }

  // Row background by worst-case phase diff
  function rowBg(worst,isCur){
    if(isCur) return 'background:#dbeafe;border-left:3px solid #2563eb';
    if(worst>150) return 'background:#f0fdf4';
    if(worst>90)  return 'background:#fefce8';
    return              'background:#fff1f2';
  }
  function pdCell(pd){
    const col=pd>150?'#065f46':pd>90?'#92400e':'#991b1b';
    return `<td style="padding:3px 7px;text-align:center;font-family:'JetBrains Mono',monospace;font-weight:700;color:${col}">${f(pd)}</td>`;
  }

  let html=`
  <div style="font-size:11px;font-weight:700;color:var(--navy2);margin-bottom:8px;display:flex;align-items:center;gap:8px">
    &#9672; Reflection Analysis — ${freq_ghz} GHz · ${totalKm.toFixed(2)} km
    <span style="font-weight:400;font-size:10px;color:var(--text3)">Specular reflection · smooth surface model</span>
  </div>

  <div style="overflow-x:auto">
  <table style="width:100%;border-collapse:collapse;font-size:10.5px;margin-bottom:12px">
    <thead><tr style="background:var(--navy);color:#e2efff">
      <th style="padding:5px 8px;text-align:left;white-space:nowrap">Path</th>
      <th style="padding:5px 8px;text-align:center">h Tx / h Rx (m)</th>
      <th style="padding:5px 8px;text-align:center">Refl. dist from A</th>
      <th style="padding:5px 8px;text-align:center">Refl. elev (m ASL)</th>
      <th style="padding:5px 8px;text-align:center">Grazing (°)</th>
      <th style="padding:5px 8px;text-align:center">Path Δ (mm)</th>
      <th style="padding:5px 8px;text-align:center">Phase (°)</th>
    </tr></thead><tbody>`;

  paths.forEach((p,i)=>{
    const bg=i%2===0?'background:var(--card-bg)':'background:var(--sl)';
    const dot=`<span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:${p.color};margin-right:5px"></span>`;
    const distLabel=isFCC()?`${(p.rDist*0.62137).toFixed(2)} mi`:`${p.rDist.toFixed(2)} km`;
    html+=`<tr style="${bg}">
      <td style="padding:4px 8px;font-weight:600;white-space:nowrap">${dot}${p.name}</td>
      <td style="padding:4px 8px;text-align:center;font-family:'JetBrains Mono',monospace">${f(p.hTx_agl)} / ${f(p.hRx_agl)}</td>
      <td style="padding:4px 8px;text-align:center;font-family:'JetBrains Mono',monospace">${distLabel}</td>
      <td style="padding:4px 8px;text-align:center;font-family:'JetBrains Mono',monospace">${f(p.rElev)}</td>
      <td style="padding:4px 8px;text-align:center;font-family:'JetBrains Mono',monospace">${f(p.graz)}</td>
      <td style="padding:4px 8px;text-align:center;font-family:'JetBrains Mono',monospace;font-weight:700">${fm(p.delta)}</td>
      <td style="padding:4px 8px;text-align:center;font-family:'JetBrains Mono',monospace;font-weight:700;color:${p.color}">${f(p.ph_deg)}</td>
    </tr>`;
  });
  html+=`</tbody></table></div>

  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
    <div style="font-size:11px;font-weight:700;color:var(--navy2)">&#9670; Separation Sweep — 8 to 20 m</div>
    <div style="font-size:10px;color:var(--text3)">Phase diff ≥150° = good SD · Click a row to apply</div>
  </div>
  <div style="overflow-x:auto;border:1px solid var(--border-l);border-radius:8px">
  <table style="width:100%;border-collapse:collapse;font-size:10.5px">
    <thead><tr style="background:var(--navy);color:#e2efff;position:sticky;top:0">
      <th style="padding:5px 10px;text-align:center;white-space:nowrap">Sep (m)</th>
      <th style="padding:5px 10px;text-align:center;white-space:nowrap" title="Phase difference between Main-A→Main-B and Main-A→Div-B reflected signals">ΔΦ A→B (°)</th>
      <th style="padding:5px 10px;text-align:center;white-space:nowrap" title="Phase difference between Main-B→Main-A and Main-B→Div-A reflected signals">ΔΦ B→A (°)</th>
      <th style="padding:5px 10px;text-align:center;white-space:nowrap" title="Vigants SD improvement factor at A=30 dB reference fade margin. Actual I_SD per modulation shown in link budget.">I_SD @ A=30dB</th>
      <th style="padding:5px 10px;text-align:center;white-space:nowrap">Status</th>
      <th style="padding:5px 10px;text-align:center;white-space:nowrap">Apply</th>
    </tr></thead><tbody>`;

  sweepRows.forEach(r=>{
    const isCur=Math.abs(r.s-curSep)<0.26;
    const bg=rowBg(r.worst,isCur);
    const status=r.worst>150?'✓ GOOD':r.worst>90?'~ FAIR':'✗ POOR';
    const stCol=r.worst>150?'#065f46':r.worst>90?'#92400e':'#991b1b';
    html+=`<tr style="${bg};cursor:pointer" onclick="applySdSep(${r.s})">
      <td style="padding:4px 10px;text-align:center;font-family:'JetBrains Mono',monospace;font-weight:${isCur?700:600}">${r.s.toFixed(1)}</td>
      ${pdCell(r.pd_AB)}${pdCell(r.pd_BA)}
      <td style="padding:4px 10px;text-align:center;font-family:'JetBrains Mono',monospace;color:var(--teal-d)">${r.isd_db.toFixed(1)}</td>
      <td style="padding:4px 10px;text-align:center;font-weight:700;color:${stCol}">${status}</td>
      <td style="padding:4px 10px;text-align:center">
        <button onclick="event.stopPropagation();applySdSep(${r.s})"
          style="padding:2px 10px;border-radius:4px;font-size:10px;font-weight:600;cursor:pointer;
          border:1px solid ${isCur?'#2563eb':'var(--border)'};
          background:${isCur?'#2563eb':'var(--sl)'};color:${isCur?'#fff':'var(--text2)'};white-space:nowrap">
          ${isCur?'✓ Active':'Apply'}
        </button>
      </td>
    </tr>`;
  });

  html+=`</tbody></table></div>
  <div style="margin-top:6px;display:flex;justify-content:space-between;align-items:center">
    <div style="display:flex;gap:12px;font-size:9.5px">
      <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:#f0fdf4;border:1px solid #86efac;display:inline-block;border-radius:2px"></span>≥150° Good</span>
      <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:#fefce8;border:1px solid #fde047;display:inline-block;border-radius:2px"></span>90–150° Fair</span>
      <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:#fff1f2;border:1px solid #fecdd3;display:inline-block;border-radius:2px"></span>&lt;90° Poor</span>
      <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:#dbeafe;border-left:3px solid #2563eb;display:inline-block;border-radius:2px"></span>Current</span>
    </div>
    <div style="font-size:9.5px;color:var(--text3)">λ = ${(300/(freq_ghz*1000)*1000).toFixed(1)} mm · Phase diff at A→B and B→A receive ends · worst case drives Status</div>
  </div>`;

  // ── Received Signal vs k-factor chart (smooth-earth two-ray model) ──────────
  const elevA=elevations[0], elevB=elevations[elevations.length-1];
  const kPoints=[];
  for(let k=0.3;k<=15.01;k+=0.05) kPoints.push(parseFloat(k.toFixed(2)));

  // 4 antenna ASL combinations
  const kCurves=[
    {label:'Main A → Main B', color:'#2563eb', h1:hA_agl+elevA, h2:hB_agl+elevB},
    {label:'Main A → Div B',  color:'#0891b2', h1:hA_agl+elevA, h2:(hB_agl-sdSep)+elevB},
    {label:'Div A → Main B',  color:'#d97706', h1:(hA_agl-sdSep)+elevA, h2:hB_agl+elevB},
    {label:'Div A → Div B',   color:'#059669', h1:(hA_agl-sdSep)+elevA, h2:(hB_agl-sdSep)+elevB},
  ].filter(c=>c.h1>elevA&&c.h2>elevB); // skip curves with negative AGL

  const kDatasets=kCurves.map(c=>({
    label:c.label,
    data:kPoints.map(k=>{const v=smoothEarthSignal(c.h1,c.h2,totalKm,freq_ghz,k);return v!==null?parseFloat(v.toFixed(2)):null;}),
    borderColor:c.color, backgroundColor:'transparent',
    borderWidth:1.8, pointRadius:0, fill:false, tension:0, spanGaps:false,
