  if (f >= pts[pts.length-1][0]) return pts[pts.length-1][1];
  for (let i = 1; i < pts.length; i++) {
    if (f <= pts[i][0]) {
      const t = (f - pts[i-1][0]) / (pts[i][0] - pts[i-1][0]);
      return pts[i-1][1] + t * (pts[i][1] - pts[i-1][1]);
    }
  }
