// ===== RANGE SWEEP REPORT =====
let rrResults=null, rrAvailTargets=[99,99.9,99.95,99.99,99.995,99.999];

function rrCapStyle(cap,maxCap){
  if(cap===null||cap===undefined||cap<=0) return 'background:#dc2626;color:#fff;text-align:center;';
  const f=cap/maxCap;
  if(f>=0.85) return 'background:#166534;color:#fff;text-align:center;';
  if(f>=0.65) return 'background:#16a34a;color:#fff;text-align:center;';
  if(f>=0.42) return 'background:#86efac;color:#14532d;text-align:center;';
  if(f>=0.22) return 'background:#fde047;color:#713f12;text-align:center;';
  if(f>=0.06) return 'background:#f97316;color:#fff;text-align:center;';
  return 'background:#ef4444;color:#fff;text-align:center;';
}

function rrInitDefaults(){
  const d=state.distance||1;
  const isMW=state.isMW;
  const defMin=parseFloat(Math.max(0.1,d*0.3).toFixed(isMW?0:1));
  const defMax=parseFloat(Math.max(defMin+1,d*3).toFixed(isMW?0:1));
  const rawStep=(defMax-defMin)/20;
  const defStep=isMW?Math.max(1,Math.round(rawStep)):parseFloat(Math.max(0.1,rawStep).toFixed(1));
  const unit=isFCC()?'miles':'km';
  const toU=v=>isFCC()?parseFloat(kmToMi(v).toFixed(2)):v;
  ['Min','Max','Step'].forEach(k=>{
    const el=document.getElementById('rr'+k);
    const lbl=document.getElementById('rr'+k+'Lbl');
    if(el&&!el._touched) el.value=toU(k==='Min'?defMin:k==='Max'?defMax:defStep);
    if(lbl) lbl.textContent=k+(k==='Step'?' ('+unit+')':[' Min',' Max'][['Min','Max'].indexOf(k)]!==undefined?' ('+unit+')':' ('+unit+')');
  });
  // Label refresh
  const lm=document.getElementById('rrMinLbl'),lx=document.getElementById('rrMaxLbl'),ls=document.getElementById('rrStepLbl');
  if(lm)lm.textContent='Min ('+unit+')';
  if(lx)lx.textContent='Max ('+unit+')';
  if(ls)ls.textContent='Step ('+unit+')';
}

['rrMin','rrMax','rrStep'].forEach(id=>{
  document.addEventListener('DOMContentLoaded',()=>{
    const el=document.getElementById(id);
    if(el) el.addEventListener('input',()=>el._touched=true);
  });
});

function calcRangeReport(){
  const toKm=v=>isFCC()?v*1.60934:v;
  const minD=toKm(parseFloat(document.getElementById('rrMin')?.value));
  const maxD=toKm(parseFloat(document.getElementById('rrMax')?.value));
  const stepD=toKm(parseFloat(document.getElementById('rrStep')?.value));
  const statusEl=document.getElementById('rrStatus');
  const wrapEl=document.getElementById('rrTableWrap');
  const xlBtn=document.getElementById('rrXlBtn');
  const goBtn=document.getElementById('rrGoBtn');

  if(isNaN(minD)||isNaN(maxD)||isNaN(stepD)||stepD<=0||minD>=maxD||minD<0.05){
    if(statusEl)statusEl.textContent='⚠ Invalid range — check min < max and step > 0';
    return;
  }
  const MAX_ROWS=300;
  const effStep=Math.max(stepD,(maxD-minD)/(MAX_ROWS-1));
  const n=Math.min(MAX_ROWS,Math.floor((maxD-minD)/effStep)+1);
  if(statusEl)statusEl.textContent='⏳ Computing '+n+' distances…';
  if(wrapEl)wrapEl.innerHTML='';
  if(xlBtn)xlBtn.style.display='none';
  if(goBtn){goBtn.disabled=true;goBtn.textContent='⏳ …';}

  setTimeout(()=>{
    const results=[];
    for(let i=0;i<n;i++){
      const d=parseFloat((minD+i*effStep).toFixed(6));
      if(d>maxD+1e-6)break;
      const c=computeWith(Object.assign({},state,{distance:d}));
      if(!c||!c.mods||!c.mods.length)continue;
      const topMod=c.mods[c.mods.length-1];
      const rssi=topMod?parseFloat(topMod.rxu.toFixed(1)):null;
      const caps={};
      for(const av of rrAvailTargets){
        let bestCap=null;
        for(let mi=c.mods.length-1;mi>=0;mi--){
          if(c.mods[mi].avail>=av){
            const cap=getCap(state.bw,c.mods[mi].mod,state.frameIdx||0);
            if(cap!==null){bestCap=cap;break;}
          }
        }
        caps[av]=bestCap;
      }
      results.push({d,rssi,caps});
    }
    rrResults=results;

    if(!results.length){
      if(statusEl)statusEl.textContent='No valid results — check link settings.';
      if(goBtn){goBtn.disabled=false;goBtn.textContent='▶ Generate';}
      return;
    }

    let maxCap=0;
    results.forEach(r=>rrAvailTargets.forEach(av=>{if(r.caps[av])maxCap=Math.max(maxCap,r.caps[av]);}));

    const unit=isFCC()?'miles':'km';
    const dispD=d=>isFCC()?kmToMi(d):d;
    const fi=state.frameIdx||0;

    // ── Build table ──────────────────────────────────────────────────────────
    let html='<table class="rr-tbl"><thead><tr>';
    html+=`<th class="rr-thl">Distance (${unit})</th>`;
    html+='<th>RSSI (dBm)</th>';
    rrAvailTargets.forEach(av=>{
      const label=av>=99.99?av+'%':av+'%';
      html+=`<th style="min-width:58px">${label}</th>`;
    });
    html+='</tr></thead><tbody>';

    results.forEach(r=>{
      const dv=dispD(r.d);
      // nice display: show 3 decimal places, strip trailing zeros
      const ds=dv.toFixed(3).replace(/\.?0+$/,'');
      html+=`<tr>`;
      html+=`<td class="rr-td-d">${ds}</td>`;
      html+=`<td class="rr-td-r">${r.rssi!==null?r.rssi.toFixed(1):'—'}</td>`;
      rrAvailTargets.forEach(av=>{
        const cap=r.caps[av];
        const style=rrCapStyle(cap,maxCap);
        const txt=cap!==null?fmtCap(cap).replace(' Mbps','').replace(' Gbps','G'):'✗';
        html+=`<td style="${style}">${txt}</td>`;
      });
      html+='</tr>';
    });
    html+='</tbody></table>';

    if(wrapEl)wrapEl.innerHTML=html;
    const stepNote=effStep>stepD?` (auto-adjusted to ${(isFCC()?kmToMi(effStep):effStep).toFixed(3)} ${unit})`:' ';
    if(statusEl)statusEl.textContent=`✓ ${results.length} distances · step ${(isFCC()?kmToMi(effStep):effStep).toFixed(3)} ${unit}${stepNote}· RSSI = unfaded RX @ highest modulation · capacity frame: ${CAP_SIZES[fi]}`;
    if(xlBtn)xlBtn.style.display='';
    if(goBtn){goBtn.disabled=false;goBtn.textContent='▶ Generate';}
  },25);
}

// ── Range Report Excel Export ────────────────────────────────────────────────
function exportRangeReportXlsx(){
  if(!rrResults||!rrResults.length){alert('Generate the report first.');return;}
  if(typeof XLSX==='undefined'){alert('SheetJS not loaded.');return;}
  try{
    const wb=XLSX.utils.book_new();
    const ws={},mg=[];
    const ec=(r,c)=>XLSX.utils.encode_cell({r,c});
    const cs=(r,c,v,t,s)=>{ws[ec(r,c)]={t:t||'s',v:(v===null||v===undefined)?'':v,s:s||{}};};
    const mgc=(r1,c1,r2,c2)=>mg.push({s:{r:r1,c:c1},e:{r:r2,c:c2}});
    const unit=isFCC()?'miles':'km';
    const dispD=d=>isFCC()?parseFloat(kmToMi(d).toFixed(3)):d;
    const fi=state.frameIdx||0;
    const{freq:f,bw,pol}=state;

    // Styles
    const fnt=(bold,sz,rgb)=>({bold:!!bold,sz:sz||10,name:'Calibri',color:rgb?{rgb}:undefined});
    const fill=rgb=>({fgColor:{rgb},patternType:'solid'});
    const bdr=()=>({style:'thin',color:{rgb:'000000'}});
    const FULL={top:bdr(),bottom:bdr(),left:bdr(),right:bdr()};
    const HDRBDR={top:{style:'thin',color:{rgb:'000000'}},bottom:{style:'thin',color:{rgb:'000000'}},left:{style:'thin',color:{rgb:'000000'}},right:{style:'thin',color:{rgb:'000000'}}};
    const ST_TTL={font:fnt(true,13,'FFFFFF'),fill:fill('0F2D4A'),alignment:{horizontal:'left',vertical:'center'},border:{top:bdr(),bottom:bdr(),left:bdr(),right:bdr()}};
    const ST_SUB={font:fnt(false,9,'475569'),fill:fill('EFF6FF'),alignment:{horizontal:'left',vertical:'center'},border:FULL};
    const ST_HDR={font:fnt(true,9,'FFFFFF'),fill:fill('1A3F5C'),alignment:{horizontal:'center',vertical:'center'},border:HDRBDR};
    const ST_DIST={font:fnt(true,10,'0F172A'),fill:fill('F1F5F9'),alignment:{horizontal:'left',vertical:'center'},border:FULL};
    const ST_RSSI={font:fnt(false,10,'334155'),fill:fill('F8FAFC'),alignment:{horizontal:'right',vertical:'center'},border:FULL};
    const capST=(cap,maxCap)=>{
      if(!cap){return {font:fnt(true,10,'FFFFFF'),fill:fill('DC2626'),alignment:{horizontal:'center',vertical:'center'},border:FULL};}
      const f=cap/maxCap;
      const bg=f>=0.85?'166534':f>=0.65?'16a34a':f>=0.42?'86efac':f>=0.22?'fde047':f>=0.06?'f97316':'ef4444';
      const fg=f>=0.42&&f<0.65?'14532d':f>=0.22&&f<0.42?'713f12':'FFFFFF';
      return {font:fnt(true,10,fg),fill:fill(bg),alignment:{horizontal:'right',vertical:'center'},border:FULL};
    };

    const NC=2+rrAvailTargets.length;
    let row=0;

    // Title
    cs(row,0,`Range Sweep Report — ${f} GHz · ${bw} MHz · ${pol} Pol`,'s',ST_TTL);
    for(let c=1;c<NC;c++)cs(row,c,'','s',ST_TTL);
    mgc(row,0,row,NC-1);row++;
    cs(row,0,`Frame: ${CAP_SIZES[fi]} · Band: ${state.isMW?(state.mwProduct+' '+state.mwBand+' GHz'):calc.band+'-Band'} · RSSI = unfaded RX at highest modulation`,'s',ST_SUB);
    mgc(row,0,row,NC-1);row++;

    // Column headers
    cs(row,0,`Distance (${unit})`,'s',ST_HDR);
    cs(row,1,'RSSI (dBm)','s',ST_HDR);
    rrAvailTargets.forEach((av,i)=>cs(row,2+i,av+'%','s',ST_HDR));
    row++;

    // Data rows
    let maxCap=0;
    rrResults.forEach(r=>rrAvailTargets.forEach(av=>{if(r.caps[av])maxCap=Math.max(maxCap,r.caps[av]);}));

    rrResults.forEach((r,ri)=>{
      const dv=dispD(r.d);
      cs(row,0,parseFloat(dv.toFixed(3)),'n',ST_DIST);
      cs(row,1,r.rssi!==null?r.rssi:null,r.rssi!==null?'n':'s',ST_RSSI);
      rrAvailTargets.forEach((av,i)=>{
        const cap=r.caps[av];
        const s=capST(cap,maxCap);
        cs(row,2+i,cap!==null?parseFloat(cap.toFixed(1)):null,cap!==null?'n':'s',s);
        if(!cap){ws[ec(row,2+i)].v='✗';}
      });
      row++;
    });

    ws['!ref']=XLSX.utils.encode_range({s:{r:0,c:0},e:{r:row,c:NC-1}});

    const fname=`RangeSweep_${f}GHz_${bw}MHz_${now?now.toISOString().slice(0,10):new Date().toISOString().slice(0,10)}.xlsx`;
    XLSX.writeFile(wb,fname,{cellStyles:true,compression:true});
  }catch(e){console.error(e);alert('Export failed: '+e.message);}
}

function closeHelp(){
  document.getElementById('helpOverlay').classList.remove('open');
  document.body.style.overflow='';
}
document.addEventListener('keydown',function(e){
  if(e.key==='Escape'&&document.getElementById('helpOverlay').classList.contains('open')) closeHelp();
});
