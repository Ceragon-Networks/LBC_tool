// Compute terrain roughness S from fetched elevation profile and derive C
// Estimate climatic factor cf from site coordinates (lat/lon)
// Based on VB document: cf=0.5 dry/mountain, 1.0 average, 2.0 over-water/humid
function vbCfFromCoords(lat,lon){
  const absLat=Math.abs(lat);
  // Over-water / coastal check: if lon suggests ocean proximity, use higher cf
  // High-humidity tropical zones
  if(absLat<15) return{cf:2.0,label:'Tropical/humid'};
  // Sub-tropical humid (SE Asia, Gulf, Caribbean, Mediterranean coast)
  if(absLat<30){
    // Middle East / arid zone: lon 25-65°E, lat 15-35°N
    if(lat>15&&lat<38&&lon>25&&lon<65) return{cf:0.5,label:'Arid/Middle East'};
    return{cf:1.5,label:'Sub-tropical'};
  }
  // Temperate (most of Europe, N America, Asia)
  if(absLat<55){
    // Middle East / arid zone extends to lat 38
    if(lat>15&&lat<38&&lon>25&&lon<65) return{cf:0.5,label:'Arid/Middle East'};
    // Europe Atlantic coast: higher humidity
    if(lon>=-10&&lon<=20&&absLat>45) return{cf:1.5,label:'Temperate/Atlantic'};
    return{cf:1.0,label:'Temperate'};
  }
  // High latitude: typically drier/colder
  return{cf:0.5,label:'High-latitude/dry'};
}

// Main "Auto from map" function — derives both cf (from coordinates) and S (from terrain)
function autoVBFromMap(){
  const hint=document.getElementById('vbTerrainHint');

  // ── Step 1: get cf from site coordinates ──
  let lat=null,lon=null;
  if(typeof siteMarkerA!=='undefined'&&siteMarkerA){const ll=siteMarkerA.getLatLng();lat=ll.lat;lon=ll.lng;}
  if(lat==null||!isFinite(lat)){lat=parseFloat(document.getElementById('siteLatA')?.value);}
  if(lon==null||!isFinite(lon)){lon=parseFloat(document.getElementById('siteLonA')?.value);}
  // Use midpoint if Site B is also available
  let latB=null,lonB=null;
  if(typeof siteMarkerB!=='undefined'&&siteMarkerB){const ll=siteMarkerB.getLatLng();latB=ll.lat;lonB=ll.lng;}
  if(latB==null||!isFinite(latB)){latB=parseFloat(document.getElementById('siteLatB')?.value);}
  if(isFinite(latB)&&isFinite(lonB)){lat=(lat+latB)/2;lon=(lon+lonB)/2;}

  let cfResult=null;
  if(isFinite(lat)&&isFinite(lon)){
    cfResult=vbCfFromCoords(lat,lon);
    state.vbCf=cfResult.cf;
    const cfEl=document.getElementById('vbCf');
    if(cfEl)cfEl.value=cfResult.cf;
    // Update cf buttons
    document.querySelectorAll('#vbCfBtns .c-btn').forEach(b=>{
      b.className='c-btn'+(Math.abs(parseFloat(b.dataset.cf)-cfResult.cf)<0.01?' active':'');
    });
  }

  // ── Step 2: compute S from terrain profile ──
  const td=window._terrainData;
  if(!td||!td.elevations||td.elevations.length<10){
    if(hint){
      hint.textContent=cfResult
        ?'cf='+cfResult.cf+' ('+cfResult.label+') — load terrain profile for terrain roughness S'
        :'📍 Pin sites on map first, then load terrain profile';
    }
    if(cfResult){update(true);}
    return;
  }

  const elev=td.elevations;
  const n=elev.length;
  const samples=[];
  for(let i=0;i<50;i++){
    const idx=Math.round(i*(n-1)/49);
    samples.push(elev[Math.min(idx,n-1)]);
  }
  const M=samples.reduce((a,b)=>a+b,0)/50;
  const S=Math.sqrt(samples.reduce((a,b)=>a+Math.pow(b-M,2),0)/50);
  const Sc=Math.max(6,Math.min(42,S));
  const cf=state.vbCf||1.0;
  const C=cf*Math.pow(Sc/15.2,-1.3);
  const Cc=Math.max(0.1,Math.min(6,parseFloat(C.toFixed(3))));
  state.vbCFactor=Cc;
  const cfEl=document.getElementById('vbCFactor');
  if(cfEl)cfEl.value=Cc;
  // Update C preset buttons
  document.querySelectorAll('#vbCBtns .c-btn').forEach(b=>{
    b.className='c-btn'+(Math.abs(parseFloat(b.dataset.cv)-Cc)<0.01?' active':'');
  });

  const cfLabel=cfResult?cfResult.label:'manual';
  if(hint)hint.textContent=
    'cf='+cf+' ('+cfLabel+') · S='+Sc.toFixed(1)+'m → C='+Cc.toFixed(3);

  update(true);
}

function autoCalcVBFromTerrain(){
  // Called automatically when terrain loads — uses current cf (no coordinate lookup)
  const td=window._terrainData;
  const hint=document.getElementById('vbTerrainHint');
  if(!td||!td.elevations||td.elevations.length<10){
    if(hint)hint.textContent='Pin sites & load terrain to auto-calculate C';
    return;
  }
  const elev=td.elevations;
  const n=elev.length;
  const samples=[];
  for(let i=0;i<50;i++){
    const idx=Math.round(i*(n-1)/49);
    samples.push(elev[Math.min(idx,n-1)]);
  }
  const M=samples.reduce((a,b)=>a+b,0)/50;
  const S=Math.sqrt(samples.reduce((a,b)=>a+Math.pow(b-M,2),0)/50);
  const Sc=Math.max(6,Math.min(42,S));
  const cf=state.vbCf||1.0;
  const C=cf*Math.pow(Sc/15.2,-1.3);
  const Cc=Math.max(0.1,Math.min(6,parseFloat(C.toFixed(3))));
  state.vbCFactor=Cc;
  const el=document.getElementById('vbCFactor');
  if(el)el.value=Cc;
  if(hint)hint.textContent='S='+Sc.toFixed(1)+'m → C='+Cc.toFixed(3)+' (use Auto button to also set cf from coordinates)';
}

