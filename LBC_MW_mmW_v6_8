// Auto-adjust X max dropdown to fit the highest modulation's max effective distance
function syncXMax(){
  try{
    const allMods=state.isMW?mwMods(state.mwProduct||'IP-20C',state.bw,state.mwBand):validMods(state.bw);
    if(!allMods||!allMods.length)return;
    // Find max effective distance across all modulations
    let bestDist=0;
    for(const mod of allMods){
      const d=findMaxDistAt(mod,state.targetAvail);
      if(d>bestDist)bestDist=d;
    }
    if(bestDist<=0)return;
    // X max options in km — must match the <select> options exactly
    const options=[5,10,15,20,30,50,80,100,150];
    // Choose the smallest option that is ≥ bestDist × 1.15 (15% headroom)
    const needed=bestDist*1.15;
    let chosen=options[options.length-1]; // default: largest
    for(const opt of options){if(opt>=needed){chosen=opt;break;}}
    const sel=document.getElementById('xMax');
    if(sel&&+sel.value!==chosen&&!_xMaxUserSet){
      sel.value=String(chosen);
    }
  }catch(e){/* silent — non-critical */}
}

function renderChart(){
  syncXMax();
  const xMax=+document.getElementById('xMax').value;
  const vMods=validMods(state.bw);
  const modsToShow=getCustomMods();
  // Update chart title based on selection
  {const _t=document.getElementById('distChartTitle');
   const _cm=document.getElementById('chartMods');
   if(_t&&_cm){const _v=_cm.value;
     if(_v==='all')_t.textContent='📈 Distance vs Availability — All Modulations';
     else if(_v==='key')_t.textContent='📈 Distance vs Availability — Key Modulations';
     else if(_v.startsWith('mod:'))_t.textContent='📈 Distance vs Availability — '+_v.replace('mod:','');
     else _t.textContent='📈 Distance vs Availability';
   }}
  // 0.1 km steps
  const step=Math.max(.1,xMax/150);
  const nPts=Math.floor(xMax/step);
  const dists=Array.from({length:nPts},(_,i)=>parseFloat(((i+1)*step).toFixed(2)));
  const tgtNines=availToNines(state.targetAvail);
  const curDist=state.distance;
  const uf=isFCC()?(1/1.60934):1; // km value -> display unit (mi in FCC)
  const tickMap=Object.fromEntries(Y_TICKS.map(t=>[t.v.toFixed(3),t.l]));

  const allMods=state.isMW?mwMods(state.mwProduct||'IP-20C',state.bw,state.mwBand):MODS;
  const datasets=modsToShow.map(mod=>{
    const ci=allMods.indexOf(mod);
    const data=dists.map(d=>{
      const res=computeWith(Object.assign({},state,{distance:d}));
      const r=res.mods.find(m=>m.mod===mod);
      const xd=parseFloat((d*uf).toFixed(3));
      if(!r)return{x:xd,y:null};
      const nines=availToNines(r.avail);
      return{x:xd,y:parseFloat(Math.min(isFinite(nines)?nines:7,7).toFixed(4))};
    });
    const color=CLR[ci%CLR.length]||CLR[0];
    return{label:mod,data,borderColor:color,backgroundColor:color+'15',
      borderWidth:2.5,pointRadius:0,pointHoverRadius:5,tension:.2,fill:false,spanGaps:false};
  });

  const refPlugin={
    id:'ref',
    afterDraw(chart){
      const{ctx:c,chartArea:{top,bottom,left,right},scales:{x,y}}=chart;
      // Target — red horizontal
      const yPx=y.getPixelForValue(tgtNines);
      if(yPx>=top&&yPx<=bottom){
        c.save();c.strokeStyle='#dc2626';c.lineWidth=2;c.setLineDash([7,4]);
        c.beginPath();c.moveTo(left,yPx);c.lineTo(right,yPx);c.stroke();c.setLineDash([]);
        const lbl=fmtA(state.targetAvail)+'%';
        c.font='bold 10px Inter,sans-serif';const tw=c.measureText(lbl).width+10;
        c.fillStyle='#dc2626';c.fillRect(left+2,yPx-13,tw,13);
        c.fillStyle='#fff';c.textAlign='left';c.fillText(lbl,left+7,yPx-2);
        c.restore();
      }
      // Current distance — navy vertical
      const xPx=x.getPixelForValue(curDist*uf);
      if(xPx>=left&&xPx<=right){
        c.save();c.strokeStyle='#0f2d4a';c.lineWidth=1.5;c.setLineDash([5,3]);
        c.beginPath();c.moveTo(xPx,top);c.lineTo(xPx,bottom);c.stroke();c.setLineDash([]);
        c.fillStyle=document.documentElement.getAttribute('data-theme')==='dark'?'#e2e8f0':'#0f2d4a';c.font='bold 10px Inter,sans-serif';c.textAlign='center';
        c.fillText((curDist*uf).toFixed(2)+' '+distUnitLbl(),xPx,top-4);
        c.restore();
      }
    }
  };

  if(myChart){myChart.destroy();myChart=null;}
  const myCanvas=document.getElementById('myChart');
  if(myCanvas){const p=myCanvas.parentElement;myCanvas.width=p?p.clientWidth||800:800;myCanvas.height=380;}
  myChart=new Chart(document.getElementById('myChart').getContext('2d'),{
    type:'line',data:{datasets},
    options:{
      responsive:false,maintainAspectRatio:false,animation:{duration:0},
      interaction:{mode:'index',intersect:false,axis:'x'},
      plugins:{
        legend:{position:'bottom',labels:{boxWidth:14,boxHeight:3,padding:12,font:{size:11,family:"'Inter',sans-serif"}}},
        tooltip:{
          callbacks:{
            title:items=>`Distance: ${items[0]?.label} ${distUnitLbl()}`,
            label:item=>{
              const avail=fmtA(ninesToAvail(item.parsed.y));
              const cap=getCap(state.bw,item.dataset.label,state.frameIdx||0);
              const capStr=cap!=null?fmtCap(cap):'—';
              return ` ${item.dataset.label}: ${avail}%  |  ${capStr}`;
            }
          },
          backgroundColor:'rgba(15,45,74,.93)',titleColor:'#e2efff',bodyColor:'#93c5fd',
          borderColor:'rgba(255,255,255,.15)',borderWidth:1,
          padding:10,titleFont:{size:12},bodyFont:{size:11,family:"'JetBrains Mono'"}
        }
      },
      scales:{
        x:{type:'linear',min:0,max:xMax*uf,
          title:{display:true,text:'Distance ('+distUnitLbl()+')',font:{size:11},color:cssVar('--chart-txt')||'#475569'},
          grid:{color:cssVar('--chart-grid')||'rgba(0,0,0,.07)'},
          ticks:{color:cssVar('--chart-txt')||'#475569',font:{size:10},callback:v=>v%1===0?v+' '+distUnitLbl():'',stepSize:.5}
        },
        y:{type:'linear',min:1.3,max:7.1,
          title:{display:true,text:'Availability  (log-outage scale)',font:{size:11},color:cssVar('--chart-txt')||'#475569'},
          grid:{color:cssVar('--chart-grid')||'rgba(0,0,0,.07)'},
          ticks:{color:cssVar('--chart-txt')||'#475569',font:{size:10},
            callback(v){return tickMap[(+v).toFixed(3)]||tickMap[(+v).toFixed(2)]||'';},
