const MW_FREQS={
  'IP-20C':   [6,7,8,10,11,13,15,18,23,24,26,28,32,38,42],
  'IP-50C':   [6,7,8,10,11,13,15,18,23,24,26,28,32,38,42],
  'IP-50CX':  [6,7,8,10,11,13,15,18,23,24,26,28,32,38,42],
  'RFU-D':    [6,7,8,10,11,13,15,18,23,24,26,28,32,38,42],
  'IP-20C-HP':[4,5,6,7,8,11],
  'RFU-D-HP': [4,5,6,7,8,11]
};
// Channel bandwidths (MHz) per product per regulatory standard.
// Values are channel bandwidths in MHz.

// ===== MAX MODULATION CAPS PER PRODUCT / BW / BAND =====
// Value = the highest modulation name allowed (inclusive).
// All modulations from the lowest up to this cap are shown.
// null = no cap (use full TX table list).
// Band ranges stored as arrays [lo, hi] (GHz, inclusive).
// Helper called inside mwMods() to resolve the cap for a given product/bw/band.
function mwMaxMod(product, bw, band){
  const bwN  = parseFloat(bw);
  const bandN = parseFloat(band);
  const is50  = (product==='IP-50C'||product==='IP-50CX');
  const isRFU = (product==='RFU-D'||product==='RFU-D-HP');
  const is20  = (product==='IP-20C'||product==='IP-20C-HP');

  // ── Universal BW caps (all applicable products / all bands) ─────────────
  if(bwN<=5)   return '256QAM';   // 3.5 & 5 MHz → 256QAM max
  if(bwN<=10)  return '1KHQAM';   // 7 & 10 MHz  → 1KHQAM max

  // ── IP-20C / IP-20C-HP ──────────────────────────────────────────────────
  if(is20){
    if(bwN<=14)  return '1KHQAM'; // 14 MHz → 1KHQAM
    return '2KQAM';               // 20–80 MHz → 2KQAM (already top of TX table)
  }

  // ── IP-50C / IP-50CX ────────────────────────────────────────────────────
  if(is50){
    if(bwN<=25)  return '2KQAM';  // 14, 20, 25 MHz → 2KQAM

    if(bwN===224) return '2KQAM'; // 224 MHz → 2KQAM where applicable

    // 50 & 56 MHz: 4KQAM for 6–26 GHz; 2KQAM for 28 GHz and above
    if(bwN===50||bwN===56){
      return (bandN<=26) ? '4KQAM' : '2KQAM';
    }

    // 28, 30, 40, 80, 112 MHz: 4KQAM for 5–32 GHz; 2KQAM for 38 & 42 GHz
    if([28,30,40,80,112].includes(bwN)){
      return (bandN<=32) ? '4KQAM' : '2KQAM';
    }

    return null; // any other BW: no cap
  }

  // ── RFU-D / RFU-D-HP ────────────────────────────────────────────────────
  if(isRFU){
    if(bwN<=14)  return '1KHQAM'; // 7, 10, 14 MHz → 1KHQAM (already covered above for ≤10)
    if(bwN===20) return '1KHQAM'; // 20 MHz → 1KHQAM

    // 25–60 MHz: no cap (4KQAM) for bands ≤18 GHz; 2KQAM cap for bands ≥23 GHz
    if(bwN>=25&&bwN<=60){
      return (bandN<=18) ? null : '2KQAM';
    }

    // 80 & 112 MHz: 2KQAM for 4–32 GHz; 1KHQAM for 38 & 42 GHz
    if(bwN===80||bwN===112){
      return (bandN<=32) ? '2KQAM' : '1KHQAM';
    }

    return null;
  }

  return null; // unknown product → no cap
}

