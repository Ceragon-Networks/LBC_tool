// Normalise tool modulation string → XPIF table key
function normXpifKey(toolMod, family){
  const m=toolMod.replace(/\s+/g,'').toUpperCase();
  if(m.startsWith('BPSK')) return family==='rfud'?'BPSK':null;
  if(m==='QPSK') return family==='ip20c'?'QPSK':'4QAM';
  if(m==='4QAM') return family==='ip20c'?'QPSK':'4QAM';
  if(m.startsWith('8QAM')) return '8QAM';
  if(m.startsWith('16QAM')) return '16QAM';
  if(m.startsWith('32QAM')) return '32QAM';
  if(m.startsWith('64QAM')) return '64QAM';
  if(m.startsWith('128QAM')) return '128QAM';
  if(m.startsWith('256QAM')) return '256QAM';
  if(m.startsWith('512QAM')) return '512QAM';
  if(m.match(/1024.*L|1K.*L/i)||m==='1KLQAM') return '1KLQAM';
  if(m.match(/1024.*H|1K.*H/i)||m==='1KHQAM') return '1KHQAM';
  if(m.match(/^1024QAM$|^1KQAM$/i)) return '1KQAM';
  if(m.match(/2048|2KQAM/i)) return '2KQAM';
  if(m.match(/4096|4KQAM/i)) return '4KQAM';
  return null;
}
function getXpifFamily(product){
  return ['RFU-D','RFU-D-HP','IP-50C','IP-50CX'].includes(product)?'rfud':'ip20c';
}
function getXpif(product, bw, modStr){
  const fam=getXpifFamily(product);
  const tbl=XPIF_DATA[fam]; if(!tbl) return null;
  const bwKeys=Object.keys(tbl).map(Number);
  const bwK=bwKeys.reduce((b,k)=>Math.abs(k-bw)<Math.abs(b-bw)?k:b, bwKeys[0]);
  const entry=tbl[bwK]; if(!entry) return null;
  const key=normXpifKey(modStr, fam); if(!key) return null;
  return entry[key]??null;
}
// XPD co-channel degradation (ITU P.530-8 / Vigants, single Tx antenna)
// Returns {xpd0,eta,Q,C,xpdRain,ci_mph,ci_mph_xpic,ci_rain,ci_rain_xpic}
function calcXpd(ffm, efm, pM_raw, freq_ghz, A001_dB, xpdg, xpif, xpicOn){
  if(pM_raw<=0||!isFinite(pM_raw)) return null;
  // Step 1: adjusted antenna XPD
  const xpd0 = xpdg<=35 ? xpdg+5 : 40;
  // Fade occurrence factor P₀ = pM × 10^(efm/10)  [% of time]
  const P0 = pM_raw * Math.pow(10, efm/10);
  if(P0<=0||!isFinite(P0)) return null;
  // Step 2: multipath activity factor η
  const eta = 1 - Math.exp(-0.2 * Math.pow(P0, 0.75));
  // Step 3: Q  (K_XP = 0.7 for single Tx antenna)
  const Q = -10 * Math.log10(0.7 * eta / P0);
  // Step 4: C = XPD₀ + Q
  const C = xpd0 + Q;
  // C/I multipath — without XPIC (Eq.39), with flat fade margin A=ffm
  const ci_mph = -10*Math.log10(
    2*Math.pow(10,-xpdg/10) + Math.pow(10,-(C-ffm)/10)
  ) + 2;
  // C/I multipath — with XPIC (Eq.40)
  const xif = xpif??0;
  const ci_mph_xpic = xpicOn&&xpif!=null ? -10*Math.log10(
    Math.pow(10,-xpdg/10) + 2*Math.pow(10,-(xpdg+xif)/10) + Math.pow(10,-(C+xif-ffm)/10)
  ) + 2 : null;
  // Rain XPD (Eq.41)
  const A001 = A001_dB>0 ? A001_dB : 0.01;
  const xpdRain = freq_ghz<=20
    ? 15 + 30*Math.log10(freq_ghz) - 12.8*Math.pow(freq_ghz,0.19)*Math.log10(A001)
    : 15 + 30*Math.log10(freq_ghz) - 22.6*Math.log10(A001);
  // C/I rain — without XPIC (Eq.42)
  const ci_rain = -10*Math.log10(
    2*Math.pow(10,-xpdg/10) + Math.pow(10,-xpdRain/10)
  ) + 2;
  // C/I rain — with XPIC
  const ci_rain_xpic = xpicOn&&xpif!=null ? -10*Math.log10(
    Math.pow(10,-xpdg/10) + 2*Math.pow(10,-(xpdg+xif)/10) + Math.pow(10,-(xpdRain+xif)/10)
  ) + 2 : null;
  return{xpd0,P0,eta,Q,C,xpdRain,ci_mph,ci_mph_xpic,ci_rain,ci_rain_xpic,xpif:xif};
}
