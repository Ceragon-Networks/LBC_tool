// ===== FIND HIGHEST ELEVATION NEAR SITE =====

// Generate ring of N points at radius_m metres around centre
function radialPoints(lat, lon, radius_m, n){
  const R = 6371000; // Earth radius in metres
  const pts = [];
  // Also include the centre point
  pts.push({lat, lon, angle: -1});
  for(let i = 0; i < n; i++){
    const bearing = (i / n) * 2 * Math.PI;
    const d = radius_m / R;
    const lat1 = lat * Math.PI/180;
    const lon1 = lon * Math.PI/180;
    const lat2 = Math.asin(Math.sin(lat1)*Math.cos(d) + Math.cos(lat1)*Math.sin(d)*Math.cos(bearing));
    const lon2 = lon1 + Math.atan2(Math.sin(bearing)*Math.sin(d)*Math.cos(lat1), Math.cos(d)-Math.sin(lat1)*Math.sin(lat2));
    pts.push({lat: lat2*180/Math.PI, lon: lon2*180/Math.PI, angle: Math.round(bearing*180/Math.PI)});
  }
  return pts;
}

