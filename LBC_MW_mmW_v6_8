let terrainChart=null;

// Generate N equally-spaced points along great-circle path
function interpGreatCircle(lat1,lon1,lat2,lon2,n){
  const pts=[];
  const toRad=d=>d*Math.PI/180;
  const toDeg=r=>r*180/Math.PI;
  const d2r=toRad; const r2d=toDeg;
  const phi1=d2r(lat1),lam1=d2r(lon1),phi2=d2r(lat2),lam2=d2r(lon2);
  const dPhi=phi2-phi1,dLam=lam2-lam1;
  const a=Math.sin(dPhi/2)**2+Math.cos(phi1)*Math.cos(phi2)*Math.sin(dLam/2)**2;
  const angDist=2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
  for(let i=0;i<=n;i++){
    const f=i/n;
    if(angDist<1e-10){pts.push({lat:lat1,lon:lon1,f});continue;}
    const A=Math.sin((1-f)*angDist)/Math.sin(angDist);
    const B=Math.sin(f*angDist)/Math.sin(angDist);
    const x=A*Math.cos(phi1)*Math.cos(lam1)+B*Math.cos(phi2)*Math.cos(lam2);
    const y=A*Math.cos(phi1)*Math.sin(lam1)+B*Math.cos(phi2)*Math.sin(lam2);
    const z=A*Math.sin(phi1)+B*Math.sin(phi2);
    pts.push({lat:r2d(Math.atan2(z,Math.sqrt(x*x+y*y))),lon:r2d(Math.atan2(y,x)),f});
  }
  return pts;
}

// Fetch elevation profile using Open-Topo-Data (SRTM 90m, free, no key)
let _terrainFetching=false;
async function fetchTerrainProfile(){
  if(_terrainFetching)return;
  _terrainFetching=true;
  const latA=parseFloat(document.getElementById('siteLatA')?.value);
  const lonA=parseFloat(document.getElementById('siteLonA')?.value);
  const latB=parseFloat(document.getElementById('siteLatB')?.value);
  const lonB=parseFloat(document.getElementById('siteLonB')?.value);
  if(isNaN(latA)||isNaN(lonA)||isNaN(latB)||isNaN(lonB))return;

  let hA=parseFloat(document.getElementById('antHgtA')?.value)||20;
  let hB=parseFloat(document.getElementById('antHgtB')?.value)||20;
  if(isFCC()){hA=ftToM(hA);hB=ftToM(hB);}
  const N=60; // sample points
  const pts=interpGreatCircle(latA,lonA,latB,lonB,N);

  // Show card
  const card=document.getElementById('terrainProfileCard');
  if(card)card.style.display='block';

  const btn=document.getElementById('terrainBtn');
  if(btn){btn.textContent='⏳ Loading…';btn.disabled=true;}

  try{
    // Try Open-Topo-Data first (SRTM 90m, free, no key)
    // Use POST to avoid URL length limits and pipe-encoding issues
    const locations=pts.map(p=>({latitude:parseFloat(p.lat.toFixed(5)),longitude:parseFloat(p.lon.toFixed(5))}));
    let elevations=null;
    
    // Attempt 1: opentopodata.org POST
    try{
      const r1=await fetch('https://api.opentopodata.org/v1/srtm90m',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({locations})
      });
      if(r1.ok){
        const d1=await r1.json();
        if(d1.status==='OK')elevations=d1.results.map(r=>r.elevation??0);
      }
    }catch(e1){console.warn('opentopodata POST failed:',e1);}
    
    // Attempt 2: opentopodata GET with pipe separator (not encoded)
    if(!elevations){
      try{
        const locs=pts.map(p=>p.lat.toFixed(5)+','+p.lon.toFixed(5)).join('|');
        const r2=await fetch('https://api.opentopodata.org/v1/srtm90m?locations='+locs);
        if(r2.ok){
          const d2=await r2.json();
          if(d2.status==='OK')elevations=d2.results.map(r=>r.elevation??0);
        }
      }catch(e2){console.warn('opentopodata GET failed:',e2);}
    }
    
    // Attempt 3: open-elevation.com POST
    if(!elevations){
      try{
        const r3=await fetch('https://api.open-elevation.com/api/v1/lookup',{
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body:JSON.stringify({locations:locations.map(l=>({latitude:l.latitude,longitude:l.longitude}))})
        });
        if(r3.ok){
          const d3=await r3.json();
          if(d3.results)elevations=d3.results.map(r=>r.elevation??0);
        }
      }catch(e3){console.warn('open-elevation failed:',e3);}
    }

    if(!elevations)throw new Error('All elevation APIs failed — check network connection');
    const kmTotal=haversineKm(latA,lonA,latB,lonB);
    const distances=pts.map(p=>parseFloat((p.f*kmTotal).toFixed(3)));
    const fcc=state.std==='FCC';
    const distScale=fcc?1/1.60934:1;
    const distUnit=fcc?'mi':'km';

    // LOS line: straight line from (elev[0]+hA) to (elev[N]+hB)
    const e0=elevations[0]+hA;
    const eN=elevations[N]+hB;
    const losLine=elevations.map((_,i)=>e0+(eN-e0)*(i/N));

    // Check for obstructions (terrain above LOS)
    let obstructed=false;
    let maxClearance=Infinity;
    const clearances=elevations.map((e,i)=>{
      const c=losLine[i]-e;
      if(c<maxClearance)maxClearance=c;
      if(c<0)obstructed=true;
      return c;
    });

    // Update LOS status badge
    const statusEl=document.getElementById('losStatus');
    if(statusEl){
      if(obstructed){
        statusEl.textContent='✗ Obstructed';
        statusEl.style.cssText='background:#fee2e2;color:#991b1b;font-size:11px;font-weight:600;padding:2px 10px;border-radius:10px';
      } else {
        statusEl.textContent='✓ Clear LOS (min '+maxClearance.toFixed(0)+' m)';
        statusEl.style.cssText='background:#d1fae5;color:#065f46;font-size:11px;font-weight:600;padding:2px 10px;border-radius:10px';
      }
    }
    document.getElementById('terrainNote').textContent=
      'SRTM 90m elevation · '+pts.length+' samples · '+fmtDist(kmTotal)+' path';

    renderTerrainChart(distances.map(d=>parseFloat((d*distScale).toFixed(3))),
      elevations, losLine, obstructed, distUnit);

  }catch(e){
    const statusEl=document.getElementById('losStatus');
    if(statusEl){statusEl.textContent='⚠ Elevation data unavailable';
      statusEl.style.cssText='background:#fef3c7;color:#92400e;font-size:11px;font-weight:600;padding:2px 10px;border-radius:10px';}
    const note=document.getElementById('terrainNote');
    if(note)note.textContent='Error: '+e.message+' — Check browser console for details';
    console.error('Terrain profile error:',e);
  }
  if(btn){btn.textContent='↻ Refresh';btn.disabled=false;}
  _terrainFetching=false;
}

// Fresnel zone radius at distance d1 from A, d2 from B, wavelength λ (all in km→m)
function fresnelR1(d1_km, d2_km, freq_ghz){
  const lam = 0.3 / freq_ghz; // wavelength in meters
  return Math.sqrt(lam * d1_km * 1000 * d2_km * 1000 / ((d1_km + d2_km) * 1000));
}

let _terrainData = null; // cache for optimiser

function renderTerrainChart(distances, elevations, losLine, obstructed, distUnit){
  const dark = document.documentElement.getAttribute('data-theme') === 'dark';
  const gridColor = dark ? 'rgba(255,255,255,.12)' : 'rgba(0,0,0,.07)';
  const txtColor  = dark ? '#e2e8f0' : '#475569';
  const showFr = document.getElementById('showFresnel')?.checked !== false;

  const canvas = document.getElementById('terrainChart');
  if(!canvas) return;
  if(terrainChart){ terrainChart.destroy(); terrainChart = null; }
  // Ensure card is visible before measuring canvas width
  const terrCard=document.getElementById('terrainProfileCard');
  if(terrCard)terrCard.style.display='block';
  // Wait one frame for layout to settle, then get width
  canvas.width  = Math.max(canvas.parentElement?.offsetWidth||0, canvas.parentElement?.clientWidth||0) || 680;
  canvas.height = 220;

  const n = elevations.length - 1;
  const totalKm = (distances[n] / (distUnit==='mi' ? 0.62137 : 1));
  const freq = state.freq || 80;

  // Fresnel 60% boundary (upper and lower around LOS)
  const fresnelUp = [], fresnelDn = [];
  distances.forEach((d, i) => {
    const d1 = (i/n) * totalKm;
    const d2 = ((n-i)/n) * totalKm;
    if(d1 < 0.001 || d2 < 0.001){ fresnelUp.push(losLine[i]); fresnelDn.push(losLine[i]); return; }
    const r = fresnelR1(d1, d2, freq) * 0.6; // 60% clearance
    fresnelUp.push(losLine[i] + r);
    fresnelDn.push(losLine[i] - r);
  });

  // Obstruction where terrain > 60% Fresnel boundary
  const fresnelObstr = elevations.map((e,i) => fresnelDn[i] < e ? e : null);
  const hasObstr = obstructed || fresnelObstr.some(v => v !== null);

  // Y scale — extend if diversity antennas are active
  let hA_m = parseFloat(document.getElementById('antHgtA')?.value)||20;
  let hB_m = parseFloat(document.getElementById('antHgtB')?.value)||20;
  if(isFCC()){hA_m=ftToM(hA_m);hB_m=ftToM(hB_m);}
  const sdVis = state.sdEnabled && isSdEligible();
  const sdSepM = state.sdSep || 12;

  // Main antenna = HIGHER = user-entered AGL height
  // Diversity antenna = LOWER = main − sdSep
  const antAele  = elevations[0] + hA_m;          // main Site A (higher)
  const antBele  = elevations[n] + hB_m;          // main Site B (higher)
  const divAele  = antAele - sdSepM;               // diversity Site A (lower)
  const divBele  = antBele - sdSepM;               // diversity Site B (lower)

  // Diversity LOS: parallel shift of main LOS down by sdSep
  const divLos = losLine.map(v => v - sdSepM);

  // Diversity Fresnel 60% (same geometry, centred on divLos)
  const divFrUp=[], divFrDn=[];
  if(sdVis){
    distances.forEach((_,i)=>{
      const d1=(i/n)*totalKm, d2=((n-i)/n)*totalKm;
      if(d1<0.001||d2<0.001){divFrUp.push(divLos[i]);divFrDn.push(divLos[i]);return;}
      const r=fresnelR1(d1,d2,freq)*0.6;
      divFrUp.push(divLos[i]+r);
      divFrDn.push(divLos[i]-r);
    });
  }
  const divFrObstr = sdVis ? elevations.map((e,i)=>divFrDn[i]<e?e:null) : [];

  // Y scale — account for all relevant heights
  const allVals = [...elevations,...losLine,...fresnelUp,
    antAele, antBele,
    ...(sdVis?[divAele,divBele,...divFrDn.filter(v=>v!=null)]:[])
  ].filter(v=>v!=null&&isFinite(v));
  const yMin = Math.floor(Math.min(...allVals)-5);
  const yMax = Math.ceil(Math.max(...allVals)+(sdVis?8:10));

  // Build sparse point arrays for antenna markers
  function sparseArr(len,idx,val){const a=new Array(len).fill(null);a[idx]=val;return a;}
  const antAdata = sparseArr(n+1,0,antAele);
  const antBdata = sparseArr(n+1,n,antBele);
  const divAdata = sparseArr(n+1,0,divAele);
  const divBdata = sparseArr(n+1,n,divBele);

  // Custom plugin: draw vertical separation bars + labels at both ends
  const sdLabelPlugin = sdVis ? {
    id:'sdLabel',
    afterDraw(chart){
      const ctx=chart.ctx;
      const drawBar=(xPx,yMainPx,yDivPx,label)=>{
        ctx.save();
        ctx.strokeStyle='rgba(5,150,105,.75)';ctx.lineWidth=1.5;
        ctx.setLineDash([3,3]);
        ctx.beginPath();ctx.moveTo(xPx,yMainPx);ctx.lineTo(xPx,yDivPx);ctx.stroke();
        ctx.setLineDash([]);
        // arrow caps
        [yMainPx,yDivPx].forEach(y=>{
          ctx.beginPath();ctx.moveTo(xPx-3,y+(y===yMainPx?4:-4));ctx.lineTo(xPx,y);ctx.lineTo(xPx+3,y+(y===yMainPx?4:-4));ctx.stroke();
        });
        ctx.fillStyle='#059669';ctx.font='bold 9px Inter,sans-serif';
        ctx.textAlign='left';
        ctx.fillText(label,xPx+5,(yMainPx+yDivPx)/2+3);
        ctx.restore();
      };
      const sepLabel=isFCC()?fmtLen(sdSepM/0.3048):sdSepM.toFixed(1)+' m';
      const xA=chart.scales.x.getPixelForValue(distances[0]);
      const xB=chart.scales.x.getPixelForValue(distances[n]);
      drawBar(xA,chart.scales.y.getPixelForValue(antAele),chart.scales.y.getPixelForValue(divAele),sepLabel);
      drawBar(xB,chart.scales.y.getPixelForValue(antBele),chart.scales.y.getPixelForValue(divBele),sepLabel);
    }
  } : null;

  // Antenna marker datasets
  const antDatasets = [
    {label:'Ant A (main)',data:antAdata,type:'scatter',
     borderColor:'#2563eb',backgroundColor:'#2563eb',
     pointStyle:'triangle',pointRadius:8,pointHoverRadius:10,showLine:false,order:0},
    {label:'Ant B (main)',data:antBdata,type:'scatter',
     borderColor:'#d97706',backgroundColor:'#d97706',
     pointStyle:'triangle',pointRadius:8,pointHoverRadius:10,showLine:false,order:0},
    ...(sdVis?[
      {label:'Ant A (div)',data:divAdata,type:'scatter',
       borderColor:'#059669',backgroundColor:'#059669',
       pointStyle:'triangle',pointRadius:8,pointHoverRadius:10,showLine:false,order:0},
      {label:'Ant B (div)',data:divBdata,type:'scatter',
       borderColor:'#059669',backgroundColor:'#059669',
       pointStyle:'triangle',pointRadius:8,pointHoverRadius:10,showLine:false,order:0},
    ]:[]),
  ];

  // Reflection Analysis — V-path rays for all 4 paths
  const showRefl = document.getElementById('showReflection')?.checked && sdVis;
  let reflPaths = [];
  if(showRefl){
    reflPaths = buildReflPaths(elevations, distances, totalKm, hA_m, hB_m, sdSepM, freq);
  }
  // Show/hide the Reflection toggle button
  const reflToggle=document.getElementById('reflToggleWrap');
  if(reflToggle)reflToggle.style.display=sdVis?'flex':'none';

  // Cache for optimiser
  _terrainData = { distances, elevations, losLine, fresnelDn, distUnit, n, totalKm, freq };
  // Auto-update reliability parameters from terrain profile
  if(state.isMW&&state.relMethod==='VB') autoCalcVBFromTerrain();
  if(state.isMW){
    syncMwInclination(); // refresh εp display and auto-fill lower antenna altitude
    if(state.relMethod==='P530-78'||state.relMethod==='P530-17') calcGeoK();
  }

  const datasets = [
    // ── Main antenna Fresnel 60% zone ──
    ...(showFr ? [
      {label:'Fresnel upper',data:fresnelUp,borderColor:'rgba(22,163,74,.4)',
       backgroundColor:'rgba(22,163,74,.12)',borderWidth:1,borderDash:[3,2],
       fill:'+1',tension:.25,pointRadius:0,order:4},
      {label:'Fresnel lower',data:fresnelDn,borderColor:'rgba(22,163,74,.4)',
       backgroundColor:'rgba(22,163,74,.12)',borderWidth:1,borderDash:[3,2],
       fill:false,tension:.25,pointRadius:0,order:4},
    ] : []),
    // ── Diversity antenna Fresnel 60% zone (teal, only when SD active) ──
    ...(sdVis && showFr ? [
      {label:'Div Fresnel upper',data:divFrUp,borderColor:'rgba(8,145,178,.4)',
       backgroundColor:'rgba(8,145,178,.10)',borderWidth:1,borderDash:[3,2],
       fill:'+1',tension:.25,pointRadius:0,order:4},
      {label:'Div Fresnel lower',data:divFrDn,borderColor:'rgba(8,145,178,.4)',
       backgroundColor:'rgba(8,145,178,.10)',borderWidth:1,borderDash:[3,2],
       fill:false,tension:.25,pointRadius:0,order:4},
    ] : []),
    // ── Terrain ──
    {label:'Terrain',data:elevations,
     borderColor:dark?'#64748b':'#475569',
     backgroundColor:dark?'rgba(100,116,139,.4)':'rgba(148,163,184,.35)',
     borderWidth:1.5,fill:true,tension:.25,pointRadius:0,order:3},
    // ── Fresnel obstructions ──
    ...(showFr && fresnelObstr.some(v=>v!==null) ? [{
      label:'Fresnel intrusion',data:fresnelObstr,
      borderColor:'rgba(239,68,68,0)',backgroundColor:'rgba(239,68,68,.4)',
      borderWidth:0,fill:true,tension:.25,pointRadius:0,order:2
    }] : []),
    ...(sdVis && showFr && divFrObstr.some(v=>v!==null) ? [{
      label:'Div Fresnel intrusion',data:divFrObstr,
      borderColor:'rgba(239,68,68,0)',backgroundColor:'rgba(239,68,68,.25)',
      borderWidth:0,fill:true,tension:.25,pointRadius:0,order:2
    }] : []),
    // ── Main LOS line (blue) ──
    {label:'LOS (main)',data:losLine,
     borderColor:'#3b82f6',backgroundColor:'transparent',
     borderWidth:2.5,borderDash:[8,4],fill:false,tension:0,pointRadius:0,order:1},
    // ── Diversity LOS line (teal, when SD active) ──
    ...(sdVis ? [{
      label:'LOS (diversity)',data:divLos,
      borderColor:'#0891b2',backgroundColor:'transparent',
      borderWidth:2,borderDash:[5,4],fill:false,tension:0,pointRadius:0,order:1
    }] : []),
    // ── Antenna markers ──
    ...antDatasets,
    // ── Reflection ray V-paths (4 paths, only when reflection toggle is on) ──
    ...(showRefl ? reflPaths.flatMap(p=>{
      const rData = new Array(n+1).fill(null);
      rData[0]   = p.hTx;      // Tx antenna ASL
      rData[p.rI]= p.rElev;    // reflection point on terrain
      rData[n]   = p.hRx;      // Rx antenna ASL
      // Reflection point marker (circle)
      const mData = new Array(n+1).fill(null);
      mData[p.rI] = p.rElev;
      return [
        {label:p.name, data:rData, type:'line',
         borderColor:p.color+'cc', backgroundColor:'transparent',
         borderWidth:1.5, borderDash:p.dash, spanGaps:true,
         pointRadius:rData.map((v,i)=>i===p.rI?6:0),
         pointStyle:rData.map((v,i)=>i===p.rI?'circle':'circle'),
         pointBackgroundColor:p.color,
         pointBorderColor:'#fff', pointBorderWidth:1.5,
         fill:false, tension:0, order:0.1},
      ];
    }) : []),
  ];

  terrainChart = new Chart(canvas.getContext('2d'),{
    type:'line',
    data:{labels:distances, datasets},
    plugins: sdLabelPlugin ? [sdLabelPlugin] : [],
    options:{
      responsive:false, maintainAspectRatio:false, animation:{duration:0},
      interaction:{mode:'index',intersect:false},
      plugins:{
        legend:{display:false},
        tooltip:{
          backgroundColor:dark?'rgba(15,23,42,.95)':'rgba(15,45,74,.92)',
          titleColor:'#bae6fd',bodyColor:'#e2e8f0',padding:8,
          callbacks:{
            title:items=>'Dist: '+items[0].label+' '+distUnit,
            label:item=>{
              if(!item.raw||item.dataset.label?.startsWith('_'))return null;
              return item.dataset.label+': '+(parseFloat(item.raw)*(isFCC()?3.28084:1)).toFixed(1)+' '+lenUnitLbl()+' ASL';
            },
            filter:item=>item.raw!=null&&!item.dataset.label?.startsWith('_')
          }
        }
      },
      scales:{
        x:{title:{display:true,text:'Distance ('+distUnit+')',font:{size:10},color:txtColor},
           grid:{color:gridColor},
           ticks:{color:txtColor,font:{size:9},maxTicksLimit:10}},
        y:{title:{display:true,text:'Elevation ('+lenUnitLbl()+' ASL)',font:{size:10},color:txtColor},
           grid:{color:gridColor},ticks:{color:txtColor,font:{size:9},callback:v=>Math.round(v*(isFCC()?3.28084:1))},min:yMin,max:yMax}
      },
      layout:{padding:{top:6,right:10,bottom:2,left:0}}
    }
  });
  // Show/hide SD legend entries
  const sdLeg=document.getElementById('sdAntLegend');
  const sdLosLeg=document.getElementById('sdLosLegend');
  const sdFrLeg=document.getElementById('sdFrLegend');
  const rLegMain=document.getElementById('reflLegendMain');
  const rLegCross=document.getElementById('reflLegendCross');
  if(sdLeg)sdLeg.style.display=sdVis?'':'none';
  if(sdLosLeg)sdLosLeg.style.display=sdVis?'':'none';
  if(sdFrLeg)sdFrLeg.style.display=(sdVis&&showFr)?'':'none';
  if(rLegMain)rLegMain.style.display=showRefl?'':'none';
  if(rLegCross)rLegCross.style.display=showRefl?'':'none';

  // Reflection panel
  const reflPanel=document.getElementById('reflectionPanel');
  if(reflPanel){
    if(showRefl && reflPaths.length){
      renderReflectionPanel(reflPaths, hA_m, hB_m, sdSepM, totalKm, freq, elevations, distances);
    } else {
      reflPanel.style.display='none';
      reflPanel.innerHTML='';
    }
  }
}

function redrawTerrainOverlays(){
  // Just re-fetch from cache without hitting API
  if(!_terrainData) return;
  const {distances,elevations,losLine,distUnit} = _terrainData;
  const hasObstr = losLine.some((l,i) => l < elevations[i]);
  renderTerrainChart(distances, elevations, losLine, hasObstr, distUnit);
}

// ── Optimise antenna heights for clear LOS + 60% Fresnel clearance ────────────
function optimiseAntennaHeights(){
  const latA=parseFloat(document.getElementById('siteLatA')?.value);
  const lonA=parseFloat(document.getElementById('siteLonA')?.value);
  const latB=parseFloat(document.getElementById('siteLatB')?.value);
  const lonB=parseFloat(document.getElementById('siteLonB')?.value);
  if(!_terrainData){alert('Please generate the terrain profile first.');return;}

  const {elevations, n, totalKm, freq} = _terrainData;
  const eA = elevations[0], eB = elevations[n];

  // Compute required clearance at each point: terrain + 60% Fresnel radius
  // We need: (eA+hA)*(1-t) + (eB+hB)*t >= req[i]
  // deficit[i] = req[i] - (eA*(1-t) + eB*t)
  // hA*(1-t) + hB*t >= deficit[i]
  const deficits = elevations.map((e,i) => {
    const t = i/n;
    const d1 = t * totalKm, d2 = (1-t) * totalKm;
    const r60 = (d1>0.001&&d2>0.001) ? fresnelR1(d1,d2,freq)*0.6 : 0;
    const req = e + r60 + 0.5; // +0.5m safety margin
    return req - (eA*(1-t) + eB*t);
  });

  // 1D search: try hA from 0 to 200m, find minimum hB needed, minimise total
  let bestHa=3, bestHb=3, bestTotal=Infinity;
  for(let hA=0; hA<=200; hA+=0.5){
    let hB=0;
    for(let i=1; i<n; i++){
      const t=i/n;
      const needed=(deficits[i]-hA*(1-t))/t;
      if(needed>hB)hB=needed;
    }
    hB=Math.max(hB,0);
    // Also ensure site B clears its own terrain
    hB=Math.max(hB,deficits[n]);
    const total=hA+hB;
    if(total<bestTotal){bestTotal=total;bestHa=hA;bestHb=hB;}
  }
  bestHa=Math.max(0,Math.ceil(bestHa*2)/2); // round up to 0.5m
  bestHb=Math.max(0,Math.ceil(bestHb*2)/2);

  // Apply to inputs (display units: ft in FCC)
  const iA=document.getElementById('antHgtA');
  const iB=document.getElementById('antHgtB');
  if(iA)iA.value=(isFCC()?mToFt(bestHa):bestHa).toFixed(1);
  if(iB)iB.value=(isFCC()?mToFt(bestHb):bestHb).toFixed(1);

  // Re-fetch terrain with new heights
  fetchTerrainProfile();
  alert('Optimised: Site A = '+fmtLen(bestHa)+' AGL, Site B = '+fmtLen(bestHb)+' AGL\n(60% Fresnel zone clearance + 0.5 m safety margin)');
}

function updateTerrainProfile(){
  const latA=parseFloat(document.getElementById('siteLatA')?.value);
  const lonA=parseFloat(document.getElementById('siteLonA')?.value);
  const latB=parseFloat(document.getElementById('siteLatB')?.value);
  const lonB=parseFloat(document.getElementById('siteLonB')?.value);
  if(!isNaN(latA)&&!isNaN(lonA)&&!isNaN(latB)&&!isNaN(lonB)){
    clearTimeout(window._terrainTimer);
    window._terrainTimer=setTimeout(fetchTerrainProfile,300);
  }
}

// ===== ETSI / FCC =====
const RAIN_ZONES={ETSI:[["Manual", "42"], ["A", "8"], ["B", "12"], ["C", "15"], ["D", "19"], ["E", "22"], ["F", "28"], ["G", "30"], ["H", "32"], ["J", "35"], ["K", "42"], ["L", "60"], ["M", "63"], ["N", "95"], ["P", "145"], ["Q", "115"]],FCC:[["Manual", "36"], ["A", "9.9"], ["B", "21.1"], ["B1", "16.1"], ["B2", "25.8"], ["C", "29.5"], ["D1", "36.2"], ["D2", "46.8"], ["D3", "61.6"], ["E", "91.5"], ["F", "22.2"], ["G", "90.2"], ["H", "209.3"]]};
state.std='ETSI';

function onStdChange(){
  state.std=document.getElementById('stdSel').value;
  if(state.isMW){applyMwBandwidths();populateMwBands();populateMwAntennas();populateMwMods();
    enforceMountForSite('A',state.antA);enforceMountForSite('B',state.antB);}
  rebuildRainZones();
  updateUnits();
  if(state.isMW)update();
}
function updateUnits(){
  const fcc=state.std==='FCC';
  // Distance label
  const dl=document.getElementById('distUnitLbl');if(dl)dl.textContent=fcc?'miles':'km';
  const sdu=document.getElementById('setDistUnit');if(sdu)sdu.textContent=fcc?'miles':'km';
  // Sync Range Sweep labels
  rrInitDefaults();
  // Antenna selects
  const antOpts=fcc?[
    {v:'0.2438',t:'0.6 ft'},{v:'0.3048',t:'1 ft'},{v:'0.6096',t:'2 ft'},{v:'0.9144',t:'3 ft'}
  ]:[
    {v:'0.2',t:'0.2 m'},{v:'0.3',t:'0.3 m'},{v:'0.31',t:'0.3 m+'},{v:'0.6',t:'0.6 m'},{v:'0.9',t:'0.9 m'}
  ];
  ['antA','antB'].forEach(id=>{
    if(state.isMW)return; // MW dish options are managed by populateMwAntennas
    const sel=document.getElementById(id);if(!sel)return;
    const prev=sel.value;
    sel.innerHTML='';
    antOpts.forEach((o,i)=>{
      const opt=document.createElement('option');
      opt.value=o.v;opt.textContent=o.t;
      if(i===0)opt.selected=true;
      sel.appendChild(opt);
    });
    // Try to keep a similar size selected
    const match=[...sel.options].find(o=>Math.abs(+o.value-+prev)<0.05);
    if(match)sel.value=match.value;
    state[id]=+sel.value;
  });
  // Distance display conversion
  const distEl=document.getElementById('distance');
  if(distEl&&document.activeElement!==distEl){
    const d=state.distance;
    distEl.value=fcc?(d/1.60934).toFixed(2):d.toFixed(2);
  }
  // Antenna height & search-radius: m <-> ft
  const aglA=document.getElementById('aglUnitA'),aglB=document.getElementById('aglUnitB');
  const radA=document.getElementById('radUnitA'),radB=document.getElementById('radUnitB');
  const curFt=aglA?aglA.textContent.trim().indexOf('ft')===0:false;
  if(curFt!==fcc){
    [['antHgtA',1],['antHgtB',1]].forEach(([id,dp])=>{
      const el=document.getElementById(id);if(!el||document.activeElement===el)return;
      const v=parseFloat(el.value);if(!isFinite(v))return;
      el.value=(fcc?mToFt(v):ftToM(v)).toFixed(dp);
    });
    ['searchRadiusA','searchRadiusB'].forEach(id=>{
      const el=document.getElementById(id);if(!el||document.activeElement===el)return;
      const v=parseFloat(el.value);if(!isFinite(v))return;
      el.value=Math.round(fcc?mToFt(v):ftToM(v)).toString();
    });
  }
  if(aglA)aglA.textContent=fcc?'ft AGL':'m AGL';
  if(aglB)aglB.textContent=fcc?'ft AGL':'m AGL';
  if(radA)radA.textContent=fcc?'ft':'m';
  if(radB)radB.textContent=fcc?'ft':'m';
}

function rebuildRainZones(){
  const std=state.std||'ETSI';
  const zones=RAIN_ZONES[std];
  const defVal=std==='FCC'?'36':'42';
  const rz=document.getElementById('rainZone');if(!rz)return;
  const prev=rz.value;
  rz.innerHTML='';
  zones.forEach(([z,v])=>{
    const o=document.createElement('option');
    o.value=v;
    o.textContent=z==='Manual'?'Manual':z+' ('+v+' mm/h)';
    rz.appendChild(o);
  });
  const mo=document.createElement('option');
  mo.id='rainMapOpt';mo.value='map';mo.disabled=true;
  mo.style.color='#0891b2';mo.style.fontStyle='italic';
  mo.textContent='● From Map — pin location first';
  rz.appendChild(mo);
  const pick=[...rz.options].find(o=>o.value===prev)||[...rz.options].find(o=>o.value===defVal);
  if(pick)rz.value=pick.value;
  if(rz.value!=='map'&&rz.value!=='custom')state.rainRate=parseFloat(rz.value)||42;
}

