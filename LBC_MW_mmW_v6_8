async function patchXlsxWithCharts(wbArr, images){
  if(typeof JSZip==='undefined') return null;
  try{
    const zip=await JSZip.loadAsync(wbArr);
    // ── Read existing structure ──────────────────────────────────────────────
    const ctXml  = await zip.file('[Content_Types].xml').async('string');
    const wbXml  = await zip.file('xl/workbook.xml').async('string');
    const wbRXml = await zip.file('xl/_rels/workbook.xml.rels').async('string');
    // Determine next indices
    const _nums=key=>Object.keys(zip.files).map(f=>(f.match(key)||[])[1]).filter(Boolean).map(Number);
    const nextWsNum   = (_nums(/xl\/worksheets\/sheet(\d+)\.xml$/).length ? Math.max(..._nums(/xl\/worksheets\/sheet(\d+)\.xml$/))+1 : 1);
    const nextMediaNum= (_nums(/xl\/media\/image(\d+)/).length        ? Math.max(..._nums(/xl\/media\/image(\d+)/))+1        : 1);
    const nextDrawNum = (_nums(/xl\/drawings\/drawing(\d+)\.xml$/).length? Math.max(..._nums(/xl\/drawings\/drawing(\d+)\.xml$/))+1: 1);
    const nextSheetId = ([...wbXml.matchAll(/sheetId="(\d+)"/g)].map(m=>+m[1]).length ? Math.max(...[...wbXml.matchAll(/sheetId="(\d+)"/g)].map(m=>+m[1]))+1 : 1);
    const nextRelId   = ([...wbRXml.matchAll(/Id="rId(\d+)"/g)].map(m=>+m[1]).length  ? Math.max(...[...wbRXml.matchAll(/Id="rId(\d+)"/g)].map(m=>+m[1]))+1  : 1);
    // ── Patch gridlines off on all existing worksheets ───────────────────────
    const _wsFiles=Object.keys(zip.files).filter(f=>/xl\/worksheets\/sheet\d+\.xml$/.test(f));
    for(const _wsf of _wsFiles){
      let _wx=await zip.file(_wsf).async('string');
      if(_wx.includes('<sheetViews>')){
        _wx=_wx.replace(/<sheetView\b([^>]*?)(\/?)>/g,(m,a,sl)=>{
          const clean=a.replace(/\s*showGridLines="[^"]*"/g,'');
          return '<sheetView'+clean+' showGridLines="0"'+(sl||'')+'>'; 
        });
      } else {
        _wx=_wx.replace('<sheetData','<sheetViews><sheetView showGridLines="0" workbookViewId="0"/></sheetViews><sheetData');
      }
      zip.file(_wsf,_wx);
    }
    // ── Charts sheet — always added; images embedded when captured ───────────
    let _wsXml, _wsRels;
    if(images.length){
      images.forEach((img,i)=>zip.file(`xl/media/image${nextMediaNum+i}.png`,img.data,{base64:true}));
      const ROWS=30,GAP=3;
      const drawXml=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<xdr:wsDr xmlns:xdr="http://schemas.openxmlformats.org/drawingml/2006/spreadsheetDrawing" xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships">
${images.map((img,i)=>{const r0=i*(ROWS+GAP);return `  <xdr:twoCellAnchor editAs="oneCell">
    <xdr:from><xdr:col>0</xdr:col><xdr:colOff>0</xdr:colOff><xdr:row>${r0}</xdr:row><xdr:rowOff>0</xdr:rowOff></xdr:from>
    <xdr:to><xdr:col>14</xdr:col><xdr:colOff>0</xdr:colOff><xdr:row>${r0+ROWS}</xdr:row><xdr:rowOff>0</xdr:rowOff></xdr:to>
    <xdr:pic><xdr:nvPicPr><xdr:cNvPr id="${i+2}" name="img${i+1}"/><xdr:cNvPicPr><a:picLocks noChangeAspect="1"/></xdr:cNvPicPr></xdr:nvPicPr>
      <xdr:blipFill><a:blip r:embed="rId${i+1}"/><a:stretch><a:fillRect/></a:stretch></xdr:blipFill>
      <xdr:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="0" cy="0"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></xdr:spPr>
    </xdr:pic><xdr:clientData/>
  </xdr:twoCellAnchor>`;}).join('\n')}
</xdr:wsDr>`;
      const drawRels=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">
${images.map((img,i)=>`  <Relationship Id="rId${i+1}" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/image" Target="../media/image${nextMediaNum+i}.png"/>`).join('\n')}
</Relationships>`;
      zip.file(`xl/drawings/drawing${nextDrawNum}.xml`, drawXml);
      zip.file(`xl/drawings/_rels/drawing${nextDrawNum}.xml.rels`, drawRels);
      _wsXml=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?><worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"><sheetViews><sheetView showGridLines="0" workbookViewId="0"/></sheetViews><sheetData/><drawing r:id="rId1"/></worksheet>`;
      _wsRels=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/drawing" Target="../drawings/drawing${nextDrawNum}.xml"/></Relationships>`;
      let ct=ctXml;
      if(!ct.includes('Extension="png"'))          ct=ct.replace('</Types>','  <Default Extension="png" ContentType="image/png"/>\n</Types>');
      if(!ct.includes(`drawing${nextDrawNum}.xml`)) ct=ct.replace('</Types>',`  <Override PartName="/xl/drawings/drawing${nextDrawNum}.xml" ContentType="application/vnd.openxmlformats-officedocument.drawing+xml"/>\n</Types>`);
      if(!ct.includes(`sheet${nextWsNum}.xml`))    ct=ct.replace('</Types>',`  <Override PartName="/xl/worksheets/sheet${nextWsNum}.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml"/>\n</Types>`);
      zip.file('[Content_Types].xml',ct);
    } else {
      // No images — plain placeholder sheet
      _wsXml=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?><worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main"><sheetViews><sheetView showGridLines="0" workbookViewId="0"/></sheetViews><sheetData><row r="1"><c r="A1" t="inlineStr"><is><t>Charts: scroll to each chart section before exporting to embed images.</t></is></c></row></sheetData></worksheet>`;
      _wsRels=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"></Relationships>`;
      let ct=ctXml;
      if(!ct.includes(`sheet${nextWsNum}.xml`)) ct=ct.replace('</Types>',`  <Override PartName="/xl/worksheets/sheet${nextWsNum}.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml"/>\n</Types>`);
      zip.file('[Content_Types].xml',ct);
    }
    zip.file(`xl/worksheets/sheet${nextWsNum}.xml`, _wsXml);
    zip.file(`xl/worksheets/_rels/sheet${nextWsNum}.xml.rels`, _wsRels);
    zip.file('xl/workbook.xml', wbXml.replace('</sheets>',`  <sheet name="Charts" sheetId="${nextSheetId}" r:id="rId${nextRelId}"/>\n  </sheets>`));
    zip.file('xl/_rels/workbook.xml.rels', wbRXml.replace('</Relationships>',`  <Relationship Id="rId${nextRelId}" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet" Target="worksheets/sheet${nextWsNum}.xml"/>\n</Relationships>`));
    // ── Return as base64 ─────────────────────────────────────────────────────
    return await zip.generateAsync({type:'base64',mimeType:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',compression:'DEFLATE',compressionOptions:{level:4}});
  }catch(e){console.error('Chart embed failed:',e);return null;}
}

// ===== EXCEL EXPORT =====
async function exportToExcel(){
  try{
    if(typeof XLSX==='undefined'){alert('SheetJS not loaded.');return;}
    const{freq:f,bw,pol,antA,antB,bl,cFactor,rainRate,targetAvail:ta,distance:d,frameIdx:fi}=state;
    const{band,FSL,atmLoss,atm,Gt,Gr,rain,mods}=calc;
    const now=new Date();
    const wb=XLSX.utils.book_new();

    // ── MW-aware helpers ──────────────────────────────────────────────────────
    const isMW=state.isMW;
    const mwProd=state.mwProduct||'IP-20C';
    const mwBandHz=state.mwBand;
    const mwBwKey=isMW?mwNearestBw(mwProd,parseFloat(bw)):null;
    // Correct mod list for current mode (MW or mmW)
    const exportMods=isMW?mwMods(mwProd,bw,mwBandHz):MODS;
    // Get full cap-row (all frame sizes) for a mod in current mode
    const getCapRow=mod=>{
      if(isMW){
        const row=MW_CAP[mwProd]?.[mwBwKey]?.[mod];
        if(!row) return null;
        const mult=MW_CARRIERS[state.config||'1+0']||1;
        return row.map(v=>v*mult);
      }
      return (CAPACITY[+bw]||CAPACITY[String(bw)])?.[mod]??null;
    };
    // ─────────────────────────────────────────────────────────────────────────

    const BDR=(clr)=>({style:'thin',color:{rgb:clr||'000000'}});
    const FULL_BDR={top:BDR(),bottom:BDR(),left:BDR(),right:BDR()};
    const HDR_BDR={top:BDR(),bottom:BDR(),left:BDR(),right:BDR()};
    const SEC_BDR={top:BDR(),bottom:BDR(),left:BDR(),right:BDR()};
    const S=(fg,bg,bold,sz,hz,bdr)=>{
      const s={font:{bold:!!bold,sz:sz||10,name:'Calibri'},
               alignment:{horizontal:hz||'left',vertical:'center',wrapText:false},
               border:bdr||FULL_BDR};
      if(fg)s.font.color={rgb:fg};
      if(bg)s.fill={fgColor:{rgb:bg},patternType:'solid'};
      return s;
    };
    const ST={
      title:S('FFFFFF','0F2D4A',true,14,'center',SEC_BDR),
      sub:  S('475569','EFF6FF',false,9,'left',FULL_BDR),
      sec:  S('FFFFFF','1A3F5C',true,11,'center',SEC_BDR),
      hdr:  S('FFFFFF','234D6E',true,11,'center',HDR_BDR),
      capH: S('FFFFFF','155E75',true,11,'center',HDR_BDR),
      lbl:  S('1E293B','F1F5F9',true,10,'left',FULL_BDR),
      lbl2: S('334155','FFFFFF',false,10,'left',FULL_BDR),
      val:  S('0F172A','FFFFFF',false,10,'right',FULL_BDR),
      val2: S('0F172A','F8FAFC',false,10,'right',FULL_BDR),
      unit: S('64748B','FFFFFF',false,9,'left',FULL_BDR),
      unit2:S('64748B','F8FAFC',false,9,'left',FULL_BDR),
      ok:   S('065F46','D1FAE5',true,10,'center',FULL_BDR),
      warn: S('92400E','FEF3C7',true,10,'center',FULL_BDR),
      fail: S('991B1B','FEE2E2',true,10,'center',FULL_BDR),
      dim:  S('94A3B8','FFFFFF',false,9,'right',FULL_BDR),
      dim2: S('94A3B8','F8FAFC',false,9,'right',FULL_BDR),
      posg: S('065F46','FFFFFF',true,10,'right',FULL_BDR),
      posg2:S('065F46','F8FAFC',true,10,'right',FULL_BDR),
      negn: S('DC2626','FFFFFF',true,10,'right',FULL_BDR),
      negn2:S('DC2626','F8FAFC',true,10,'right',FULL_BDR),
      cap:  S('155E75','CFFAFE',true,10,'right',FULL_BDR),
      cap2: S('155E75','E0FDFF',true,10,'right',FULL_BDR),
      foot: S('000000',null,true,10,'left',FULL_BDR),
    };
    // Helper: return alternating style (even=white, odd=stripe)
    const alt=(even,s1,s2)=>even?s1:s2;
    // Helper: center all cells in a worksheet, optionally skipping row ranges
    const _ctrWS=(wsObj,skipRows=[])=>{
      Object.keys(wsObj).filter(k=>!k.startsWith('!')).forEach(k=>{
        const {r}=XLSX.utils.decode_cell(k);
        if(skipRows.some(([a,b])=>r>=a&&r<=b))return;
        if(wsObj[k]&&wsObj[k].s)wsObj[k].s={...wsObj[k].s,alignment:{horizontal:'center',vertical:'center',wrapText:false}};
      });
    };

    const ws={},mg=[];
    const ec=(r,c)=>XLSX.utils.encode_cell({r,c});
    const cs=(r,c,v,t,s)=>{ws[ec(r,c)]={t:t||'s',v:(v===null||v===undefined)?'':v,s:s||{}};};
    const fill=(r,c1,c2,s)=>{for(let c=c1;c<=c2;c++){if(!ws[ec(r,c)])cs(r,c,'','s',s);else ws[ec(r,c)].s=s;}};
    const mgc=(r1,c1,r2,c2)=>mg.push({s:{r:r1,c:c1},e:{r:r2,c:c2}});
    const NC=13;
    let row=0;

    cs(row,0,isMW
      ?`Microwave Link Budget Report — ${mwProd}  ·  ${f} GHz (${mwBandHz} GHz Band)  ·  ${bw} MHz`
      :`${band}-Band Link Budget Report — ${f} GHz ${band}-Band`,'s',ST.title);
    fill(row,1,NC-1,ST.title);mgc(row,0,row,NC-1);row++;
    cs(row,0,`Generated: ${now.toLocaleDateString()} ${now.toLocaleTimeString()}  |  ${bw} MHz  |  ${pol} Pol  |  ${d} km  |  Target: ${fmtA(ta)}%  |  Capacity frame: ${CAP_SIZES[fi]}`,'s',ST.sub);
    fill(row,1,NC-1,ST.sub);mgc(row,0,row,NC-1);row+=2;

    // INPUT PARAMS
    cs(row,0,'INPUT PARAMETERS','s',ST.sec);fill(row,1,2,ST.sec);mgc(row,0,row,2);row++;
    ['Parameter','Value','Unit'].forEach((h,c)=>cs(row,c,h,'s',ST.hdr));row++;
    [['Frequency',f,'GHz'],['Band',band+'-Band',''],['Bandwidth',bw,'MHz'],['Polarization',pol,''],
     ['Antenna Site A',`${antA} m → ${Gt.toFixed(1)} dBi`,''],['Antenna Site B',`${antB} m → ${Gr.toFixed(1)} dBi`,''],
     ['Configuration',state.config,''],['Branching Loss',bl,'dB'],['Distance',d,'km'],['Rain Rate R₀.₀₁',rainRate,'mm/h'],
     ['C Factor',cFactor,''],['Target Availability',parseFloat(fmtA(ta)),'%'],
     ['Target Outage',parseFloat(((100-ta)/100*31536e3).toFixed(1)),'s/year'],
     ['Capacity Frame Size',CAP_SIZES[fi],''],
    ].forEach(([l,v,u])=>{cs(row,0,l,'s',ST.lbl);cs(row,1,v,typeof v==='number'?'n':'s',ST.val);cs(row,2,u,'s',ST.unit);row++;});
    row++;

    // LINK BUDGET
    cs(row,0,'LINK BUDGET BREAKDOWN','s',ST.sec);fill(row,1,2,ST.sec);mgc(row,0,row,2);row++;
    ['Component','Value','Unit'].forEach((h,c)=>cs(row,c,h,'s',ST.hdr));row++;
    [['Free Space Loss',parseFloat(FSL.toFixed(3)),'dB'],
     ['Atmospheric Loss',parseFloat(atmLoss.toFixed(6)),'dB'],
     ['  H₂O specific attenuation γ',parseFloat(atm.gW.toFixed(6)),'dB/km'],
     ['  O₂ specific attenuation γ',parseFloat(atm.gO.toFixed(6)),'dB/km'],
     ['Rain coefficient k',parseFloat(rain.k.toFixed(4)),''],
     ['Rain coefficient α',parseFloat(rain.a.toFixed(4)),''],
     ['Specific rain attenuation γ',parseFloat(rain.gamma.toFixed(4)),'dB/km'],
     ['Effective path length (reduced)',parseFloat(rain.dEff.toFixed(4)),'km'],
     ['Rain attenuation A₀.₀₁',parseFloat(rain.A001.toFixed(3)),'dB'],
     ['Antenna gain Tx (Site A)',parseFloat(Gt.toFixed(2)),'dBi'],
     ['Antenna gain Rx (Site B)',parseFloat(Gr.toFixed(2)),'dBi'],
    ].forEach(([l,v,u],ri)=>{
      const even=ri%2===0;
      cs(row,0,l,'s',even?ST.lbl:ST.lbl2);
      cs(row,1,v,'n',even?ST.val:ST.val2);
      cs(row,2,u,'s',even?ST.unit:ST.unit2);
      row++;
    });
    row++;

    // MODULATION TABLE
    cs(row,0,'MODULATION PERFORMANCE & CAPACITY','s',ST.sec);fill(row,1,NC-1,ST.sec);mgc(row,0,row,NC-1);row++;
    const th=['Modulation','TX (dBm)','RSL Thr. (dBm)','Unfaded RX (dBm)','Eff. FM (dB)',
      'Rain A₀.₀₁ (dB)','Rain Outage (s)','MP Outage (s)','Total Outage (s)',
      'Time in Mod (d:hh:mm:ss)','Availability (%)','Status',`Capacity (${CAP_SIZES[fi]})`];
    th.forEach((h,c)=>cs(row,c,h,'s',c===12?ST.capH:ST.hdr));row++;
    mods.forEach((mr,ri)=>{
      const even=ri%2===0;
      const aS=mr.ok?ST.ok:mr.avail>=ta-.5?ST.warn:ST.fail;
      const cap=getCap(bw,mr.mod,fi);
      const nextAvail=ri<mods.length-1?mods[ri+1].avail:0;
      const timeInModSec=(mr.avail-nextAvail)*31536e3/100;
      const modFont={font:{bold:true,sz:10,name:'Calibri',color:{rgb:'0F172A'}},
        fill:{fgColor:{rgb:even?'FFFFFF':'F8FAFC'},patternType:'solid'},
        alignment:{horizontal:'left',vertical:'center'},border:FULL_BDR};
      cs(row,0,mr.mod,'s',modFont);
      cs(row,1,mr.tx,'n',even?ST.val:ST.val2);
      cs(row,2,parseFloat(mr.rsl.toFixed(1)),'n',even?ST.val:ST.val2);
      cs(row,3,parseFloat(mr.rxu.toFixed(1)),'n',even?ST.val:ST.val2);
      cs(row,4,parseFloat(mr.efm.toFixed(2)),'n',mr.efm>0?(even?ST.posg:ST.posg2):(even?ST.negn:ST.negn2));
      cs(row,5,parseFloat(rain.A001.toFixed(3)),'n',rain.A001>mr.efm?(even?ST.negn:ST.negn2):(even?ST.posg:ST.posg2));
      cs(row,6,parseFloat(mr.rainSec.toFixed(1)),'n',even?ST.dim:ST.dim2);
      cs(row,7,parseFloat(mr.mpSec.toFixed(2)),'n',even?ST.dim:ST.dim2);
      cs(row,8,parseFloat(mr.totSec.toFixed(1)),'n',even?ST.dim:ST.dim2);
      cs(row,9,fmtDHMS(timeInModSec),'s',{font:{bold:true,sz:9,name:'Calibri',color:{rgb:'155E75'}},fill:{fgColor:{rgb:even?'CFFAFE':'E0F7FA'},patternType:'solid'},alignment:{horizontal:'center',vertical:'center'},border:FULL_BDR});
      cs(row,10,parseFloat(fmtA(mr.avail)),'n',aS);
      cs(row,11,mr.ok?'✓ OK':'✗ FAIL','s',aS);
      cs(row,12,cap!==null?parseFloat(cap.toFixed(2)):null,cap!==null?'n':'s',even?ST.cap:ST.cap2);
      // Center all cells in modulation data rows
      for(let c=0;c<NC;c++){const k=ec(row,c);if(ws[k])ws[k].s={...ws[k].s,alignment:{horizontal:'center',vertical:'center',wrapText:false}};}
      row++;
    });
    // A37:M47 — bold black text, no fill (Excel rows 37-47 = 0-indexed 36-46); row 35 (Excel 36) keeps original header colour
    const BLACK_BOLD=S('000000',null,true,10,'center',FULL_BDR);
    for(let r=36;r<=46;r++){for(let c=0;c<=12;c++){const k=ec(r,c);if(ws[k])ws[k].s=BLACK_BOLD;}}
    row++;
    cs(row,0,'Reference: ITU-R P.838-3 · ITU-R P.676-12 · ITU-R P.530-17 (multipath) · ITU-R P.530-18 (rain path reduction, frequency-dependent χ(f)) · Ceragon mmW RSL, TX & Capacity tables','s',ST.foot);
    // A49: no borders
    const refK=ec(row,0);if(ws[refK])ws[refK].s={...ws[refK].s,border:{}};
    mgc(row,0,row,NC-1);row++;

    _ctrWS(ws,[[5,18],[22,32]]);
    ws['!ref']=XLSX.utils.encode_range({s:{r:0,c:0},e:{r:row,c:NC-1}});
    ws['!merges']=mg;
    // Autofit cols D-M (indices 3-12); keep A-C fixed
    const fixedW=[32,14,14];
    for(let c=3;c<=12;c++){
      let mx=10;
      Object.keys(ws).filter(k=>k[0]!=='!').forEach(k=>{
        const addr=XLSX.utils.decode_cell(k);
        if(addr.c===c){const v=ws[k].v;const l=v!=null?String(v).length:0;if(l>mx)mx=l;}
      });
      fixedW.push(mx+2);
    }
    ws['!cols']=fixedW.map(w=>({wch:w}));
    ws['!rows']=Array.from({length:row},(_,i)=>({hpt:i<3?22:18}));
    ws['!views']=[{showGridLines:false}];
    XLSX.utils.book_append_sheet(wb,ws,'Link Budget');

    // SHEET 2: CAPACITY OVERVIEW (all frame sizes)
    const ws3={},mg3=[];
    const ec3=(r,c)=>XLSX.utils.encode_cell({r,c});
    const cs3=(r,c,v,t,s)=>{ws3[ec3(r,c)]={t:t||'s',v:(v===null||v===undefined)?'':v,s:s||{}};};
    const mg3a=(r1,c1,r2,c2)=>mg3.push({s:{r:r1,c:c1},e:{r:r2,c:c2}});
    let r3=0;
    const totalCols=CAP_SIZES.length+1;
    cs3(r3,0,`Capacity Overview (Mbps) — ${bw} MHz Bandwidth`,'s',ST.title);
    for(let c=1;c<totalCols;c++)cs3(r3,c,'','s',ST.title);
    mg3a(r3,0,r3,totalCols-1);r3++;
    cs3(r3,0,`Frequency: ${f} GHz ${band}-Band  |  Bandwidth: ${bw} MHz  |  Polarization: ${pol}`,'s',ST.sub);
    mg3a(r3,0,r3,totalCols-1);r3++;
    cs3(r3,0,'Modulation','s',ST.hdr);
    CAP_SIZES.forEach((sz,i)=>cs3(r3,i+1,sz,'s',ST.hdr));r3++;
    exportMods.forEach((mod,ri)=>{
      const even3=ri%2===0;
      const capRow=getCapRow(mod);
      cs3(r3,0,mod,'s',{font:{bold:true,sz:10,name:'Calibri'},fill:{fgColor:{rgb:even3?'FFFFFF':'F8FAFC'},patternType:'solid'},border:FULL_BDR});
      if(capRow){
        CAP_SIZES.forEach((_,i)=>{
          cs3(r3,i+1,capRow[i]??null,capRow[i]!=null?'n':'s',even3?ST.val:ST.val2);
        });
      } else {
        CAP_SIZES.forEach((_,i)=>cs3(r3,i+1,'N/A','s',{font:{sz:10,color:{rgb:'94A3B8'}},fill:{fgColor:{rgb:even3?'FFFFFF':'F8FAFC'},patternType:'solid'},alignment:{horizontal:'center'},border:FULL_BDR}));
      }
      r3++;
    });
    _ctrWS(ws3);
    ws3['!ref']=XLSX.utils.encode_range({s:{r:0,c:0},e:{r:r3,c:totalCols-1}});
    ws3['!merges']=mg3;
    ws3['!cols']=[{wch:14},...CAP_SIZES.map(()=>({wch:12}))];
    ws3['!views']=[{showGridLines:false}];
    XLSX.utils.book_append_sheet(wb,ws3,'Capacity Overview');

    // SHEET 3: MAX RANGE SUMMARY
    const MILES=[99,99.5,99.8,99.9,99.95,99.99,99.995,99.998,99.999,99.9999];
    const ws2={},mg2=[];
    const ec2=(r,c)=>XLSX.utils.encode_cell({r,c});
    const cs2=(r,c,v,t,s)=>{ws2[ec2(r,c)]={t:t||'s',v:(v===null||v===undefined)?'':v,s:s||{}};};
    const mg2a=(r1,c1,r2,c2)=>mg2.push({s:{r:r1,c:c1},e:{r:r2,c:c2}});
    let r2=0;
    const nc2=exportMods.length*2+1;
    cs2(r2,0,`Max Range Summary — ${f} GHz ${isMW?mwProd+' '+mwBandHz+'GHz':band+'-Band'}  |  ${bw} MHz`,'s',ST.title);
    for(let c=1;c<nc2;c++)cs2(r2,c,'','s',ST.title);
    mg2a(r2,0,r2,nc2-1);r2++;
    cs2(r2,0,`Ant: ${antA}m/Ant:${antB}m | Rain: ${rainRate} mm/h | C: ${cFactor} | Capacity frame: ${CAP_SIZES[fi]}`,'s',ST.sub);
    mg2a(r2,0,r2,nc2-1);r2++;
    // Headers: Avail | mod1 km | mod1 Mbps | mod2 km | ...
    cs2(r2,0,'Availability (%)','s',ST.hdr);
    exportMods.forEach((m,i)=>{
      cs2(r2,i*2+1,m+' (km)','s',ST.hdr);
      cs2(r2,i*2+2,m+' (Mbps)','s',ST.hdr);
    });r2++;
    MILES.forEach((milestone,ri)=>{
      const isTgt=Math.abs(milestone-ta)<0.0001;
      const rowBg=isTgt?'DBEAFE':ri%2===0?'FFFFFF':'F8FAFC';
      const fnt={bold:isTgt,sz:10,color:{rgb:isTgt?'1D4ED8':'334155'}};
      cs2(r2,0,fmtA(milestone)+'%','s',{font:fnt,fill:{fgColor:{rgb:rowBg},patternType:'solid'},alignment:{horizontal:'center',vertical:'center'},border:FULL_BDR});
      exportMods.forEach((mod,i)=>{
        const dm=findMaxDistAt(mod,milestone);
