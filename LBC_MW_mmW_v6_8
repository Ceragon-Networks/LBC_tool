// Register zoom plugin with Chart.js
if(typeof ChartZoom !== 'undefined') Chart.register(ChartZoom);
</script>
<script src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.bundle.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
/* ── Light theme (default) ── */
:root,[data-theme="light"]{
  --navy:#0f2d4a;--navy2:#1a3f5c;--navy3:#234d6e;
  --blue:#2563eb;--blue-l:#dbeafe;--blue-m:#93c5fd;
  --sl:#f1f5f9;--sll:#f8fafc;--border:#cbd5e1;--border-l:#e2e8f0;
  --green:#059669;--green-l:#d1fae5;--green-d:#065f46;
  --amber:#d97706;--amber-l:#fef3c7;--red:#dc2626;--red-l:#fee2e2;
  --white:#ffffff;--teal:#0891b2;--teal-l:#cffafe;--teal-d:#155e75;
  --text:#0f172a;--text2:#334155;--text3:#64748b;
  --bg:#f8fafc;--card-bg:#ffffff;--hdr-from:#0f2d4a;--hdr-to:#1a3f5c;
  --chart-grid:rgba(0,0,0,.07);--chart-txt:#475569;
}
/* ── Dark theme ── */
[data-theme="dark"]{
  --navy:#e2e8f0;--navy2:#cbd5e1;--navy3:#94a3b8;
  --blue:#60a5fa;--blue-l:#1e3a5f;--blue-m:#1d4ed8;
  --sl:#1e293b;--sll:#0f172a;--border:#334155;--border-l:#1e293b;
  --green:#34d399;--green-l:#064e3b;--green-d:#a7f3d0;
  --amber:#fbbf24;--amber-l:#451a03;--red:#f87171;--red-l:#450a0a;
  --white:#1e293b;--teal:#22d3ee;--teal-l:#0c4a6e;--teal-d:#a5f3fc;
  --text:#f1f5f9;--text2:#cbd5e1;--text3:#94a3b8;
  --bg:#0f172a;--card-bg:#1e293b;--hdr-from:#0a1628;--hdr-to:#0f2d4a;
  --chart-grid:rgba(255,255,255,.15);--chart-txt:#e2e8f0;
  --hdr-gradient-from:#0a1628;--hdr-gradient-to:#0f2d4a;
}
/* Dark mode: chart/sec headers stay dark navy for contrast */
[data-theme="dark"] .chart-hdr,
[data-theme="dark"] .sec-hdr,
[data-theme="dark"] .card-hdr{
  background:linear-gradient(90deg,#0a1628,#0f2d4a) !important;
  color:#e2e8f0;
}
[data-theme="dark"] .chart-hdr-title,
[data-theme="dark"] .sec-hdr-title{color:#e2e8f0;}
/* Dark mode: cap-cell teal readable */
[data-theme="dark"] .cap-cell{background:#0c4a6e;color:#7dd3fc;}
/* Dark mode: Fetch Climate button */
[data-theme="dark"] #fetchBtn{background:#1e3a5f !important;color:#e2e8f0 !important;border:1px solid rgba(255,255,255,.2);}
[data-theme="dark"] #fetchBtn:hover{background:#1d4ed8 !important;}
[data-theme="dark"] #geoKBtn{background:#1e3a5f !important;color:#e2e8f0 !important;border:1px solid rgba(255,255,255,.2);}
[data-theme="dark"] #geoKBtn:hover{background:#1d4ed8 !important;}
/* Dark mode: climate badge/results */
[data-theme="dark"] .climate-badge{background:linear-gradient(135deg,#0a2e1a,#0f3320);border-color:#34d399;}
[data-theme="dark"] .cb-row{border-color:#1a4730;}
[data-theme="dark"] .cb-lbl{color:#94a3b8;}
[data-theme="dark"] .cb-val{color:#34d399;}
[data-theme="dark"] .apply-btn{background:linear-gradient(135deg,#065f46,#047857);}
[data-theme="dark"] .apply-btn:hover{background:linear-gradient(135deg,#047857,#059669);}
/* Dark mode: site location card inputs */
[data-theme="dark"] #locSearch{background:var(--sl) !important;color:var(--text) !important;border-color:var(--border) !important;}
[data-theme="dark"] #locSearch::placeholder{color:var(--text3);}
[data-theme="dark"] #siteLat,[data-theme="dark"] #siteLon{background:var(--sl) !important;color:var(--text) !important;border-color:var(--border) !important;}
[data-theme="dark"] #siteLat::placeholder,[data-theme="dark"] #siteLon::placeholder{color:var(--text3);}
/* Dark mode: peak search button */
[data-theme="dark"] .peak-btn{background:#064e3b !important;color:#a7f3d0 !important;border-color:#10b981 !important;}
[data-theme="dark"] #peakSuggestion{background:#0c2e1a;border-color:#34d399;color:#a7f3d0;}
/* Dark mode: max distance button and panel */
[data-theme="dark"] .max-btn{background:#1e3a5f !important;color:#e2e8f0 !important;border:1px solid rgba(255,255,255,.2);}
[data-theme="dark"] .max-btn:hover{background:#1d4ed8 !important;}
[data-theme="dark"] .max-panel{background:var(--sl);border-color:var(--border);}
[data-theme="dark"] .max-panel-hdr{background:#0a1628 !important;}
[data-theme="dark"] .max-tbl td{color:var(--text);border-color:var(--border);}
/* Dark mode: modulation select in header */
[data-theme="dark"] #selMod{
  background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.25);
  color:#e2e8f0;border-radius:5px;padding:3px 7px;
}
[data-theme="dark"] #selMod option{background:#0f2d4a;color:#e2e8f0;}
/* Dark mode: chart control selects */
[data-theme="dark"] .chart-controls select{
  background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.25);color:#e2e8f0;
}
[data-theme="dark"] .chart-controls select option{
  background:#0f2d4a;color:#e2e8f0;
}
[data-theme="dark"] .chart-controls label{color:#93c5fd;}
/* Dark mode: chart canvas area */
[data-theme="dark"] .chart-canvas-wrap{background:var(--sl);}
/* Dark mode: site location card */
[data-theme="dark"] #siteLocationCard .sec-hdr{background:linear-gradient(90deg,#0a1628,#0f2d4a)!important;}
/* Dark mode: R001 rain rate panel */
[data-theme="dark"] #cb-r001-row{background:#0c2a3a;border-color:#22d3ee;}
[data-theme="dark"] #cb-r001{color:#22d3ee !important;}
[data-theme="dark"] #cb-zone{color:#67e8f9 !important;background:#0c4a6e;}
/* Dark mode: loc dropdown */
[data-theme="dark"] .loc-dropdown{background:var(--sl);border-color:var(--border);}
[data-theme="dark"] .loc-opt{color:var(--text);border-color:var(--border);}
[data-theme="dark"] .loc-opt:hover{background:var(--card-bg);}
/* Dark mode: chart notes */
[data-theme="dark"] .chart-note{color:var(--text3);}
/* Dark mode: table row hover and selected */
[data-theme="dark"] tbody tr:hover{background:#1e3a5f !important;color:var(--text);}
[data-theme="dark"] tbody tr.sel{background:#1e3a5f !important;border-left:3px solid #60a5fa !important;}
[data-theme="dark"] tbody tr.sel td{color:var(--text) !important;}
[data-theme="dark"] tbody tr.sel td:first-child{color:#60a5fa !important;font-weight:700;}
/* Dark mode: table header always dark navy */
[data-theme="dark"] thead tr{background:#0a1628 !important;color:#e2e8f0 !important;}
[data-theme="dark"] th.cap-hdr{background:#0c4a6e !important;color:#7dd3fc !important;}
/* Dark mode inputs and selects */
[data-theme="dark"] input[type=number],
[data-theme="dark"] select{background:var(--sl);color:var(--text);border-color:var(--border);}
/* Dark mode table rows */
[data-theme="dark"] .brow:nth-child(even){background:var(--sl);}
[data-theme="dark"] .brow{background:var(--card-bg);}
[data-theme="dark"] tr:nth-child(even){background:var(--sl);}
[data-theme="dark"] tbody td{color:var(--text);}
[data-theme="dark"] tbody tr{border-color:var(--border);}
body{font-family:'Inter',sans-serif;font-size:13px;color:var(--text);
  background:linear-gradient(135deg,#f0f6ff 0%,#f8fafc 60%,#f0f4f8 100%);min-height:100vh}
.hdr{background:linear-gradient(135deg,var(--navy) 0%,var(--navy2) 60%,var(--navy3) 100%);
  color:#fff;padding:12px 24px;display:flex;justify-content:space-between;align-items:center;
  box-shadow:0 2px 12px rgba(15,45,74,.25);gap:12px;flex-wrap:wrap}
.hdr-title{font-size:17px;font-weight:600;letter-spacing:-.02em}
.hdr-sub{font-size:10px;color:#93c5fd;margin-top:3px;letter-spacing:.04em}
.hdr-right{display:flex;align-items:center;gap:10px}
.band-badge{padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;border:1.5px solid}
.band-w{background:rgba(37,99,235,.18);border-color:#60a5fa;color:#93c5fd}
.band-d{background:rgba(16,185,129,.15);border-color:#34d399;color:#6ee7b7}
.band-e{background:rgba(168,85,247,.18);border-color:#c084fc;color:#e9d5ff}
.export-btn{display:flex;align-items:center;gap:5px;padding:7px 13px;border-radius:7px;
  background:linear-gradient(135deg,#059669,#047857);color:#fff;border:none;cursor:pointer;
  font-size:11.5px;font-weight:600;transition:all .15s;white-space:nowrap}
.export-btn:hover{background:linear-gradient(135deg,#047857,#065f46);box-shadow:0 3px 8px rgba(0,0,0,.2)}
#helpBtn:hover{background:rgba(255,255,255,.22)}
/* ── Help modal ── */
.help-overlay{position:fixed;inset:0;background:rgba(15,23,42,.55);backdrop-filter:blur(2px);
  z-index:2000;display:none;align-items:flex-start;justify-content:center;padding:40px 16px;overflow-y:auto}
.help-overlay.open{display:flex}
.help-modal{background:var(--card-bg);color:var(--text);width:100%;max-width:920px;border-radius:14px;
  box-shadow:0 20px 60px rgba(0,0,0,.35);border:1px solid var(--border-l);display:flex;flex-direction:column;
  max-height:calc(100vh - 80px);overflow:hidden;animation:helpIn .18s ease}
@keyframes helpIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
.help-hdr{background:linear-gradient(135deg,var(--navy),var(--navy2),var(--navy3));color:#fff;
  padding:16px 22px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0}
.help-hdr-title{font-size:16px;font-weight:600;letter-spacing:-.01em;display:flex;align-items:center;gap:9px}
.help-hdr-title .hh-sub{font-size:10.5px;color:#93c5fd;font-weight:400;letter-spacing:.04em}
.help-close{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);color:#e2e8f0;
  width:30px;height:30px;border-radius:8px;cursor:pointer;font-size:17px;line-height:1;display:flex;
  align-items:center;justify-content:center;transition:background .15s}
.help-close:hover{background:rgba(255,255,255,.25)}
.help-toc{flex-shrink:0;display:flex;flex-wrap:wrap;gap:6px;padding:12px 22px;border-bottom:1px solid var(--border-l);
  background:var(--sll)}
.help-toc a{font-size:11px;font-weight:600;color:var(--blue);background:var(--blue-l);border:1px solid var(--blue-m);
  padding:4px 10px;border-radius:20px;text-decoration:none;transition:all .12s}
.help-toc a:hover{background:var(--blue);color:#fff}
.help-body{padding:8px 24px 26px;overflow-y:auto;line-height:1.6;font-size:13px;color:var(--text2);text-align:left}
.help-body p,.help-body ul,.help-body li,.help-body h3{text-align:left}
.help-body .help-deftable th,.help-body .help-deftable td{text-align:left}
.help-body h3{font-size:14px;font-weight:600;color:var(--navy2);margin:22px 0 8px;padding-bottom:6px;
  border-bottom:2px solid var(--border-l);display:flex;align-items:center;gap:8px;scroll-margin-top:8px}
[data-theme="dark"] .help-body h3{color:#e2e8f0}
.help-body p{margin:6px 0}
.help-body ul{margin:6px 0 6px 2px;padding-left:18px}
.help-body li{margin:5px 0}
.help-body code{background:var(--sl);border:1px solid var(--border-l);border-radius:4px;padding:1px 5px;
  font-family:'JetBrains Mono',monospace;font-size:11.5px;color:var(--text)}
.help-body strong{color:var(--text)}
.help-deftable{width:100%;border-collapse:collapse;margin:8px 0;font-size:12px}
.help-deftable th{text-align:left;background:var(--sl);color:var(--navy2);font-weight:600;padding:6px 10px;
  border:1px solid var(--border-l);font-size:11px;text-transform:uppercase;letter-spacing:.03em}
[data-theme="dark"] .help-deftable th{color:#e2e8f0}
.help-deftable td{padding:6px 10px;border:1px solid var(--border-l);vertical-align:top;color:var(--text2)}
.help-deftable td:first-child{font-weight:600;color:var(--text);white-space:nowrap}
.help-note{background:var(--blue-l);border:1px solid var(--blue-m);border-radius:8px;padding:10px 14px;
  margin:10px 0;font-size:12px;color:var(--text2)}
.help-tip{background:var(--green-l);border:1px solid var(--green);border-radius:8px;padding:10px 14px;
  margin:10px 0;font-size:12px;color:var(--text2)}
.help-foot{flex-shrink:0;border-top:1px solid var(--border-l);padding:10px 22px;font-size:10.5px;
  color:var(--text3);text-align:center;background:var(--sll)}
mark.help-hl{background:#fde68a;color:#78350f;border-radius:2px;padding:0 1px}
.wrap{max-width:1380px;margin:0 auto;padding:16px;display:flex;gap:16px;align-items:flex-start}
.inp-panel{background:var(--bg);width:232px;min-width:232px;display:flex;flex-direction:column;gap:10px}
.card{background:var(--card-bg);border:1px solid var(--border-l);border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.card-hdr{background:linear-gradient(90deg,var(--sl),var(--sll));padding:8px 14px;font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--navy2);border-bottom:1px solid var(--border-l);display:flex;align-items:center;gap:7px}
.card-body{padding:12px 14px}
.fld{margin-bottom:10px}.fld:last-child{margin-bottom:0}
.lbl{font-size:10.5px;font-weight:500;color:var(--text3);letter-spacing:.05em;text-transform:uppercase;margin-bottom:4px}
input[type=number],select{width:100%;background:var(--card-bg);color:var(--text);border:1px solid var(--border);border-radius:6px;padding:6px 9px;font-size:12.5px;color:var(--text);background:var(--white);font-family:'Inter',sans-serif;outline:none;transition:border-color .15s}
input[type=number]:focus,select:focus{border-color:var(--blue)}
.pol-row{display:flex;gap:6px}
.pol-btn{flex:1;padding:6px;border-radius:6px;border:1.5px solid var(--border);cursor:pointer;font-size:12px;font-weight:600;text-align:center;transition:all .15s;background:var(--white);color:var(--text3)}
.pol-btn.active{background:var(--blue-l);border-color:var(--blue);color:var(--blue)}
.cfg-row{display:flex;gap:6px}
.cfg-btn{flex:1;padding:7px 4px;border-radius:6px;border:1.5px solid var(--border);cursor:pointer;font-size:11px;font-weight:600;text-align:center;transition:all .15s;background:var(--white);color:var(--text3);line-height:1.3}
.cfg-btn.active{background:#fef3c7;border-color:#d97706;color:#92400e}
.cfg-badge{font-size:9px;font-weight:400;display:block;margin-top:1px;opacity:.8}
.c-row{display:flex;gap:5px;margin-bottom:6px}
.c-btn{flex:1;padding:4px 2px;border-radius:5px;border:1px solid var(--border);cursor:pointer;font-size:9.5px;font-weight:600;text-align:center;background:var(--white);color:var(--text3);transition:all .15s}
.c-btn.active{background:var(--blue-l);border-color:var(--blue);color:var(--blue)}
.hint{font-size:10px;color:var(--text3);margin-top:3px}
[data-theme="dark"] .hint{color:var(--text2)}
/* ===== RANGE SWEEP REPORT ===== */
.rr-wrap{border:1px solid var(--border-l);border-radius:12px;overflow:hidden;margin-top:14px;background:var(--card-bg)}
.rr-hdr{background:linear-gradient(90deg,var(--navy),var(--navy2));padding:9px 16px;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap}
.rr-hdr-title{color:#e2e8f0;font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase}
.rr-body{padding:14px 16px}
.rr-inputs{display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end;margin-bottom:10px}
.rr-field{display:flex;flex-direction:column;gap:3px}
.rr-field label{font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.05em}
.rr-field input{width:90px;padding:6px 8px;border:1px solid var(--border);border-radius:6px;background:var(--white);color:var(--text);font-size:12px;font-weight:500}
.rr-go-btn{padding:7px 16px;background:var(--navy);color:#e2e8f0;border:none;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;letter-spacing:.04em;transition:all .15s;white-space:nowrap;align-self:flex-end}
.rr-go-btn:hover{background:#1d4ed8}
.rr-xl-btn{padding:7px 13px;background:#064e3b;color:#6ee7b7;border:1px solid #065f46;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;letter-spacing:.03em;transition:all .15s;white-space:nowrap;align-self:flex-end}
.rr-xl-btn:hover{background:#065f46}
[data-theme="dark"] .rr-go-btn{background:#1e3a5f;color:#e2e8f0}[data-theme="dark"] .rr-go-btn:hover{background:#1d4ed8}
.rr-status{font-size:10px;color:var(--text3);margin-bottom:8px;min-height:14px}
.rr-table-wrap{overflow:auto;max-height:540px;border:1px solid var(--border-l);border-radius:8px}
.rr-tbl{border-collapse:collapse;width:100%;font-size:11px}
.rr-tbl th{background:var(--navy);color:#e2efff;padding:7px 10px;white-space:nowrap;text-align:center;font-size:10px;font-weight:700;letter-spacing:.03em;text-transform:none;position:sticky;top:0;z-index:2}
.rr-tbl th.rr-thl{text-align:left}
.rr-tbl td{padding:5px 9px;border:1px solid rgba(0,0,0,.07);white-space:nowrap;font-weight:600;font-size:11px;text-align:right}
[data-theme="dark"] .rr-tbl td{border-color:rgba(255,255,255,.05)}
.rr-tbl tr:hover td{filter:brightness(1.07)}
.rr-td-d{text-align:center!important;background:var(--sl)!important;color:var(--text)!important;font-weight:700!important}
.rr-td-r{background:var(--sll)!important;color:var(--text2)!important;text-align:center!important}
.dist-row{display:flex;gap:6px;align-items:stretch}
.dist-row input{flex:1}
.max-btn{white-space:nowrap;padding:0 10px;background:var(--navy);color:#e2e8f0;border:none;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;transition:background .15s}
.max-btn:hover{background:var(--navy2)}
.max-panel{background:var(--sll);border:1px solid var(--border-l);border-radius:8px;margin-top:8px;overflow:hidden;display:none}
.max-panel.visible{display:block}
.max-panel-hdr{background:var(--navy);color:#e2e8f0;padding:6px 10px;font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;display:flex;justify-content:space-between;align-items:center}
.max-panel-hdr button{background:none;border:none;color:#93c5fd;cursor:pointer;font-size:14px}
.max-tbl{width:100%;border-collapse:collapse;font-size:12px}
.max-tbl td{padding:8px 12px;font-size:13px;font-weight:500;border-bottom:1px solid var(--border-l)}
.max-tbl tr:last-child td{border-bottom:none}
.max-tbl .mn{font-family:'JetBrains Mono',monospace;font-weight:500;text-align:right}
.res-panel{background:var(--bg);flex:1;display:flex;flex-direction:column;gap:12px}
.budget-grid{display:grid;grid-template-columns:repeat(3,1fr)}
.bg-col{padding:14px 16px}.bg-col+.bg-col{border-left:1px solid var(--border-l)}
.bg-col-title{font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid;display:inline-block}
.bc-path{color:var(--blue);border-color:var(--blue-m)}
.bc-link{color:#7c3aed;border-color:#c4b5fd}
.bc-avail{color:var(--green);border-color:#6ee7b7}
.brow{background:var(--card-bg);display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid var(--border-l)}
.brow:last-child{border-bottom:none}
.brow-l{color:var(--text3);font-size:11.5px}
.brow-v{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:500;color:var(--text)}
.brow-v.hl{color:var(--green);font-weight:600}
.brow-v.cap{color:#0891b2;font-weight:600}.brow-v.warn{color:var(--amber);font-weight:600}
.brow-v.err{color:var(--red);font-weight:600}.brow-v.td-dim{color:var(--text3);font-size:12.5px}
.brow-v.cap{color:var(--teal-d);font-weight:600}
.status-box{border-radius:8px;padding:10px;text-align:center;margin-top:10px;border:1.5px solid}
.status-ok{background:var(--green-l);border-color:var(--green);color:var(--green-d)}
.status-fail{background:var(--red-l);border-color:var(--red);color:var(--red)}
.status-num{font-size:17px;font-weight:600;font-family:'JetBrains Mono',monospace}
.status-lbl{font-size:10px;margin-top:2px;font-weight:500}
.bar-wrap{margin-top:8px}.bar-lbl{font-size:10px;color:var(--text3);margin-bottom:3px}
.bar-track{background:var(--border-l);border-radius:4px;height:6px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;transition:width .3s,background .3s}
.sec-hdr{background:linear-gradient(90deg,var(--navy),var(--navy2));padding:9px 16px;display:flex;justify-content:space-between;align-items:center;border-radius:12px 12px 0 0}
.sec-hdr-title{color:#e2e8f0;font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase}
.sec-hdr select{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#e2e8f0;border-radius:5px;padding:3px 8px;font-size:11.5px;cursor:pointer}
.sec-hdr select option{background:var(--navy);color:#e2e8f0}
.sec-hdr label{color:#93c5fd;font-size:10px;white-space:nowrap}
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
thead tr{background:var(--navy);color:#e2e8f0}
th{padding:9px 10px;font-size:10px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;text-align:right;white-space:nowrap}
.u{text-transform:none}
th:first-child{text-align:left}
td:first-child{font-size:13.5px;font-weight:700;text-align:left}
th.cap-hdr{background:var(--teal-d,#155e75);color:var(--teal-l,#cffafe)}
tbody tr{border-bottom:1px solid var(--border-l);cursor:pointer;transition:background .12s}
tbody tr:nth-child(even){background:var(--sll)}
tbody tr:hover{background:#eff6ff}
tbody tr.sel{background:#dbeafe;border-left:3px solid var(--blue);color:#0f172a}
tbody tr.sel td:first-child{padding-left:7px}
td{padding:7px 9px;text-align:right;font-family:'JetBrains Mono',monospace;font-size:11px;color:#475569}
td:first-child{text-align:left;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--text)}
td.cap-cell{background:var(--teal-l);color:var(--teal-d);font-size:13px;font-weight:700}
.pill{display:inline-block;padding:2px 7px;border-radius:5px;font-size:10px;font-weight:600;border:1px solid}
.pill-ok{background:var(--green-l);color:var(--green-d);border-color:var(--green)}
.pill-warn{background:var(--amber-l);color:#92400e;border-color:var(--amber)}
.pill-fail{background:var(--red-l);color:#991b1b;border-color:var(--red)}
.avail-ok{color:var(--green-d);font-weight:600}.avail-warn{color:#92400e;font-weight:600}.avail-fail{color:#991b1b;font-weight:600}
.td-pos{color:var(--green-d);font-size:13px;font-weight:600}.td-neg{color:var(--red);font-size:13px;font-weight:600}.td-warn{color:#92400e;font-size:13px;font-weight:600}.td-dim{color:#94a3b8}
.chart-card{background:var(--card-bg);border:1px solid var(--border-l);border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.chart-hdr{background:linear-gradient(90deg,var(--navy),var(--navy2));padding:9px 16px;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap}
.chart-hdr-title{color:#e2e8f0;font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase}
.chart-controls{display:flex;gap:8px;align-items:center}
.chart-controls select{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);color:#e2e8f0;border-radius:5px;padding:3px 7px;font-size:11px;cursor:pointer}
.chart-controls select option{background:#1e293b;color:#e2e8f0;}
.chart-controls select option{background:var(--navy);color:#e2e8f0}
.chart-controls label{color:#93c5fd;font-size:10.5px;white-space:nowrap}
.chart-body{padding:16px 20px 10px}
.chart-canvas-wrap{position:relative;height:320px}
.chart-note{font-size:10px;color:var(--text3);margin-top:8px;text-align:center}
.spin-sm{display:inline-block;width:11px;height:11px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite}
.acm-row{display:flex;gap:6px}
.acm-btn{flex:1;padding:7px 4px;border-radius:6px;border:1.5px solid var(--border);cursor:pointer;
  font-size:11px;font-weight:600;text-align:center;transition:all .15s;background:var(--white);color:var(--text3);line-height:1.3}
.acm-btn.active{background:#fef9c3;border-color:#ca8a04;color:#713f12}
.acm-btn.disabled-btn{opacity:.4;cursor:not-allowed}
.acm-badge{font-size:9px;font-weight:400;display:block;margin-top:1px;opacity:.8}
@keyframes spin{to{transform:rotate(360deg)}}
.footer{text-align:center;padding:12px;font-size:10px;color:var(--text3);letter-spacing:.03em}
/* capacity badge in link budget */
.cap-badge{display:inline-block;background:var(--teal-l);color:var(--teal-d);border:1px solid #67e8f9;border-radius:6px;padding:6px 10px;text-align:center;margin-top:8px;width:100%}
.cap-badge-num{font-size:15px;font-weight:600;font-family:'JetBrains Mono',monospace}
.cap-badge-lbl{font-size:10px;margin-top:1px}

#siteMap{height:380px;border-radius:8px;border:1px solid var(--border-l);overflow:hidden;margin-top:10px;position:relative;z-index:0}
.climate-badge{background:linear-gradient(135deg,#f0fdf4,#ecfdf5);border:1px solid #6ee7b7;border-radius:8px;padding:8px 10px;margin-top:8px;display:none}
.climate-badge.visible{display:block}
.cb-row{display:flex;justify-content:space-between;align-items:center;padding:3px 0;border-bottom:1px solid #d1fae5;font-size:11px}
.cb-row:last-child{border-bottom:none}
.cb-lbl{color:var(--text3)}.cb-val{font-family:"JetBrains Mono",monospace;font-weight:600;color:var(--green-d);text-align:right}
.apply-btn{width:100%;margin-top:7px;padding:6px;background:var(--green);color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:11.5px;font-weight:600}
.apply-btn:hover{background:var(--green-d)}
.loc-search-wrap{position:relative}
.loc-dropdown{position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid var(--border);border-radius:0 0 6px 6px;z-index:9999;max-height:170px;overflow-y:auto;display:none;box-shadow:0 4px 12px rgba(0,0,0,.12)}
.loc-dropdown.open{display:block}
.loc-opt{padding:6px 10px;font-size:11.5px;cursor:pointer;border-bottom:1px solid var(--border-l)}
.loc-opt:hover{background:var(--blue-l)}.loc-opt:last-child{border-bottom:none}
.coord-row{display:flex;gap:6px}.coord-row input{flex:1;font-size:11.5px}
.fetch-btn{width:100%;margin-top:6px;padding:7px;background:var(--navy);color:#e2e8f0;border:none;border-radius:6px;cursor:pointer;font-size:11.5px;font-weight:600;display:flex;align-items:center;justify-content:center;gap:6px}
.fetch-btn:hover{background:var(--navy2)}
.atm-mode-note{font-size:9.5px;color:var(--text3);margin-top:5px;text-align:center}

/* ── Map button tooltips ── */
.map-btn-wrap{position:relative;display:inline-block;}
.map-btn-wrap .map-tooltip{
  visibility:hidden;opacity:0;
  position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);
  background:#0f2d4a;color:#e2e8f0;
  font-size:10px;line-height:1.5;white-space:nowrap;
  padding:6px 10px;border-radius:6px;
  box-shadow:0 2px 8px rgba(0,0,0,.35);
  pointer-events:none;
  transition:opacity .15s;z-index:9999;
  text-align:left;
}
.map-btn-wrap .map-tooltip strong{display:block;color:#93c5fd;margin-bottom:2px;}
.map-btn-wrap .map-tooltip::after{
  content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);
  border:5px solid transparent;border-top-color:#0f2d4a;
}
.map-btn-wrap:hover .map-tooltip{visibility:visible;opacity:1;}
[data-theme="dark"] .map-btn-wrap .map-tooltip{background:#1e293b;border:1px solid #334155;}
[data-theme="dark"] .map-btn-wrap .map-tooltip::after{border-top-color:#1e293b;}
/* User-configured field highlight */
input.user-set, select.user-set {
  background-color:#FFF8DC !important;
  border-color:#F59E0B !important;
  box-shadow:0 0 0 2px rgba(245,158,11,.18) !important;
  color:#1a1a1a !important;
}
[data-theme="dark"] input.user-set,[data-theme="dark"] select.user-set{
  background-color:#3d2e00 !important;
  border-color:#F59E0B !important;
  color:#fef3c7 !important;
}
.clear-hl-btn{display:flex;align-items:center;gap:5px;padding:7px 12px;border-radius:7px;
  background:rgba(245,158,11,.65);border:1px solid rgba(245,158,11,.85);color:#fff;
  font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;white-space:nowrap;}
.clear-hl-btn:hover{background:rgba(245,158,11,.85);border-color:#F59E0B;}
[data-theme="dark"] .clear-hl-btn{background:rgba(245,158,11,.55);border-color:rgba(245,158,11,.75);color:#fff;}
[data-theme="dark"] .clear-hl-btn:hover{background:rgba(245,158,11,.75);}
</style>
</head>
<body>
<div class="hdr">
  <div>
    <div style="display:flex;align-items:center;gap:12px">
      <div style="background:#fff;border-radius:8px;padding:4px 10px;display:flex;align-items:center">
        <img src="data:image/png;base64," alt="Ceragon" style="height:26px;display:block">
      </div>
      <div style="width:1px;height:30px;background:rgba(255,255,255,.2)"></div>
      <div class="hdr-title">&#128225; Ceragon Link Budget Calculator <span style="font-size:11px;font-weight:400;color:#93c5fd;letter-spacing:.04em">v6.8</span></div>
    </div>
    <div class="hdr-sub">ITU-R P.530-17 (multipath) &nbsp;&middot;&nbsp; P.530-18 (rain path reduction) &nbsp;&middot;&nbsp; P.838-3 &nbsp;&middot;&nbsp; P.676-12 &nbsp;|&nbsp; Ceragon Planning tool &copy;</div>
  </div>
  <div class="hdr-right">
    <button id="helpBtn" onclick="openHelp()" title="How to use this tool (help &amp; methodology)"
      style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);
      color:#e2e8f0;padding:5px 12px;border-radius:20px;cursor:pointer;font-size:12px;
      font-weight:500;display:flex;align-items:center;gap:6px;transition:background .2s">
      <span style="font-weight:700">&#63;</span>
      <span>Help</span>
    </button>
    <button id="themeToggle" onclick="toggleTheme()" title="Toggle dark/light mode"
      style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);
      color:#e2e8f0;padding:5px 12px;border-radius:20px;cursor:pointer;font-size:12px;
      font-weight:500;display:flex;align-items:center;gap:6px;transition:background .2s">
      <span id="themeIcon">&#9790;</span>
      <span id="themeLabel">Dark</span>
    </button>
    <div>
      <div id="bandBadge" class="band-badge band-w">W-Band &nbsp; 80 GHz</div>
      <div id="hdrSub2" style="color:#93c5fd;font-size:10px;margin-top:4px;text-align:right">2000 MHz &nbsp;&middot;&nbsp; V Pol</div>
    </div>
    <button class="export-btn" onclick="exportToExcel()">&#128190; Export to Excel</button>
    <button class="clear-hl-btn" onclick="clearUserSet()" title="Remove amber highlights from all configured fields">&#10006; Clear highlights</button>
  </div>
</div>

<div class="wrap">
<div class="inp-panel">
  <div class="card">
    <div class="card-hdr">&#128251; Radio</div>
    <div class="card-body">
      <div class="fld">
        <div class="lbl" title="Select the frequency band: Microwave (4–42 GHz), E-Band (71–86 GHz), W-Band (80 GHz), or D-Band (140 GHz)">Band</div>
        <select id="bandSel" onchange="onBandChange()" title="Select the frequency band: Microwave (4–42 GHz), E-Band (71–86 GHz), W-Band (80 GHz), or D-Band (140 GHz)">
          <option value="MW" selected>Microwave Band</option>
          <option value="E">E-Band</option>
          <option value="W">W-Band</option>
          <option value="D">D-Band</option>
        </select>
      </div>
      <div class="fld" id="mwProductFld" style="display:none">
        <div class="lbl" title="Ceragon microwave product. Each product defines TX power, RSL thresholds and DFM tables.">Product</div>
        <select id="mwProduct" onchange="onMwProductChange()" title="Ceragon microwave product. Each product defines TX power, RSL thresholds and DFM tables.">
          <option value="IP-20C">IP-20C</option>
          <option value="IP-20C-HP">IP-20C-HP</option>
          <option value="IP-50C">IP-50C</option>
          <option value="IP-50CX">IP-50CX</option>
          <option value="RFU-D">RFU-D</option>
          <option value="RFU-D-HP">RFU-D-HP</option>
        </select>
      </div>
      <div class="fld" id="ePowerFld">
        <div class="lbl" title="IP-50EX(A) is the standard power variant; IP-50EX(A)-P is the high-power variant with improved link budget.">Product</div>
        <select id="ePower" onchange="onEPowerChange()" title="IP-50EX(A) is the standard power variant; IP-50EX(A)-P is the high-power variant with improved link budget.">
          <option value="std" selected>IP-50EX(A)</option>
          <option value="hi">IP-50EX(A)-P</option>
        </select>
      </div>
      <div class="fld">
        <div class="lbl" title="Regulatory standard: ETSI (European/ITU-R) or FCC (North American). Affects antenna gain and channel plan tables.">Standard</div>
        <select id="stdSel" onchange="onStdChange()" title="Regulatory standard: ETSI (European/ITU-R) or FCC (North American). Affects antenna gain and channel plan tables.">
          <option value="ETSI" selected>ETSI</option>
          <option value="FCC">FCC</option>
        </select>
      </div>
      <div class="fld" id="freqFld">
        <div class="lbl" title="Operating TX frequency in GHz within the selected band. Affects free-space loss, rain attenuation, and atmospheric loss.">Frequency (GHz)</div>
        <input type="number" id="freq" min="71" max="86" step="1" value="80" title="Operating TX frequency in GHz. Higher frequency = greater rain attenuation and atmospheric loss.">
        <div class="hint" id="freqHint">E-Band: 71 – 86 GHz</div>
      </div>
      <div class="fld" id="mwFreqFld" style="display:none">
        <div class="lbl" title="ITU-R frequency band plan for the selected MW band. Determines available TX frequencies and channel spacing.">Frequency Band</div>
        <select id="mwBandSel" onchange="onMwBandSelChange()" title="ITU-R frequency band plan. Determines available TX frequencies and channel spacing."></select>
        <div class="hint" id="mwFreqHint"></div>
        <div class="lbl" style="margin-top:7px" title="TX frequency in GHz. Use arrows to step through ITU-R preset frequencies for the selected band plan.">TX Frequency (GHz)</div>
        <div style="display:flex;gap:5px;align-items:center">
          <button id="mwFreqDown" onclick="stepMwFreq(-1)" title="Previous preset frequency"
            style="width:28px;height:28px;border:1.5px solid var(--border);border-radius:6px;
            background:var(--sl);color:var(--text2);cursor:pointer;font-size:14px;font-weight:700;
            display:flex;align-items:center;justify-content:center;flex-shrink:0;line-height:1">&#9664;</button>
          <input type="number" id="mwFreq" min="3.6" max="43.45" step="0.001" placeholder="GHz"
            style="font-family:'JetBrains Mono',monospace;text-align:center;flex:1" oninput="onMwFreqInput()"
            title="TX frequency in GHz. Type a value or use the arrows to step through ITU-R preset frequencies.">
          <button id="mwFreqUp" onclick="stepMwFreq(+1)" title="Next preset frequency"
            style="width:28px;height:28px;border:1.5px solid var(--border);border-radius:6px;
            background:var(--sl);color:var(--text2);cursor:pointer;font-size:14px;font-weight:700;
            display:flex;align-items:center;justify-content:center;flex-shrink:0;line-height:1">&#9654;</button>
        </div>
        <div id="mwFreqPresetHint" style="font-size:10px;color:var(--text3);margin-top:3px;text-align:center"></div>
      </div>
      <div class="fld"><div class="lbl" title="Channel bandwidth in MHz. Wider bandwidth = higher capacity but greater susceptibility to rain attenuation.">Bandwidth (MHz)</div>
        <select id="bw" title="Channel bandwidth. Wider BW = higher Mbps throughput but higher rain attenuation (A₀.₀₁ scales with bandwidth)."><option value="250">250 MHz</option><option value="500">500 MHz</option><option value="1000">1000 MHz</option><option value="2000" selected>2000 MHz</option></select>
      </div>
      <div class="fld">
        <div class="lbl" title="Link configuration: 1+0 = single path (one TX, one RX). 2+0 = co-polar dual path, doubles capacity (no protection).">Configuration</div>
        <select id="cfgSelect" onchange="setConfig(this.value)" title="1+0 = single path. 2+0 = co-polar dual path, doubles Mbps throughput with no protection switching.">
          <option value="1+0" selected>1+0</option>
          <option value="2+0">2+0</option>
        </select>
      </div>
      <div class="fld">
        <div class="lbl" title="Typical = nominal published sensitivity. Guaranteed = worst-case factory spec (adds +2 dB offset to RSL threshold).">RSL Performance Level</div>
        <select id="rslTypical" onchange="onRslModeChange()" title="Typical = nominal sensitivity. Guaranteed = worst-case spec (+2 dB offset). Use Guaranteed for conservative planning.">
          <option value="typ" selected>Typical</option>
          <option value="gty">Guaranteed</option>
        </select>
      </div>
      <div class="fld">
        <div class="lbl" title="BER point for RSL threshold. BER 10⁻⁶ = standard ITU-R objective. BER 10⁻³ = relaxed (0.5 dB lower threshold, used for ATPC reference).">RSL BER Threshold</div>
        <select id="rslBer" onchange="onRslModeChange()" title="BER 10⁻⁶ = standard RSL threshold. BER 10⁻³ = 0.5 dB lower, used as ATPC minimum or relaxed availability reference.">
          <option value="e6" selected>BER 10&#x207b;&#x2076;</option>
          <option value="e3">BER 10&#x207b;&#x00b3;</option>
        </select>

      </div>
      <div class="fld">
        <div class="lbl" title="ACM: link automatically shifts to a lower modulation during fades to maintain connectivity. ACMB extends ACM range further.">ACM &amp; ACMB</div>
        <div style="display:flex;gap:16px;align-items:center;padding:4px 0">
          <div style="display:flex;align-items:center;gap:8px">
            <label class="toggle-switch" id="acmSwitch" title="Adaptive Coding & Modulation: automatically shifts modulation during fades. Enables minimum-modulation RSL thresholds.">
              <input type="checkbox" id="acmChk" onchange="setACM(this.checked)">
              <span class="toggle-slider"></span>
            </label>
            <span style="font-size:12px;font-weight:600;color:var(--text2)" title="Adaptive Coding & Modulation: automatically steps down modulation to maintain link during rain/multipath events.">ACM</span>
          </div>
          <div style="width:1px;height:20px;background:var(--border-l)"></div>
          <div style="display:flex;align-items:center;gap:8px">
            <label class="toggle-switch disabled-sw" id="acmbSwitch" title="ACM Boost: extends ACM down to the lowest available modulations (requires ACM enabled). Maximises link resilience.">
              <input type="checkbox" id="acmbChk" onchange="setACMB(this.checked)">
              <span class="toggle-slider"></span>
            </label>
            <span style="font-size:12px;font-weight:600;color:var(--text2)" title="ACM Boost: extends ACM range to lowest modulations for maximum resilience. Requires ACM to be enabled.">ACMB</span>
          </div>
        </div>
      </div>
      <div class="fld"><div class="lbl" title="Antenna polarization. H and V use different ITU-R P.838-3 rain attenuation coefficients k and α. V-pol has slightly higher attenuation at lower frequencies.">Polarization</div>
        <div class="pol-row">
          <button class="pol-btn" id="polH" onclick="setPol('H')" title="Horizontal polarization. Uses ITU-R P.838-3 kH and αH coefficients for rain attenuation.">H Pol</button>
          <button class="pol-btn active" id="polV" onclick="setPol('V')" title="Vertical polarization. Uses ITU-R P.838-3 kV and αV coefficients for rain attenuation.">V Pol</button>
        </div>
      </div>
      <div class="fld"><div class="lbl" title="Ethernet frame size for capacity calculation. 'Radio (aggregate)' shows raw modulation throughput. Smaller frames = lower efficiency due to header overhead.">Capacity Frame Size</div>
        <select id="frameSize" onchange="state.frameIdx=this.selectedIndex;render();" title="Frame size for Ethernet throughput calculation. Smaller frames have higher header overhead, reducing net throughput.">
          <option value="0" selected>Radio (aggregate)</option>
          <option value="1">64 bytes</option>
          <option value="2">128 bytes</option>
          <option value="3">256 bytes</option>
          <option value="4">512 bytes</option>
          <option value="5">1024 bytes</option>
          <option value="6">1518 bytes (std)</option>
          <option value="7">9612 bytes (jumbo)</option>
        </select>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-hdr">&#128301; Antennas</div>
    <div class="card-body">
      <!-- Site A antenna + mount -->
      <div class="fld"><div class="lbl" id="lblA" title="Antenna dish diameter at Site A. Larger antenna = higher gain (dBi) = better link budget and longer range.">Site A — Antenna Size</div>
        <select id="antA" onchange="onAntChange('A')" title="Antenna diameter at Site A. Gain scales approximately as 20·log(diameter). Larger = better, but more wind load.">
          <option value="0.2" selected>0.2 m</option>
          <option value="0.3">0.3 m</option>
          <option value="0.31">0.3 m+</option>
          <option value="0.6">0.6 m</option>
          <option value="0.9">0.9 m</option>
        </select>
      </div>
      <div class="fld" id="mountAFld" style="display:none">
        <div class="lbl" title="Direct mount: antenna bolts directly to ODU, minimal loss. Remote mount: uses waveguide/coaxial jumper — adds branching/cable loss.">Site A — Mount</div>
        <select id="mwMountA" onchange="onMwMountChange()" title="Direct mount: ODU on antenna, minimal cable loss. Remote mount: ODU separated from antenna by waveguide, adds branch loss.">
          <option value="direct" selected>Direct mount</option>
          <option value="remote">Remote mount</option>
        </select>
        <div class="hint" id="mountAHint"></div>
      </div>
      <!-- Site B antenna + mount -->
      <div class="fld"><div class="lbl" id="lblB" title="Antenna dish diameter at Site B. Larger antenna = higher gain (dBi) = better link budget and longer range.">Site B — Antenna Size</div>
        <select id="antB" onchange="onAntChange('B')" title="Antenna diameter at Site B. Gain scales approximately as 20·log(diameter). Larger = better, but more wind load.">
          <option value="0.2" selected>0.2 m</option>
          <option value="0.3">0.3 m</option>
          <option value="0.31">0.3 m+</option>
          <option value="0.6">0.6 m</option>
          <option value="0.9">0.9 m</option>
        </select>
      </div>
      <div class="fld" id="mountBFld" style="display:none">
        <div class="lbl" title="Direct mount: antenna bolts directly to ODU, minimal loss. Remote mount: uses waveguide/coaxial jumper — adds branching/cable loss.">Site B — Mount</div>
        <select id="mwMountB" onchange="onMwMountChange()" title="Direct mount: ODU on antenna, minimal cable loss. Remote mount: ODU separated from antenna by waveguide, adds branch loss.">
          <option value="direct" selected>Direct mount</option>
          <option value="remote">Remote mount</option>
        </select>
        <div class="hint" id="mountBHint"></div>
      </div>
    </div>
  </div>
  <div class="card" id="mwRelCard" style="display:none">
    <div class="card-hdr">&#128225; Microwave Link Settings</div>
    <div class="card-body">
      <div class="fld">
        <div class="lbl" title="Additional system losses not already accounted for (connectors, jumpers, diplexer offset, etc.). Positive = loss, negative = gain.">Miscellaneous Loss <span class="u">(dB)</span></div>
        <input type="number" id="miscLoss" min="-10" max="20" step="0.5" value="0" onchange="onMiscLossChange()" title="Extra system loss in dB. Positive value adds to path loss (e.g. 1 dB connector loss). Negative for miscellaneous gain.">
      </div>
      <div class="fld">
        <div class="lbl" title="Multipath fading model for outage calculation. Vigants-Barnett (North America), ITU-R P.530-7/8 (older), ITU-R P.530-17 (current standard, d³·⁶ exponent).">Reliability Method</div>
        <select id="relMethod" onchange="onRelMethodChange()" title="Multipath outage model: Vigants-Barnett uses C factor; P.530-7/8 uses geoclimatic K (d³); P.530-17 uses K (d³·⁶, more conservative for long paths).">
          <option value="VB">Vigants-Barnett</option>
          <option value="P530-78">ITU-R P.530-7/8</option>
          <option value="P530-17" selected>ITU-R P.530-17</option>
        </select>
      </div>
      <!-- VB-specific: C Factor + terrain roughness -->
      <div id="vbFields" style="display:none">
        <div class="fld">
          <div class="lbl" title="Vigants-Barnett terrain/climate factor. 0.25 = dry/mountainous, 1.0 = average, 4.0 = flat/over-water/coastal. Can also be auto-calculated from map data.">C Factor (climate &amp; terrain)</div>
          <div class="c-row" id="vbCBtns">
            <button class="c-btn" data-cv="0.25" onclick="setVBCFactor(0.25)" title="Mountainous / dry">Mtn</button>
            <button class="c-btn active" data-cv="1" onclick="setVBCFactor(1)" title="Average terrain &amp; climate">Avg</button>
            <button class="c-btn" data-cv="4" onclick="setVBCFactor(4)" title="Over water / gulf coastal">Water</button>
          </div>
          <input type="number" id="vbCFactor" min="0.1" max="6" step="0.05" value="1" onchange="onVBCFactorChange()" title="Vigants-Barnett C factor: 0.25 = dry/mountain, 1.0 = average, 4.0 = flat over-water/coastal. Directly multiplies multipath outage probability.">
          <div class="hint">0.25 mountain/dry · 1.0 average · 4.0 over-water/coastal</div>
        </div>
        <div class="fld">
          <div class="lbl" title="Climate-specific multiplier used when auto-calculating C from terrain roughness. 0.5 = dry/mountain, 1.0 = average temperate, 2.0 = humid/coastal.">Climatic Factor c<sub>f</sub></div>
          <div class="c-row" id="vbCfBtns">
            <button class="c-btn" data-cf="0.5" onclick="setVBCf(0.5)" title="Mountainous / dry climate">Dry</button>
            <button class="c-btn active" data-cf="1" onclick="setVBCf(1)" title="Average temperate climate">Avg</button>
            <button class="c-btn" data-cf="2" onclick="setVBCf(2)" title="Humid / over-water / coastal">Wet</button>
          </div>
          <input type="number" id="vbCf" min="0.1" max="3" step="0.1" value="1" onchange="onVBCfChange()" title="Climate factor for auto-C calculation: 0.5 = dry/mountain, 1.0 = average temperate, 2.0 = humid/coastal. Used with terrain roughness S.">
          <div class="hint">0.5 dry/mountain · 1.0 average · 2.0 humid/coastal</div>
        </div>
        <div class="fld">
          <button onclick="autoVBFromMap()" style="width:100%;padding:5px;background:var(--navy);color:#e2e8f0;border:none;border-radius:5px;cursor:pointer;font-size:11px;font-weight:600">
            &#127758; Auto C from map (terrain roughness + climate zone)
          </button>
          <div class="hint" id="vbTerrainHint">Pin sites &amp; load terrain to auto-calculate C</div>
        </div>
      </div>
      <!-- P.530-7/8 and P.530-17: geoclimatic K + inclination -->
      <div id="p530Fields" style="display:none">
        <div class="fld">
          <div class="lbl" title="Path type determines which ITU-R P.530-7/8 formula is used for geoclimatic factor K: Inland (Eq.29), Coastal large water (Eq.30), Coastal medium water (Eq.31).">Path Type</div>
          <select id="p530PathType" onchange="onP530PathTypeChange()" title="Inland uses Eq.29 for K. Coastal paths blend K_inland with K_coastal using over-water fraction r_c (Eq.30 for large, Eq.31 for medium bodies of water).">
            <option value="inland" selected>Inland</option>
            <option value="coastal_large">Coastal / Large body of water</option>
            <option value="coastal_medium">Coastal / Medium body of water</option>
          </select>
          <div class="hint">Inland = Eq.29 · Coastal = Eq.30/31 (ITU-R P.530-7/8)</div>
        </div>
        <!-- Coastal-only field -->
        <div class="fld" id="rcField" style="display:none">
          <div class="lbl" title="Fraction of the path profile traversing below 100 m altitude over open water. 0 = no over-water section, 1 = fully over water.">Over-water fraction r<sub>c</sub></div>
          <input type="number" id="p530Rc" min="0" max="1" step="0.05" value="0.5"
            onchange="onGeoKParamChange()" placeholder="0 – 1"
            title="Fraction of path over open water below 100 m ASL. Used in ITU-R P.530-7/8 Eq.30/31 to blend inland and coastal K values.">
          <div class="hint">Fraction of path profile below 100 m altitude over water<br>0 = no over-water · 1 = fully over water</div>
        </div>
        <div class="fld">
          <div class="lbl" title="Altitude above sea level of the lower of the two antennas. Used to compute geoclimatic C₀ factor in ITU-R P.530-7/8. Auto-filled from terrain data when available.">Lower Antenna Altitude (m ASL)</div>
          <input type="number" id="lowerAntAlt" min="0" max="5000" step="10" value="200"
            onchange="onGeoKParamChange()" placeholder="m above sea level"
            title="Altitude (m ASL) of the lower antenna. Affects geoclimatic C₀ factor in ITU-R P.530-7/8. Pin both sites and load terrain to auto-fill.">
          <div class="hint" id="lowerAntAltHint">Used for geoclimatic C₀ factor — auto-filled from terrain when available</div>
        </div>
        <div class="fld">
          <div class="lbl" title="Terrain classification for geoclimatic factor K. Plains = low roughness, Hills = moderate, Mountains = high roughness. Affects multipath outage probability.">Terrain Type</div>
          <select id="terrainType" onchange="onGeoKParamChange()" title="Terrain category for ITU-R P.530-7/8 geoclimatic K: Plains = flat, low multipath risk; Hills = moderate; Mountains = steep, reduced multipath risk.">
            <option value="plains">Plains</option>
            <option value="hills" selected>Hills</option>
            <option value="mountains">Mountains</option>
          </select>
        </div>
        <div class="fld">
          <div class="lbl" title="ITU-R P.530 geoclimatic factor K captures location-specific multipath fading severity. Typically 10⁻⁵ (low risk) to 10⁻³ (high risk). Auto-calculate from site coordinates using P.453 refractivity maps.">Geoclimatic Factor K</div>
          <input type="text" id="geoK" value="1e-4" style="font-family:monospace"
            onchange="onGeoKChange()" placeholder="e.g. 1e-4"
            title="ITU-R P.530 geoclimatic factor K. Controls multipath outage: higher K = more outage. Typical range 1e-5 (dry/mountains) to 1e-3 (humid/flat). Click button to auto-calculate.">
          <div style="margin-top:4px">
            <button id="geoKBtn" onclick="calcGeoK()" style="width:100%;padding:5px;background:var(--navy);color:#e2e8f0;border:none;border-radius:5px;cursor:pointer;font-size:11px;font-weight:600">
              &#128205; Auto-calculate K from site coordinates
            </button>
          </div>
          <div class="hint" id="geoKHint">Enter coordinates &amp; click button · or type K manually</div>
        </div>
        <div class="fld">
          <div class="lbl" title="Vertical angle (mrad) between the two antenna ends. Higher inclination reduces multipath fading probability. Auto-calculated from site heights and distance.">Path Inclination |ε<sub>p</sub>| (mrad)</div>
          <input type="number" id="pathEps" min="0" max="50" step="0.1"
            onchange="onPathEpsChange()" placeholder="manual override"
            title="Path inclination in milliradians. Reduces multipath probability in ITU-R P.530. Auto-calculated from antenna AGL heights; enter manually to override.">
          <div class="hint" id="pathEpsHint">Auto-calculated from antenna heights</div>
        </div>
      </div>
    </div>
  </div>
  <!-- ══ SPACE DIVERSITY CARD ══ -->
  <div class="card" id="sdCard" style="display:none">
    <div class="card-hdr">&#128268; Space Diversity (SD)</div>
    <div class="card-body">
      <div class="fld">
        <div class="lbl" title="Space Diversity: two vertically-separated antennas with IFC 3dB digital combining. Applicable for RFU-D / RFU-D-HP at 4–11 GHz on paths subject to reflected terrain multipath. ITU-R P.530-17 §9.2.">Enable SD</div>
        <div style="display:flex;align-items:center;gap:10px;padding:4px 0">
          <label class="toggle-switch" id="sdSwitch" title="Enable Space Diversity improvement calculation (ITU-R P.530-17). Only applicable for RFU-D / RFU-D-HP / IP-20C-HP at 4–11 GHz.">
            <input type="checkbox" id="sdChk" onchange="onSdChange(this.checked)">
            <span class="toggle-slider"></span>
          </label>
          <span style="font-size:12px;font-weight:600;color:var(--text2)">IFC 3dB combining</span>
        </div>
        <div class="hint">Reflected terrain · RFU-D / RFU-D-HP / IP-20C-HP · 4–11 GHz</div>
      </div>
      <div class="fld" id="sdSepFld" style="display:none">
        <div class="lbl" title="Vertical antenna separation in metres, centre-to-centre. Typical range: 3–15 m. Larger separation → higher diversity gain.">Antenna Separation (m)</div>
        <input type="number" id="sdSepInp" min="1" max="30" step="0.5" value="12"
          onchange="state.sdSep=Math.max(1,+this.value);redrawTerrainOverlays();update()"
          title="Vertical centre-to-centre separation between the two diversity antennas (metres). Typical: 3–15 m. ITU-R P.530-17 §9.2.">
        <div class="hint">3–15 m typical · larger = more diversity gain</div>
      </div>
      <div id="sdImprovBadge" style="display:none;margin-top:6px;background:var(--green-l);border:1px solid var(--green);border-radius:8px;padding:8px 12px">
        <div style="font-size:10px;color:var(--green-d);font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">SD Improvement (I<sub>SD</sub>)</div>
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span id="sdImprovDb" style="font-size:18px;font-weight:700;color:var(--green-d);font-family:'JetBrains Mono',monospace">—</span>
          <span id="sdImprovFactor" style="font-size:11px;color:var(--green-d);font-weight:600;background:#d1fae5;padding:3px 9px;border-radius:6px">—</span>
        </div>
      </div>
    </div>
  </div>
  <!-- ══ END SPACE DIVERSITY CARD ══ -->

  <!-- ══ CO-CHANNEL XPD CARD ══ -->
  <div class="card" id="xpdCard" style="display:none">
    <div class="card-hdr">&#128225; Co-channel XPD</div>
    <div class="card-body">
      <div class="fld">
        <div class="lbl" title="Enable cross-polarization discrimination degradation analysis (ITU P.530-8). Shows C/I protection ratio for multipath and rain per modulation.">Co-channel Analysis</div>
        <div style="display:flex;align-items:center;gap:10px;padding:4px 0">
          <label class="toggle-switch">
            <input type="checkbox" id="xpdChk" onchange="state.xpdEnabled=this.checked;render()">
            <span class="toggle-slider"></span>
          </label>
          <span style="font-size:12px;font-weight:600;color:var(--text2)">XPD Analysis</span>
        </div>
      </div>
      <div id="xpdFields" style="display:none">
        <div class="fld">
          <div class="lbl" title="Minimum antenna XPD (cross-polarization discrimination) at boresight, dB. Applied equally to TX and RX antennas.">Antenna XPD (dB)</div>
          <input type="number" id="antennaXpd" min="20" max="50" step="1" value="30"
            onchange="state.antennaXpd=+this.value;render()"
            title="Antenna XPD boresight value (dB). Default 30 dB. XPD₀ = XPD+5 if XPD≤35, else 40.">
          <div class="hint">Boresight XPD — same Tx and Rx · default 30 dB</div>
        </div>
        <div class="fld">
          <div class="lbl" title="XPIC (Cross-Polarization Interference Canceller) device — provides XPIF dB of cancellation per modulation from the XPIF table.">XPIC Device</div>
          <div style="display:flex;align-items:center;gap:10px;padding:4px 0">
            <label class="toggle-switch">
              <input type="checkbox" id="xpicChk" onchange="state.xpicEnabled=this.checked;render()">
              <span class="toggle-slider"></span>
            </label>
            <span style="font-size:12px;font-weight:600;color:var(--text2)">XPIC enabled</span>
          </div>
          <div class="hint">XPIF values from Ceragon product table</div>
        </div>
      </div>
    </div>
  </div>
  <!-- ══ END CO-CHANNEL XPD CARD ══ -->

  <div class="card">
    <div class="card-hdr">&#127783;&#65039; Path &amp; Rain</div>
    <div class="card-body">
      <div class="fld"><div class="lbl" title="Link path length. Directly affects free-space loss, rain path length, and multipath fading probability. Click 'Max' to calculate maximum range per modulation.">Distance (<span id="distUnitLbl">km</span>)</div>
        <div class="dist-row">
          <input type="number" id="distance" min="0.1" max="50" step="0.1" value="1.8" title="Path length in km (or miles). Longer = more FSL and rain attenuation. Use Max button to find maximum range at target availability.">
          <button class="max-btn" id="maxBtn" onclick="calcMaxDistAll()">&#128207; Max</button>
        </div>
        <div class="max-panel" id="maxPanel">
          <div class="max-panel-hdr">
            <span>Max Range @ Target Availability</span>
            <button onclick="document.getElementById('maxPanel').classList.remove('visible')">&times;</button>
          </div>
          <table class="max-tbl"><tbody id="maxTbody"></tbody></table>
        </div>
      </div>
      <div class="fld"><div class="lbl" title="ITU-R rain zone defining R₀.₀₁ — rain rate exceeded 0.01% of an average year (about 53 min/yr). Higher zone = more rain = more outage. 'From Map' fetches ITU-R P.837-8 data from the site coordinates.">Rain Zone</div>
        <select id="rainZone" onchange="onRainZone()" title="Select ITU-R rain zone or enter custom R₀.₀₁ rate. 'From Map' requires pinned site coordinates and uses ITU-R P.837-8 interpolated rain rate maps.">
          <option value="42" selected>Manual</option>
          <option value="8">A (8 mm/h)</option>
          <option value="12">B (12 mm/h)</option>
          <option value="15">C (15 mm/h)</option>
          <option value="19">D (19 mm/h)</option>
          <option value="22">E (22 mm/h)</option>
          <option value="28">F (28 mm/h)</option>
          <option value="30">G (30 mm/h)</option>
          <option value="32">H (32 mm/h)</option>
          <option value="35">J (35 mm/h)</option>
          <option value="42" selected>K (42 mm/h)</option>
          <option value="60">L (60 mm/h)</option>
          <option value="63">M (63 mm/h)</option>
          <option value="95">N (95 mm/h)</option>
          <option value="145">P (145 mm/h)</option>
          <option value="115">Q (115 mm/h)</option>
          <option value="map" id="rainMapOpt" disabled style="color:#0891b2;font-style:italic">&#128205; From Map</option>
        </select>
        <input type="number" id="rainCustom" min="1" max="300" step="1" value="42" style="margin-top:5px;display:none" placeholder="Custom R0.01 (mm/h)" title="Custom R₀.₀₁ rain rate in mm/h — rain rate exceeded 0.01% of a year. Enter site-specific measurement or ITU-R P.837-8 extracted value.">
      </div>
      <div class="fld"><div class="lbl" title="Terrain roughness C factor (retained for reference / legacy export). Not used in the active ITU-R P.530-18 path reduction calculation, which derives d₀_eff from frequency and rain rate.">C Factor (terrain)</div>
        <div class="c-row">
          <button class="c-btn" onclick="setCFactor(0)" title="Smooth terrain / flat ground">Smooth</button>
          <button class="c-btn active" onclick="setCFactor(2)" title="Average terrain roughness — default">Average</button>
          <button class="c-btn" onclick="setCFactor(4)" title="Rough / mountainous terrain">Rough</button>
        </div>
        <input type="number" id="cFactor" min="0" max="6" step="0.5" value="2" title="Terrain roughness C factor (legacy/reference only). ITU-R P.530-18 path reduction uses a frequency-dependent d₀_eff formula instead.">
      </div>
      <div class="fld">
        <div class="lbl" title="Minimum acceptable link availability. Higher target = stricter requirement. Modulations in green meet this target; amber = within 0.5%; red = below target.">Target Availability (%)</div>
        <select id="targetAvail" onchange="state.targetAvail=+this.value;update()" title="Required link availability. 99.999% = ITU-R high-grade; 99.995% = typical backhaul; 99.9% = relaxed. Tighter target = fewer viable modulations at a given distance.">
          <option value="99">99.000 %</option>
          <option value="99.5">99.500 %</option>
          <option value="99.9">99.900 %</option>
          <option value="99.95">99.950 %</option>
          <option value="99.99">99.990 %</option>
          <option value="99.995" selected>99.995 %</option>
          <option value="99.998">99.998 %</option>
          <option value="99.999">99.999 %</option>
          <option value="100">100.000 %</option>
        </select>
        <div class="hint" id="tgtHint"></div>
      </div>
    </div>
  </div>
</div>

  
<div class="res-panel">
