// P.530-16 used a frequency-INDEPENDENT formula: d0 = 35·exp(-0.015·R),
// dEff = d/(1+d/d0). This underestimates availability at high frequencies.
//
// P.530-18 (2021) introduced a frequency-dependent correction χ(f) that
// reduces the effective path distance factor d0_eff = d0/χ(f) for frequencies
// above ~10 GHz. Higher χ → shorter effective path → less predicted rain
// attenuation → better availability — especially significant for:
//   · E-band (70/80 GHz): r improvement > 35% at 10 km
//   · 26–40 GHz: r improvement ~10–20% at 10 km
//   · <15 GHz: negligible change
//
// Calibration reference (R=40 mm/h, d=10 km, verified against ITU-R comparison):
//   f=19 GHz: r_P530-18=0.627 vs r_P530-16=0.658 → χ=1.145
//   f=37 GHz: r_P530-18=0.520 vs r_P530-16=0.658 → χ=1.777
//   f=80 GHz: r_P530-18=0.427 vs r_P530-16=0.658 → χ=2.583
//
// Note: The full P.530-18 formula also produces r > 1.0 for very short
// high-frequency paths (<1.5 km at 80 GHz) due to rain cell concentration
// effects. This implementation uses the 1/(1+d/d0_eff) form, which correctly
// captures the long-range behaviour (the commercially relevant case for
// availability calculations on links > 2 km).
// Rain rate is capped at 100 mm/h per P.530-18 §2.3.1.

function calcP530_18_chi(f) {
  // Frequency-dependent path reduction correction factor χ(f).
  // χ = 1.0 → P.530-18 identical to P.530-16 (low frequencies)
  // χ > 1.0 → P.530-18 predicts less rain fade than P.530-16
  // Piecewise-linear interpolation from calibrated reference points.
  // Reference points: [frequency GHz, χ]
  const pts = [
    [0,   1.000],   // below 6 GHz: negligible frequency dependence
    [6,   1.000],
    [10,  1.010],   // small correction begins
    [19,  1.145],   // calibrated: r=0.627 at d=10km, R=40
    [26,  1.380],   // interpolated (26 GHz band)
    [37,  1.777],   // calibrated: r=0.520 at d=10km, R=40
    [58,  2.200],   // interpolated (60 GHz V-band)
    [80,  2.583],   // calibrated: r=0.427 at d=10km, R=40
    [86,  2.700],   // slight extrapolation for upper E-band
    [100, 2.900]    // W-band extrapolation
