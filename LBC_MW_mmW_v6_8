async function findHighestNearSite(site){
  const latEl = document.getElementById('siteLat'+site);
  const lonEl = document.getElementById('siteLon'+site);
  const radEl = document.getElementById('searchRadius'+site);
  if(!latEl||!lonEl){alert('Please set Site '+site+' location first.');return;}
  const lat = parseFloat(latEl.value);
  const lon = parseFloat(lonEl.value);
  if(isNaN(lat)||isNaN(lon)){alert('Please set Site '+site+' coordinates first.');return;}
  const radius = parseFloat(radEl?.value)||100;
  const radiusM = isFCC()?ftToM(radius):radius;

  const btn = document.querySelector('[onclick="findHighestNearSite(\'' + site + '\')"]');
  if(btn){btn.textContent='⏳ 5s…';btn.disabled=true;}
  let _scanCountdown=5;
  const _scanTimer=setInterval(()=>{
    _scanCountdown=Math.max(0,_scanCountdown-1);
    if(btn)btn.textContent='⏳ '+Math.max(1,_scanCountdown)+'s…';
    if(_scanCountdown<=0){
      clearInterval(_scanTimer);
      controller.abort(); // force abort so fetch resolves immediately
    }
  },1000);

  try{
    // Generate 24 ring points + centre = 25 elevation queries
    const pts = radialPoints(lat, lon, radiusM, 16);
    const locations = pts.map(p=>({latitude:parseFloat(p.lat.toFixed(6)),longitude:parseFloat(p.lon.toFixed(6))}));

    // Fetch elevations with 5s timeout — try both APIs in parallel, take first success
    let elevations = null;
    const controller = new AbortController();
    const timeoutId = setTimeout(()=>controller.abort(), 5000);

    async function tryApi(url, body){
      const r = await fetch(url, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify(body), signal: controller.signal
      });
      if(!r.ok) throw new Error('HTTP '+r.status);
      const d = await r.json();
      const result = d.results || (d.status==='OK' ? d.results : null);
      if(!result) throw new Error('Bad response');
      return result.map(e => e.elevation ?? 0);
    }

    try{
      // Race both APIs — whichever responds first wins
      elevations = await Promise.any([
        tryApi('https://api.opentopodata.org/v1/srtm90m', {locations}),
        tryApi('https://api.open-elevation.com/api/v1/lookup', {locations})
      ]);
    }catch(e){
      if(e.name==='AbortError'||controller.signal.aborted)
        throw new Error('Scan timed out (5s) — elevation API too slow or unavailable');
      throw new Error('Elevation data unavailable — check network connection');
    }finally{
      clearTimeout(timeoutId);
      clearInterval(_scanTimer);
    }
    if(!elevations) throw new Error('No elevation data returned');

    // Find highest point
    let maxElev = -Infinity, maxIdx = 0;
    elevations.forEach((e,i)=>{if(e>maxElev){maxElev=e;maxIdx=i;}});
    const centre = elevations[0];  // index 0 is the centre point
    const best = pts[maxIdx];
    const gainM = maxElev - centre;

    if(maxIdx === 0){
      alert('Site ' + site + ' is already the highest point within the ' + radius + ' ' + lenUnitLbl() + ' radius. Elevation: ' + fmtLen(centre));
