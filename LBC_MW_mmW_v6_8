// Detect nominal band (integer GHz key) from a frequency in MHz
function detectMwBand(freqMHz){
  for(const [band,r] of Object.entries(MW_BAND_RANGES)){
    if(freqMHz>=r.low && freqMHz<=r.high) return +band;
  }
  return null;
}
function populateMwBands(){
  const product=state.mwProduct||'IP-20C';
  const supportedBands=MW_PRODUCT_BANDS[product]||MW_PRODUCT_BANDS['IP-20C'];
  const sel=document.getElementById('mwBandSel'); if(!sel)return;
  const prev=state.mwBand;
  sel.innerHTML='';
  supportedBands.forEach(b=>{
    const r=MW_BAND_RANGES[b]; if(!r)return;
    const o=document.createElement('option');
    o.value=b;
    o.textContent=b;
    sel.appendChild(o);
  });
  // Pick closest to previous band
  const pick=supportedBands.includes(prev)?prev:supportedBands[0];
  sel.value=pick;
  applyMwBandRange(+pick, false);
}
// Apply range constraints for a selected nominal band, optionally keeping existing freq
function applyMwBandRange(band, keepFreq){
  const r=MW_BAND_RANGES[band]; if(!r)return;
  const inp=document.getElementById('mwFreq'); if(!inp)return;
  const lowGHz=(r.low/1000);
  const highGHz=(r.high/1000);
  inp.min=lowGHz.toFixed(3); inp.max=highGHz.toFixed(3);
  const lStr=lowGHz.toFixed(2).replace(/\.?0+$/,'');
  const hStr=highGHz.toFixed(2).replace(/\.?0+$/,'');
  inp.placeholder=lStr+' – '+hStr+' GHz';
  const hint=document.getElementById('mwFreqHint');
  if(hint)hint.textContent='Range: '+lStr+' – '+hStr+' GHz';
  state.mwBand=band;
  state.freq=band;
  // Determine frequency: snap to preset (center by default) or keep if valid
  const presets=r.presets||[];
  let newMHz, presetIdx;
  if(keepFreq && state.freqMHz>=r.low && state.freqMHz<=r.high){
    // Keep current freq, find nearest preset index for buttons/hint
    newMHz=state.freqMHz;
    let minD=Infinity;
    presets.forEach((p,i)=>{const d=Math.abs(p-newMHz);if(d<minD){minD=d;presetIdx=i;}});
  } else {
    // Default: center preset
    presetIdx=presets.length>0?Math.floor((presets.length-1)/2):0;
    newMHz=presets.length>0?presets[presetIdx]:Math.round((r.low+r.high)/2);
  }
  const newGHz=parseFloat((newMHz/1000).toFixed(3));
  inp.value=newGHz;
  state.freqMHz=newMHz;
  updateMwFreqPresetHint(band,presetIdx);
  updateMwStepButtons(band,presetIdx);
}
