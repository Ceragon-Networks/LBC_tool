// ===== CAPACITY vs AVAILABILITY STEP CHART =====
let capChart=null;
const AVAIL_STEPS=[99,99.5,99.9,99.95,99.99,99.995,99.998,99.999,100];

function getBestModCap(avail,fi){
  if(avail>=100)return{mod:'None',cap:0};
  const vMods=validMods(state.bw);
  const res=computeWith(Object.assign({},state,{targetAvail:avail}));
  // Iterate from highest to lowest valid modulation
  for(let i=vMods.length-1;i>=0;i--){
    const mod=vMods[i];
    const mr=res.mods.find(m=>m.mod===mod);
    if(!mr||mr.avail<avail)continue;
    const cap=getCap(state.bw,mod,fi);
    if(cap===null)continue; // skip mods with no capacity at this BW
    return{mod,cap};
  }
  return{mod:'None',cap:0};
}

function getCapChartColors(){
  const dark=document.documentElement.getAttribute('data-theme')==='dark';
  if(!dark)return CLR; // original colours
  // Brighter versions for dark backgrounds
  return["#a78bfa","#c084fc","#60a5fa","#22d3ee","#34d399","#86efac","#fbbf24","#f87171","#fc8181","#e879f9"];
}
