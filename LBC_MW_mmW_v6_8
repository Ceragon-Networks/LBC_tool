// ===== CLIMATE & R001 INTEGRATION =====

const R001_GRID_B64="";
const R001_NROWS=361,R001_NCOLS=721,R001_LAT0=-90,R001_LON0=-180,R001_STEP=0.5;
let r001grid=null;

async function loadR001Grid(){
  try{
    const binary=atob(R001_GRID_B64);
    const bytes=new Uint8Array(binary.length);
    for(let i=0;i<binary.length;i++)bytes[i]=binary.charCodeAt(i);
    const ds=new DecompressionStream('gzip');
    const writer=ds.writable.getWriter();writer.write(bytes);writer.close();
    const chunks=[];const reader=ds.readable.getReader();
    while(true){const{done,value}=await reader.read();if(done)break;chunks.push(value);}
    let total=chunks.reduce((s,c)=>s+c.length,0);
    const buf=new Uint8Array(total);let off=0;
    for(const c of chunks){buf.set(c,off);off+=c.length;}
    r001grid=new Float32Array(buf.buffer);
    console.log('R001 grid loaded:',r001grid.length,'cells');
    const _lat=parseFloat(document.getElementById('siteLatA')?.value);
    const _lon=parseFloat(document.getElementById('siteLonA')?.value);
    if(!isNaN(_lat)&&!isNaN(_lon))applyMapR001(_lat,_lon);
  }catch(e){console.warn('R001 load failed:',e.message);}
}

function getR001(lat,lon){
  if(!r001grid)return null;
  lat=Math.max(-90,Math.min(90,lat));
  lon=((lon+180)%360+360)%360-180;
  const fi=(lat-R001_LAT0)/R001_STEP,fj=(lon-R001_LON0)/R001_STEP;
  const i0=Math.min(Math.floor(fi),R001_NROWS-2),j0=Math.min(Math.floor(fj),R001_NCOLS-2);
  const i1=i0+1,j1=j0+1,t=fi-i0,s=fj-j0;
  return (1-t)*(1-s)*r001grid[i0*R001_NCOLS+j0]+(1-t)*s*r001grid[i0*R001_NCOLS+j1]
        +t*(1-s)*r001grid[i1*R001_NCOLS+j0]+t*s*r001grid[i1*R001_NCOLS+j1];
}

function rainZone(r){
  if(r<2)return 'A';if(r<5)return 'B';if(r<8)return 'C';if(r<13)return 'D';
  if(r<19)return 'E';if(r<28)return 'F';if(r<30)return 'G';if(r<32)return 'H';
  if(r<35)return 'J';if(r<45)return 'K';if(r<65)return 'M';if(r<95)return 'N';
  return 'P';
}

function applyMapR001(lat,lon){
  const r=getR001(lat,lon);
  if(r===null)return;
  state.mapR001=r;
  const zone=rainZone(r);
  const mapOpt=document.getElementById('rainMapOpt');
  if(mapOpt){mapOpt.disabled=false;mapOpt.textContent='● From Map — '+r.toFixed(1)+' mm/h (Zone '+zone+')';}
  const rz=document.getElementById('rainZone');
  const rc=document.getElementById('rainCustom');
  if(rz){rz.value='map';if(rc)rc.style.display='none';}
  state.rainRate=r;
  const note=document.getElementById('atmModeNote');
  if(note&&!state.useClimate)note.innerHTML='<span style="color:#0891b2">● Rain from map: '+r.toFixed(1)+' mm/h (ITU-R P.837-8, Zone '+zone+')</span>';
  update(true);
}

function calcWVD(T,RH){if(T==null||RH==null)return null;return(216.7*RH/(100*(T+273.15)))*6.112*Math.exp(17.67*T/(T+243.5));}
function arrMean(arr){const v=(arr||[]).filter(x=>x!=null);return v.length?v.reduce((a,b)=>a+b,0)/v.length:null;}

