function mwCableLoss(config, band){
  const row=MW_CABLE_LOSS[config]||MW_CABLE_LOSS['1+0'];
  const keys=Object.keys(row);
  const k=row[String(band)]!=null?String(band):nearestKey(Number(band),keys);
  return row[k]??0;
}
// Total Branching Loss = direct BL + cable loss × (number of remote sites)
// mountA/mountB are resolved effective mounts ('direct'|'remote') for each site
function mwBranchLoss(mount, config, band, mountA, mountB){
  // Direct BL from table
  const tbl=MW_DATA.loss.direct;
  const row=tbl[config]||tbl['1+0']; if(!row) return 0;
  const keys=Object.keys(row);
  const k=row[String(band)]!=null?String(band):nearestKey(Number(band),keys);
  const directBL=row[k]??0;
  // Cable loss: add per remote site
  const cable=mwCableLoss(config,band);
  const remoteA=(mountA||mount)==='remote'?1:0;
  const remoteB=(mountB||mount)==='remote'?1:0;
  return directBL + cable*(remoteA+remoteB);
}
// Resolve effective mount for ONE site: remote forced if its antenna > 6ft/1.8m
function mwResolveMountSite(userMount, antSize, std){
  const big = std==='FCC' ? (antSize > 6) : (antSize > 1.8);
  return (big || userMount==='remote') ? 'remote' : 'direct';
}
// Overall effective mount: remote if EITHER site is remote (for BL table lookup)
function mwResolveMount(userMount, antA, antB, std){
  const mA = mwResolveMountSite(state.mwMountA||'direct', antA, std);
  const mB = mwResolveMountSite(state.mwMountB||'direct', antB, std);
  return (mA==='remote'||mB==='remote') ? 'remote' : 'direct';
}
// TX power (dBm) for product/band/mod
function mwTx(product, band, mod, bw){
  const k=mwTxKey(product,bw);
  const t=MW_DATA.tx[k]; if(!t) return null;
  const md=t.mods[mod]; if(!md) return null;
  const keys=Object.keys(md);
  const bk=md[String(band)]!=null?String(band):nearestKey(Number(band),keys);
  const v=md[bk];
  return (v==null||v===0)?null:v; // 0 in table = not supported (e.g. 24 GHz)
}
// Guaranteed BER-6 RSL threshold (dBm) for product/bw/mod/band
function mwRslBase(product, bw, mod, band){
  const k=mwRslKey(product);
  const r=MW_DATA.rsl[k]; if(!r) return null;
  const bwKeys=Object.keys(r.data);
  const bwk=r.data[String(bw)]?String(bw):nearestKey(Number(bw),bwKeys);
  const row=r.data[bwk]; if(!row) return null;
  const md=row[mod]; if(!md) return null;
  const keys=Object.keys(md);
  const bk=md[String(band)]!=null?String(band):nearestKey(Number(band),keys);
  const v=md[bk];
  return v==null?null:v;
}
// Typical delta (dB, positive number to subtract) for product/band
function mwTypDelta(product, band){
  const col=mwFamily(product).delta;
  const d=MW_DATA.rsldelta;
  const bk=d[String(band)]?String(band):nearestKey(Number(band),Object.keys(d));
  const row=d[bk]; if(!row) return 1.0;
  return row[col]??1.0;
}
// DFM (dB) for product/bw/mod  (guaranteed BER-6 baseline)
function mwDfm(product, bw, mod, perf, ber){
  const fam=mwFamily(product).dfm;
  // find DFM row: bw match (nearest) AND family column == mod
  const cand=MW_DATA.dfm.filter(r=>r[fam]===mod);
  if(!cand.length) return null;
  let best=null,bd=Infinity;
  cand.forEach(r=>{const dd=Math.abs(Number(r.bw)-Number(bw));if(dd<bd){bd=dd;best=r;}});
  if(!best||best.dfm==null) return null;
  let v=Number(best.dfm);
  if(perf==='typ') v+=0.2;   // typical +0.2 dB
  if(ber==='e3')  v+=0.4;    // BER E-3 +0.4 dB
  return v;
}
// Effective fade margin from flat margin + dispersive fade margin
function effFM(flatFM, dfm){
  if(dfm==null||!isFinite(dfm)) return flatFM;
  return -10*Math.log10(Math.pow(10,-flatFM/10)+Math.pow(10,-dfm/10));
}
// Path inclination |εp| (mrad) from antenna heights (m AGL) + site elevations + distance(km)
function pathInclination(){
  const d=state.distance||0.001;
  let dh=null;
  try{
    const hA=parseFloat(document.getElementById('antHgtA')?.value);
    const hB=parseFloat(document.getElementById('antHgtB')?.value);
    if(isFinite(hA)&&isFinite(hB)){
      let a=hA,b=hB;
      if(isFCC()){a=ftToM(a);b=ftToM(b);}
      // add site ground elevations if terrain data present
      const eA=window._terrainData?.elevations?.[0];
      const eB=window._terrainData?.elevations?.[window._terrainData.elevations.length-1];
      if(isFinite(eA)&&isFinite(eB)){ a+=eA; b+=eB; }
      dh=Math.abs(a-b);
    }
  }catch(e){}
  if(dh==null) return 0;
  return dh/d; // m / km = mrad
}
// Multipath outage probability (% of time) per reliability method, using EFM
function mwMultipath(method, EFM, d, f, eps, K, vbC){
  if(EFM<=0) return 100;
  const fade=Math.pow(10,-EFM/10);
  if(method==='VB'){
    // Vigants-Barnett (Pathloss Eq.15, d in km):
    //   P = 6×10⁻⁷ · C · f · d³ · 10^(-A/10)
    // C = 0.25 (mountainous/dry), 1.0 (average), 4.0 (over water/coastal)
    // vbC is the direct C factor value
    const C = (vbC!=null&&isFinite(vbC)&&vbC>0) ? vbC : 1.0;
    return Math.min(6e-7 * C * f * Math.pow(d,3) * fade * 100, 100);
    // ×100: VB formula outputs a fraction; multiply to get %
  }
  if(method==='P530-78'){
    // ITU-R P.530-7/8 (Eq.28): pw(%) = K·d^3.6·f^0.89·(1+|εp|)^-1.4·10^(-EFM/10)
    // Formula result is already in % — no ×100 needed
    return Math.min(K*Math.pow(d,3.0)*Math.pow(f,0.89)*Math.pow(1+Math.abs(eps),-1.4)*fade, 100);
  }
  // ITU-R P.530-17 (updated exponent d^3.6):
  return Math.min(K*Math.pow(d,3.6)*Math.pow(f,0.89)*Math.pow(1+Math.abs(eps),-1.4)*fade, 100);
}

function computeWith(s){
  const{freq:f,bw,pol,antA,antB,bl,cFactor:C,rainRate:R,distance:d,targetAvail:ta}=s;
  if(s.isMW){
    // ---- Microwave link budget ----
    const product=s.mwProduct||'IP-20C';
    const band=s.mwBand||f;                 // discrete band (GHz)
    const std=s.std||'ETSI';
    const FSL=fslFn(d,band);
    const atm=(typeof getAtmos==="function"?getAtmos(band):aLerp(band));
    const atmLoss=(atm.gW+atm.gO)*d;
    const Gt=mwGain(antA,band,std), Gr=mwGain(antB,band,std);
    const mount=mwResolveMount(null,antA,antB,std);
    const mA=mwResolveMountSite(state.mwMountA||'direct',antA,std);
    const mB=mwResolveMountSite(state.mwMountB||'direct',antB,std);
    const blMW=mwBranchLoss(mount,s.config||'1+0',band,mA,mB)+(s.miscLoss||0);
    const rain=calcRain(band,pol,R,d);
    const perf=s.rslMode&&s.rslMode.indexOf('e3')>=0?'e3':'e6';  // not used directly; see below
    const isTyp=(s.rslMode||'typ_e6').indexOf('typ')===0;
    const isE3=(s.rslMode||'typ_e6').indexOf('e3')>=0;
    const method=s.relMethod||'P530-17';
    const K=(s.geoK!=null&&isFinite(s.geoK))?s.geoK:1e-4;
    const eps=(s.pathEps!=null&&isFinite(s.pathEps))?s.pathEps:pathInclination();
    const C=s.cFactor;
    const modList=mwMods(product,bw,band);
    const lowest=modList[0];                 // lowest profile (BPSK/QPSK) — no ACM offset
    const mods=modList.map(mod=>{
      const tx=mwTx(product,band,mod,bw);
      if(tx==null) return null;              // band not supported for this product/mod
      const baseRSL=mwRslBase(product,bw,mod,band);
      if(baseRSL==null) return null;         // mod/BW not supported
      const acmOffset=(s.acm && mod!==lowest)?3.5:0;
      const typOffset=isTyp? -mwTypDelta(product,band):0;  // typical thresholds are lower
      const berOffset=isE3? -0.5:0;          // BER E-3 is 0.5 dB lower
      const rsl=baseRSL+typOffset+berOffset+acmOffset;
      if(Gt==null||Gr==null) return null;
      const rxu=tx+Gt+Gr-FSL-atmLoss-blMW;
      const ffm=rxu-rsl;                      // flat (thermal) fade margin
      const dfm=mwDfm(product,bw,mod,isTyp?'typ':'gty',isE3?'e3':'e6');
      const efm=effFM(ffm,dfm);               // effective (flat ⊕ dispersive)
      const pR=rainPct(rain.A001,ffm);        // rain uses flat margin
      const vbC=(s.vbCFactor!=null&&isFinite(s.vbCFactor))?s.vbCFactor:1.0;
      const pM=mwMultipath(method,efm,d,band,eps,K,vbC); // multipath uses EFM; VB uses vbCFactor, P530 uses K
      // ── Space Diversity — Vigants non-selective improvement (ITU P.530-8 Eq.23) ──
      // Applicable: RFU-D / RFU-D-HP / IP-20C-HP, bands 4–11 GHz
      // I_SD = 1.2×10⁻³ × (f/d) × S² × v² × 10^(A/10)
      //   f=GHz, d=km, S=m (centre-to-centre), v=1 (avg), A=flat fade margin (dB)
      // I_SD is per-modulation: larger fade margin → greater diversity gain
      // I_SD < 1 when A < 0 (link in outage) → clamp to 1 (no negative benefit)
      const sdOk=s.sdEnabled&&[4,5,6,7,8,11].includes(Number(band))&&
                 (product==='RFU-D'||product==='RFU-D-HP'||product==='IP-20C-HP');
      const sdS=s.sdSep||12;
      const I_SD=sdOk&&ffm>0?Math.max(1, 1.2e-3*(Number(band)/d)*sdS*sdS*Math.pow(10,ffm/10)):1;
      const pM_used=sdOk?Math.max(0,pM/I_SD):pM;
      const sdDb=sdOk&&I_SD>1?+(10*Math.log10(I_SD)).toFixed(2):0;
      // ────────────────────────────────────────────────────────────────────────
      const pT=Math.min(pR+pM_used,100);
      const avail=Math.max(0,100-pT);
      // XPD co-channel analysis (per-mod: each mod has its own ffm, pM, XPIF)
      let xpd=null;
      if(s.xpdEnabled){
        const xpif=getXpif(product,bw,mod);
        xpd=calcXpd(ffm,efm,pM,Number(band),c.rain.A001,s.antennaXpd||30,xpif,s.xpicEnabled);
        if(xpd) xpd.xpif=xpif;
      }
      return{mod,tx,rsl,rxu,efm,ffm,dfm,pR,pM,pM_SD:pM_used,pT,avail,sdDb,I_SD:sdOk?I_SD:null,
        rainSec:pR/100*31536e3,mpSec:pM_used/100*31536e3,mpSec_noSD:pM/100*31536e3,totSec:pT/100*31536e3,ok:avail>=ta,xpd};
    }).filter(m=>m!==null);
    return{band:'MW',isMW:true,mwProduct:product,mwBand:band,mount,mountA:mA,mountB:mB,relMethod:method,
      geoK:K,pathEps:eps,FSL,atmLoss,atm,Gt,Gr,bl:blMW,rain,mods};
  }
  const band=f>=130?'D':f>=92?'W':'E';   // E:71-86 W:92-115 D:130-175
  const rslBand=band;                      // E, W, D each have own RSL/TX tables
  const FSL=fslFn(d,f),atm=(typeof getAtmos==="function"?getAtmos(f):aLerp(f)),atmLoss=(atm.gW+atm.gO)*d;
  const Gt=antG(antA,f),Gr=antG(antB,f),rain=calcRain(f,pol,R,d);
  const vModList=validMods(bw);
  const lastMod=vModList[0]; // lowest modulation = last step (no ACM offset)
  const mods=vModList.map(mod=>{
    const txBase=TX[rslBand]?.[mod]??TX['W']?.[mod]??TX['E']?.[mod];
    if(txBase==null)return null;
    const tx=txBase+(s.ePowerHi&&rslBand==='E'?3:0);
    const acmOffset=(s.acm && mod!==lastMod)?3.5:0;
    const baseRSL=RSL[rslBand]?.[mod]?.[bw]??RSL[rslBand]?.[mod]?.[String(bw)];
    if(baseRSL==null)return null; // mod not supported at this BW
    const rslOffset=(RSL_OFFSETS[s.rslMode||'typ_e6']||0);
    const rslV=baseRSL+rslOffset+acmOffset;
    const rxu=tx+Gt+Gr-FSL-atmLoss-bl,efm=rxu-rslV;
    const pR=rainPct(rain.A001,efm),pM=mpPct(efm,d,f,C),pT=Math.min(pR+pM,100);
    const avail=Math.max(0,100-pT);
    if(rslV==null)return null;
    return{mod,tx,rsl:rslV,rxu,efm,pR,pM,pT,avail,
      rainSec:pR/100*31536e3,mpSec:pM/100*31536e3,totSec:pT/100*31536e3,ok:avail>=ta};
  });
  const modsFiltered=mods.filter(m=>m!==null);
  return{band,FSL,atmLoss,atm,Gt,Gr,rain,mods:modsFiltered};
}
function findMaxDistAt(mod,ta){
  const chk=d=>{
    const r=computeWith(Object.assign({},state,{distance:d})).mods.find(m=>m.mod===mod);
    return r?r.avail:0;
  };
  if(chk(.05)<ta)return 0;
  let lo=.05,hi=80;
  for(let i=0;i<44;i++){const mid=(lo+hi)/2;chk(mid)>=ta?lo=mid:hi=mid;}
  return(lo+hi)/2;
}

