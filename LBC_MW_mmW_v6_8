/* ============================ MICROWAVE LINK-BUDGET LAYER ============================
   Data: MW_DATA (TX power, DFM, antenna gain, branching loss, RSL thresholds + deltas).
   All figures are Ceragon equipment tables ingested from MW_radio_parameters.xlsx.
   Reliability (multipath) models are standard published forms — see methodology panel. */

// Product -> key used in TX/RSL/DFM/delta tables
function mwTxKey(product, bw){
  if(product==='IP-50C'||product==='IP-50CX')
    return (bw>=224)?'IP-50C/CX BW equal to 224MHz':'IP-50C/CX BW  less than 224MHz';
  return product; // IP-20C, IP-20C-HP, RFU-D, RFU-D-HP
}
function mwRslKey(product){
  if(product==='IP-50C'||product==='IP-50CX') return 'IP-50C/CX';
  return product;
}
function mwFamily(product){ // for DFM column + delta column
  if(product==='IP-50C'||product==='IP-50CX') return {dfm:'ip50', delta:'IP-50C/CX'};
  if(product==='RFU-D-HP'||product==='IP-20C-HP') return {dfm:(product==='RFU-D-HP'?'rfud':'ip20'), delta:'IP-20C-HP/RFU-D-HP'};
  if(product==='RFU-D') return {dfm:'rfud', delta:'IP-20C/RFU-D'};
  return {dfm:'ip20', delta:'IP-20C/RFU-D'}; // IP-20C
}
// nearest available numeric key in an object/array of numbers
function nearestKey(target, keys){
  let best=null,bd=Infinity;
  keys.forEach(k=>{const v=+k,dd=Math.abs(v-target);if(dd<bd){bd=dd;best=k;}});
  return best;
}
// Ordered modulation list (low->high) for a product at a given BW, from TX table
function mwMods(product, bw, band){
  const k=mwTxKey(product,bw);
  const t=MW_DATA.tx[k]; if(!t) return [];
  const allMods=Object.keys(t.mods);
  // Apply max-modulation cap when band is known
  if(band==null||!isFinite(parseFloat(band))) return allMods;
  const cap=mwMaxMod(product,bw,band);
  if(!cap) return allMods;
  const capIdx=allMods.indexOf(cap);
  if(capIdx<0) return allMods; // cap name not in this product's list → no cut
  return allMods.slice(0, capIdx+1);
}
// Available antenna sizes for band+standard (from gain table)
function mwSizes(band, std){
  const m=MW_DATA.asize[std]||{};
  return m[String(band)]||m[String(band)+'.0']||m[band]||[];
}
// Antenna gain (dBi) for a given size (ETSI m if std=ETSI, FCC ft if std=FCC), band
function mwGain(size, band, std){
  // gainmap keyed by "band|etsiSize" and "band|ftFccSize"
  const b=Number(band);
  const tryKeys = std==='FCC'
    ? [`${b}|ft${Number(size)}`, `${b}.0|ft${Number(size)}`, `${b}|ft${Number(size)}.0`]
    : [`${b}|${Number(size)}`, `${b}.0|${Number(size)}`, `${b}|${Number(size)}.0`];
  for(const kk of tryKeys){ if(MW_DATA.gainmap[kk]!=null) return MW_DATA.gainmap[kk]; }
  // fallback: match by size pair
  for(const s of MW_DATA.gainsizes){
    const sz = std==='FCC'? Number(s.fcc): Number(s.etsi);
    if(Math.abs(sz-Number(size))<1e-6){
      const g=s.g[String(b)]??s.g[String(b)+'.0']??s.g[b];
      if(g!=null) return g;
    }
  }
  return null;
}
