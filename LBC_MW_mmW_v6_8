// Carriers per configuration (from "Capacity per carrier" sheet)
const MW_CARRIERS={'1+0':1,'1+1':1,'2+0':2,'2+2':2,'4+0':4};

// Nearest BW key for MW_CAP lookup
function mwNearestBw(product, bwMHz){
  const tbl=MW_CAP[product]; if(!tbl) return null;
  const keys=Object.keys(tbl).map(Number).sort((a,b)=>a-b);
  if(!keys.length) return null;
  let best=keys[0], bestD=Math.abs(keys[0]-bwMHz);
  for(const k of keys){const d=Math.abs(k-bwMHz);if(d<bestD){bestD=d;best=k;}}
  return String(best);
}

// Unified getCap — mmW uses CAPACITY table, MW uses MW_CAP × carriers
function getCap(bw, mod, fi){
  if(state.isMW){
    const product=state.mwProduct||'IP-20C';
    const bwKey=mwNearestBw(product, parseFloat(bw));
    if(!bwKey) return null;
    const row=MW_CAP[product]?.[bwKey]?.[mod];
    if(!row) return null;
    const v=row[fi];
    if(v==null) return null;
    return v * (MW_CARRIERS[state.config||'1+0']||1);
  }
  const row=(CAPACITY[+bw]||CAPACITY[String(bw)])?.[mod];
  if(!row) return null;
  const v=row[fi];
  if(v==null) return null;
  return state.config==='2+0'?v*2:v;
}
function fmtCap(v){if(v===null||v===undefined)return'N/A';return v>=1000?(v/1000).toFixed(2)+' Gbps':v.toFixed(1)+' Mbps';}

