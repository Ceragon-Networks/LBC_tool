function calcGeoK(){
  // Resolve coordinates — markers first, then input fields
  let latA=null,lonA=null,latB=null,lonB=null;
  if(typeof siteMarkerA!=='undefined'&&siteMarkerA){const ll=siteMarkerA.getLatLng();latA=ll.lat;lonA=ll.lng;}
  if(typeof siteMarkerB!=='undefined'&&siteMarkerB){const ll=siteMarkerB.getLatLng();latB=ll.lat;lonB=ll.lng;}
  if(latA==null||!isFinite(latA)) latA=parseFloat(document.getElementById('siteLatA')?.value);
  if(lonA==null||!isFinite(lonA)) lonA=parseFloat(document.getElementById('siteLonA')?.value);
  if(latB==null||!isFinite(latB)) latB=parseFloat(document.getElementById('siteLatB')?.value);
  if(lonB==null||!isFinite(lonB)) lonB=parseFloat(document.getElementById('siteLonB')?.value);

  const lat=(isFinite(latA)&&isFinite(latB))?(latA+latB)/2:(isFinite(latA)?latA:(isFinite(latB)?latB:null));
  const lon=(isFinite(lonA)&&isFinite(lonB))?(lonA+lonB)/2:(isFinite(lonA)?lonA:(isFinite(lonB)?lonB:null));

  const hint=document.getElementById('geoKHint');
  if(lat==null||!isFinite(lat)||lon==null||!isFinite(lon)){
    if(hint)hint.textContent='📍 Enter site coordinates or pin sites on the map first';
    return;
  }

  // ── C0: lower antenna altitude × terrain type (ITU-R P.530-7/8 Table 1) ──
  const alt=state.lowerAntAlt||200;
  const ttype=state.terrainType||'hills';
  const C0_TABLE={'low':[0.0,3.5,1.75],'mid':[2.5,6.0,4.25],'high':[5.5,8.0,10.5]};
  const tier=alt<400?'low':alt<700?'mid':'high';
  const tIdx=ttype==='plains'?0:ttype==='hills'?1:2;
  const C0=C0_TABLE[tier][tIdx];

  // ── C_Lat (Eq.29) ──
  const absLat=Math.abs(lat);
  let CLat=0;
  if(absLat>60) CLat=7;
  else if(absLat>53) CLat=absLat-53;

  // ── C_Lon (Eq.29) ──
  let CLon=0;
  if(lon>=-20&&lon<=60) CLon=3;        // Europe / Africa
  else if(lon>=-170&&lon<-20) CLon=-3; // Americas

  // ── P_L: climatic variable approximated from latitude (ITU-R P.453) ──
  let PL=20;
  if(absLat<15) PL=50;
  else if(absLat<30) PL=30;
  else if(absLat<55) PL=20;
  else PL=15;

  // ── Ki: inland K (Eq.29) ──
  const Ki=5e-7*Math.pow(10,-0.1*(C0-CLat-CLon))*Math.pow(PL,1.5);

  // ── Coastal / over-water K (Eq.30 / Eq.31) ──
  const pathType=state.p530PathType||'inland';
  const rc=Math.max(0,Math.min(1,state.p530Rc||0));
  let K_final=Ki;
  let pathLabel='Inland (Eq.29)';

  if(pathType!=='inland'&&rc>0){
    // Kcl for large body of water (Eq.30 numerator):
    //   Kcl = 2.3e-4 × 10^(-0.1·C0 - 0.011·|rc|)
    // Using C0 without CLat/CLon correction as per standard (coastal formula)
    const Kcl=2.3e-4*Math.pow(10,-0.1*C0-0.011*Math.abs(rc));

    if(pathType==='coastal_large'){
      // Eq.30: K = 10^((1-rc)·log10(Ki) + rc·log10(Kcl))   if Kcl >= Ki
      //         K = Ki                                         if Kcl < Ki
      if(Kcl>=Ki){
        K_final=Math.pow(10,(1-rc)*Math.log10(Ki)+rc*Math.log10(Kcl));
        pathLabel='Coastal/large water (Eq.30) rc='+rc.toFixed(2);
      } else {
        K_final=Ki;
        pathLabel='Coastal (Eq.30): Kcl<Ki → using inland K';
      }
    } else {
      // coastal_medium: Eq.31
      // Kcm = 10^(0.5·(log10(Ki)+log10(Kcl)))
      const Kcm=Math.pow(10,0.5*(Math.log10(Ki)+Math.log10(Kcl)));
      if(Kcm>=Ki){
        K_final=Math.pow(10,(1-rc)*Math.log10(Ki)+rc*Math.log10(Kcm));
        pathLabel='Coastal/medium water (Eq.31) rc='+rc.toFixed(2);
      } else {
        K_final=Ki;
        pathLabel='Coastal (Eq.31): Kcm<Ki → using inland K';
      }
    }
  }

  state.geoK=K_final;
  const el=document.getElementById('geoK');
  if(el)el.value=K_final.toExponential(2);

  if(hint)hint.textContent=
    pathLabel+' · K='+K_final.toExponential(2)+
    ' ('+lat.toFixed(2)+'°, '+lon.toFixed(2)+'°)';

  update(true);
}
